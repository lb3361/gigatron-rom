                                          1849    anda([channelMask])             #2
                                          1850    adda(1)                         #3
                                          1851    ld(syncBits^hSync,OUT)          #4 Start horizontal pulse
                                          1852
                                          1853    # Horizontal sync and sound channel update for scanlines outside vBlank
                                          1854    label('sound2')
