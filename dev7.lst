videoF:       02ec 0120  ld   [$20]       2092    ld([videoSync1])                #29 Completely black pixel line
              02ed 8080  adda $80         2093    adda(0x80)                      #30
              02ee d220  st   [$20],x     2094    st([videoSync1],X)              #31
              02ef 011f  ld   [$1f]       2095    ld([frameX])                    #32
