                                          2030    # Back porch B: second of 4 repeated scan lines
                                          2031    # - Recompute Xi from dXi and store for retrieval in the next scan lines
                                          2032    label('videoB')
videoB:       02ca 00d3  ld   $d3         2033    ld('videoC')                    #29 2nd scanline of 4
              02cb c20d  st   [$0d]       2034    st([nextVideo])                 #30
              02cc 1401  ld   $01,y       2035    ld(videoTable>>8,Y)             #31
              02cd 0109  ld   [$09]       2036    ld([videoY])                    #32
              02ce 9001  adda $01,x       2037    adda(1,X)                       #33
              02cf 011f  ld   [$1f]       2038    ld([frameX])                    #34
              02d0 8d00  adda [y,x]       2039    adda([Y,X])                     #35
              02d1 fd0a  bra  [$0a]       2040    bra([videoModeB])               #36
              02d2 d21f  st   [$1f],x     2041    st([frameX],X)                  #37 Store in RAM and X
                                          2042
                                          2043    # Back porch C: third of 4 repeated scan lines
                                          2044    # - Nothing new to for video do as Yi and Xi are known,
                                          2045    # - This is the time to emit and reset the next sound sample
                                          2046    label('videoC')
videoC:       02d3 00dc  ld   $dc         2047    ld('videoD')                    #29 3rd scanline of 4
