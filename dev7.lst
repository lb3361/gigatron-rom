                                          1574
                                          1575  if not WITH_128K_BOARD:
                                          1576
              01de 1505  ld   [$05],y     1577    runVcpu(189-80,               #80
              01df c000  st   $00,[$00]
              01e0 00f3  ld   $f3
              01e1 c21e  st   [$1e]
              01e2 e0ff  jmp  y,$ff
              01e3 0020  ld   $20
                                          1578            '---D line 40 select',
                                          1579            returnTo='vBlankEnd#189')
                                          1580    label('.select#70')
.select#70:   01e4 1505  ld   [$05],y     1581    runVcpu(189-70,               #70
              01e5 c000  st   $00,[$00]
              01e6 00f3  ld   $f3
              01e7 c21e  st   [$1e]
              01e8 e0ff  jmp  y,$ff
              01e9 0025  ld   $25
                                          1582            '---D line 40 no select',
                                          1583            returnTo='vBlankEnd#189')
                                          1584    # This must end in 0x1fe and continue
                                          1585    # with the video loop entry point at 0x1ff
              01ea 0200  nop              1586    fillers(until=0xf3)
              01eb 0200  nop
              01ec 0200  nop
              * 9 times
                                          1587    label('vBlankEnd#189')
vBlankEnd#189:
              01f3 1401  ld   $01,y       1588    ld(videoTop_v5>>8,Y)          #189
              01f4 09f9  ld   [y,$f9]     1589    ld([Y,videoTop_v5])           #190
              01f5 c209  st   [$09]       1590    st([videoY])                  #191
              01f6 c21f  st   [$1f]       1591    st([frameX])                  #192
              01f7 ecfa  bne  $01fa       1592    bne(pc()+3)                   #193
              01f8 fcfb  bra  $01fb       1593    bra(pc()+3)                   #194
              01f9 0001  ld   $01         1594    ld('videoA')                  #195
              01fa 00ec  ld   $ec         1595    ld('videoF')                  #195(!)
              01fb c20d  st   [$0d]       1596    st([nextVideo])               #196
              01fc 0102  ld   [$02]       1597    ld([channel])                 #197 Normalize channel for robustness
              01fd 2003  anda $03         1598    anda(0b00000011)              #198
              01fe c202  st   [$02]       1599    st([channel])                 #199
                                          1600
