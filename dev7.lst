              126a de00  st   [y,x++]     6021  st([Y,Xpp])                     #28
              126b 0118  ld   [$18]       6022  ld([vAC+0])                     #29 Pulse: T[4i+2] = 0 if i<32 else 63
              126c 2020  anda $20         6023  anda(0x20)                      #30
              126d ec70  bne  $1270       6024  bne(pc()+3)                     #31
