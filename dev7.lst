              124b 0124  ld   [$24]       6113  ld([sysArgs+0])                 #25+i*12
              124c ce00  st   [y,x]       6114  st([Y,X])                       #26+i*12
              124d 012f  ld   [$2f]       6115  ld([vTmp])                      #27+i*12
              124e a007  suba $07         6116  suba(7)                         #28+i*12
              124f ec45  bne  .sysVdb0    6117  bne('.sysVdb0')                 #29+i*12
              1250 8008  adda $08         6118  adda(8)                         #30+i*12
              1251 1403  ld   $03,y       6119  ld(hi('REENTER'),Y)             #115
              1252 e0cb  jmp  y,$cb       6120  jmp(Y,'REENTER')                #116
              1253 00c4  ld   $c4         6121  ld(-120/2)                      #117
                                          6122  label('.sysVdb1')
.sysVdb1:     1254 c226  st   [$26]       6123  st([sysArgs+2])                 #24+i*12
              1255 0125  ld   [$25]       6124  ld([sysArgs+1])                 #25+i*12
              1256 ce00  st   [y,x]       6125  st([Y,X])                       #26+i*12
              1257 012f  ld   [$2f]       6126  ld([vTmp])                      #27+i*12
              1258 a007  suba $07         6127  suba(7)                         #28+i*12
              1259 ec45  bne  .sysVdb0    6128  bne('.sysVdb0')                 #29+i*12
              125a 8008  adda $08         6129  adda(8)                         #30+i*12
              125b 1403  ld   $03,y       6130  ld(hi('REENTER'),Y)             #115
              125c e0cb  jmp  y,$cb       6131  jmp(Y,'REENTER')                #116
