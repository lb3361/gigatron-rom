              0d8e 8115  adda [$15]       4512  adda([vTicks])                  #21
                                          4513  assert (38 - 22)//2 >= v6502_adjust
                                          4514
                                          4515  #-----------------------------------------------------------------------
                                          4516  #       MOS 6502 emulator
                                          4517  #-----------------------------------------------------------------------
                                          4518
                                          4519  # Some quirks:
                                          4520  # - Stack in zero page instead of page 1
                                          4521  # - No interrupts
                                          4522  # - No decimal mode (may never be added). D flag is emulated but ignored.
                                          4523  # - BRK switches back to running 16-bits vCPU
                                          4524  # - Illegal opcodes map to BRK, but can read ghost operands before trapping
                                          4525  # - Illegal opcode $ff won't be trapped and cause havoc instead
                                          4526
                                          4527  # Big things TODO:
                                          4528  # XXX Tuning, put most frequent instructions in the primary page
                                          4529
                                          4530  label('v6502_ror')
                                          4531  assert v6502_Cflag == 1
v6502_ror:    0d8f 1525  ld   [$25],y     4532  ld([v6502_ADH],Y)               #12
              0d90 00fc  ld   $fc         4533  ld(-46//2+v6502_maxTicks)       #13 Is there enough time for the excess ticks?
              0d91 8115  adda [$15]       4534  adda([vTicks])                  #14
              0d92 e8a4  blt  .recheck17  4535  blt('.recheck17')               #15
              0d93 0127  ld   [$27]       4536  ld([v6502_P])                   #16 Transfer C to "bit 8"
              0d94 2001  anda $01         4537  anda(1)                         #17
              0d95 807f  adda $7f         4538  adda(127)                       #18
              0d96 2080  anda $80         4539  anda(128)                       #19
              0d97 c219  st   [$19]       4540  st([v6502_BI])                  #20 The real 6502 wouldn't use BI for this
              0d98 0d00  ld   [y,x]       4541  ld([Y,X])                       #21 Transfer bit 0 to C
              0d99 6127  xora [$27]       4542  xora([v6502_P])                 #22
              0d9a 2001  anda $01         4543  anda(1)                         #23
              0d9b 6127  xora [$27]       4544  xora([v6502_P])                 #24
              0d9c c227  st   [$27]       4545  st([v6502_P])                   #25
              0d9d 00ca  ld   $ca         4546  ld('v6502_ror#36')              #26 Shift table lookup
              0d9e c22f  st   [$2f]       4547  st([vTmp])                      #27
              0d9f 0d00  ld   [y,x]       4548  ld([Y,X])                       #28
              0da0 20fe  anda $fe         4549  anda(~1)                        #29
              0da1 1405  ld   $05,y       4550  ld(hi('shiftTable'),Y)          #30
              0da2 e200  jmp  y,ac        4551  jmp(Y,AC)                       #31
              0da3 fcff  bra  $ff         4552  bra(255)                        #32 bra shiftTable+255
                                          4553  label('.recheck17')
.recheck17:   0da4 140e  ld   $0e,y       4554  ld(hi('v6502_check'),Y)         #17 Go back to time check before dispatch
              0da5 e0f2  jmp  y,$f2       4555  jmp(Y,'v6502_check')            #18
              0da6 00f6  ld   $f6         4556  ld(-20/2)                       #19
                                          4557
                                          4558  label('v6502_lsr')
                                          4559  assert v6502_Cflag == 1
v6502_lsr:    0da7 1525  ld   [$25],y     4560  ld([v6502_ADH],Y)               #12
              0da8 0d00  ld   [y,x]       4561  ld([Y,X])                       #13 Transfer bit 0 to C
              0da9 6127  xora [$27]       4562  xora([v6502_P])                 #14
              0daa 2001  anda $01         4563  anda(1)                         #15
              0dab 6127  xora [$27]       4564  xora([v6502_P])                 #16
              0dac c227  st   [$27]       4565  st([v6502_P])                   #17
              0dad 00c3  ld   $c3         4566  ld('v6502_lsr#28')              #18 Shift table lookup
              0dae c22f  st   [$2f]       4567  st([vTmp])                      #19
              0daf 0d00  ld   [y,x]       4568  ld([Y,X])                       #20
              0db0 20fe  anda $fe         4569  anda(~1)                        #21
              0db1 1405  ld   $05,y       4570  ld(hi('shiftTable'),Y)          #22
              0db2 e200  jmp  y,ac        4571  jmp(Y,AC)                       #23
              0db3 fcff  bra  $ff         4572  bra(255)                        #24 bra shiftTable+255
                                          4573
                                          4574  label('v6502_rol')
                                          4575  assert v6502_Cflag == 1
v6502_rol:    0db4 1525  ld   [$25],y     4576  ld([v6502_ADH],Y)               #12
              0db5 0d00  ld   [y,x]       4577  ld([Y,X])                       #13
              0db6 2080  anda $80         4578  anda(0x80)                      #14
              0db7 c22f  st   [$2f]       4579  st([v6502_Tmp])                 #15
              0db8 0127  ld   [$27]       4580  ld([v6502_P])                   #16
              0db9 2001  anda $01         4581  anda(1)                         #17
                                          4582  label('.rol#18')
.rol#18:      0dba 8d00  adda [y,x]       4583  adda([Y,X])                     #18
              0dbb 8d00  adda [y,x]       4584  adda([Y,X])                     #19
              0dbc ce00  st   [y,x]       4585  st([Y,X])                       #20
              0dbd c228  st   [$28]       4586  st([v6502_Qz])                  #21 Z flag
              0dbe c229  st   [$29]       4587  st([v6502_Qn])                  #22 N flag
              0dbf 0127  ld   [$27]       4588  ld([v6502_P])                   #23 C Flag
              0dc0 20fe  anda $fe         4589  anda(~1)                        #24
              0dc1 112f  ld   [$2f],x     4590  ld([v6502_Tmp],X)               #25
              0dc2 4500  ora  [x]         4591  ora([X])                        #26
              0dc3 c227  st   [$27]       4592  st([v6502_P])                   #27
              0dc4 140e  ld   $0e,y       4593  ld(hi('v6502_next'),Y)          #28
              0dc5 00f0  ld   $f0         4594  ld(-32/2)                       #29
              0dc6 e020  jmp  y,$20       4595  jmp(Y,'v6502_next')             #30
                                          4596  #nop()                          #31 Overlap
                                          4597  #
                                          4598  label('v6502_asl')
v6502_asl:    0dc7 1525  ld   [$25],y     4599  ld([v6502_ADH],Y)               #12,32
              0dc8 0d00  ld   [y,x]       4600  ld([Y,X])                       #13
              0dc9 2080  anda $80         4601  anda(0x80)                      #14
              0dca c22f  st   [$2f]       4602  st([v6502_Tmp])                 #15
              0dcb fcba  bra  .rol#18     4603  bra('.rol#18')                  #16
              0dcc 0000  ld   $00         4604  ld(0)                           #17
                                          4605
                                          4606  label('v6502_jmp1')
v6502_jmp1:   0dcd 0200  nop              4607  nop()                           #12
              0dce 0124  ld   [$24]       4608  ld([v6502_ADL])                 #13
              0dcf c21a  st   [$1a]       4609  st([v6502_PCL])                 #14
              0dd0 0125  ld   [$25]       4610  ld([v6502_ADH])                 #15
              0dd1 c21b  st   [$1b]       4611  st([v6502_PCH])                 #16
              0dd2 140e  ld   $0e,y       4612  ld(hi('v6502_next'),Y)          #17
              0dd3 e020  jmp  y,$20       4613  jmp(Y,'v6502_next')             #18
              0dd4 00f6  ld   $f6         4614  ld(-20/2)                       #19
                                          4615
                                          4616  label('v6502_jmp2')
v6502_jmp2:   0dd5 0200  nop              4617  nop()                           #12
              0dd6 1525  ld   [$25],y     4618  ld([v6502_ADH],Y)               #13
              0dd7 0d00  ld   [y,x]       4619  ld([Y,X])                       #14
              0dd8 de00  st   [y,x++]     4620  st([Y,Xpp])                     #15 (Just X++) Wrap around: bug compatible with NMOS
              0dd9 c21a  st   [$1a]       4621  st([v6502_PCL])                 #16
              0dda 0d00  ld   [y,x]       4622  ld([Y,X])                       #17
              0ddb c21b  st   [$1b]       4623  st([v6502_PCH])                 #18
              0ddc 140e  ld   $0e,y       4624  ld(hi('v6502_next'),Y)          #19
              0ddd e020  jmp  y,$20       4625  jmp(Y,'v6502_next')             #20
              0dde 00f5  ld   $f5         4626  ld(-22/2)                       #21
                                          4627
                                          4628  label('v6502_pla')
v6502_pla:    0ddf 011c  ld   [$1c]       4629  ld([v6502_S])                   #12
              0de0 1200  ld   ac,x        4630  ld(AC,X)                        #13
              0de1 8001  adda $01         4631  adda(1)                         #14
              0de2 c21c  st   [$1c]       4632  st([v6502_S])                   #15
              0de3 0500  ld   [x]         4633  ld([X])                         #16
              0de4 c218  st   [$18]       4634  st([v6502_A])                   #17
              0de5 c228  st   [$28]       4635  st([v6502_Qz])                  #18 Z flag
              0de6 c229  st   [$29]       4636  st([v6502_Qn])                  #19 N flag
              0de7 140e  ld   $0e,y       4637  ld(hi('v6502_next'),Y)          #20
              0de8 00f4  ld   $f4         4638  ld(-24/2)                       #21
              0de9 e020  jmp  y,$20       4639  jmp(Y,'v6502_next')             #22
                                          4640  #nop()                          #23 Overlap
                                          4641  #
                                          4642  label('v6502_pha')
v6502_pha:    0dea 140e  ld   $0e,y       4643  ld(hi('v6502_next'),Y)          #12,24
              0deb 011c  ld   [$1c]       4644  ld([v6502_S])                   #13
              0dec a001  suba $01         4645  suba(1)                         #14
              0ded d21c  st   [$1c],x     4646  st([v6502_S],X)                 #15
              0dee 0118  ld   [$18]       4647  ld([v6502_A])                   #16
              0def c600  st   [x]         4648  st([X])                         #17
              0df0 e020  jmp  y,$20       4649  jmp(Y,'v6502_next')             #18
              0df1 00f6  ld   $f6         4650  ld(-20/2)                       #19
                                          4651
                                          4652  label('v6502_brk')
v6502_brk:    0df2 0002  ld   $02         4653  ld(hi('ENTER'))                 #12 Switch to vCPU
              0df3 c205  st   [$05]       4654  st([vCpuSelect])                #13
                                          4655  assert v6502_A == vAC
              0df4 0000  ld   $00         4656  ld(0)                           #14
              0df5 c219  st   [$19]       4657  st([vAC+1])                     #15
              0df6 1403  ld   $03,y       4658  ld(hi('REENTER'),Y)             #16 Switch in the current time slice
              0df7 00fa  ld   $fa         4659  ld(-22//2+v6502_adjust)         #17
              0df8 e0cb  jmp  y,$cb       4660  jmp(Y,'REENTER')                #18
              0df9 0200  nop              4661  nop()                           #19
                                          4662
                                          4663  # All interpreter entry points must share the same page offset, because
                                          4664  # this offset is hard-coded as immediate operand in the video driver.
                                          4665  # The Gigatron's original vCPU's 'ENTER' label is already at $2ff, so we
                                          4666  # just use $dff for 'v6502_ENTER'. v6502 actually has two entry points.
                                          4667  # The other is 'v6502_RESUME' at $10ff. It is used for instructions
                                          4668  # that were fetched but not yet executed. Allowing the split gives finer
                                          4669  # granulariy, and hopefully more throughput for the simpler instructions.
                                          4670  # (There is no "overhead" for allowing instruction splitting, because
                                          4671  #  both emulation phases must administer [vTicks] anyway.)
                                          4672
              0dfa 0200  nop              4673  fillers(until=0xff)
              0dfb 0200  nop
              0dfc 0200  nop
              * 5 times
                                          4674  label('v6502_ENTER')
v6502_ENTER:  0dff fc22  bra  v6502_next2 4675  bra('v6502_next2')              #0 v6502 primary entry point
                                          4676  # --- Page boundary ---
                                          4677  align(0x100, size=0x100)
              0e00 a005  suba $05         4678  suba(v6502_adjust)              #1,19 Adjust for vCPU/v6520 timing differences
                                          4679
                                          4680  #19 Addressing modes
                                          4681  (   'v6502_mode0'  ); bra('v6502_modeIZX'); bra('v6502_modeIMM'); bra('v6502_modeILL') # $00 xxx000xx
              0e01 fce0  bra  v6502_modeIZX
              0e02 fc42  bra  v6502_modeIMM
              0e03 fc58  bra  v6502_modeIMP
                                          4682  bra('v6502_modeZP');  bra('v6502_modeZP');  bra('v6502_modeZP');  bra('v6502_modeILL') # $04 xxx001xx
              0e04 fc5d  bra  v6502_modeZP
              0e05 fc5d  bra  v6502_modeZP
              0e06 fc5d  bra  v6502_modeZP
              0e07 fc58  bra  v6502_modeIMP
                                          4683  bra('v6502_modeIMP'); bra('v6502_modeIMM'); bra('v6502_modeACC'); bra('v6502_modeILL') # $08 xxx010xx
              0e08 fc58  bra  v6502_modeIMP
              0e09 fc42  bra  v6502_modeIMM
              0e0a fc52  bra  v6502_modeACC
              0e0b fc58  bra  v6502_modeIMP
                                          4684  bra('v6502_modeABS'); bra('v6502_modeABS'); bra('v6502_modeABS'); bra('v6502_modeILL') # $0c xxx011xx
              0e0c fc78  bra  v6502_modeABS
              0e0d fc78  bra  v6502_modeABS
              0e0e fc78  bra  v6502_modeABS
              0e0f fc58  bra  v6502_modeIMP
                                          4685  bra('v6502_modeREL'); bra('v6502_modeIZY'); bra('v6502_modeIMM'); bra('v6502_modeILL') # $10 xxx100xx
              0e10 fccf  bra  v6502_modeREL
              0e11 fcab  bra  v6502_modeIZY
              0e12 fc42  bra  v6502_modeIMM
              0e13 fc58  bra  v6502_modeIMP
                                          4686  bra('v6502_modeZPX'); bra('v6502_modeZPX'); bra('v6502_modeZPX'); bra('v6502_modeILL') # $14 xxx101xx
              0e14 fc5b  bra  v6502_modeZPX
              0e15 fc5b  bra  v6502_modeZPX
              0e16 fc5b  bra  v6502_modeZPX
              0e17 fc58  bra  v6502_modeIMP
                                          4687  bra('v6502_modeIMP'); bra('v6502_modeABY'); bra('v6502_modeIMP'); bra('v6502_modeILL') # $18 xxx110xx
              0e18 fc58  bra  v6502_modeIMP
              0e19 fc7b  bra  v6502_modeABY
              0e1a fc58  bra  v6502_modeIMP
              0e1b fc58  bra  v6502_modeIMP
                                          4688  bra('v6502_modeABX'); bra('v6502_modeABX'); bra('v6502_modeABX'); bra('v6502_modeILL') # $1c xxx111xx
              0e1c fc7a  bra  v6502_modeABX
              0e1d fc7a  bra  v6502_modeABX
              0e1e fc7a  bra  v6502_modeABX
              0e1f fc58  bra  v6502_modeIMP
                                          4689
                                          4690  # Special encoding cases for emulator:
                                          4691  #     $00 BRK -         but gets mapped to #$DD      handled in v6502_mode0
                                          4692  #     $20 JSR $DDDD     but gets mapped to #$DD      handled in v6502_mode0 and v6502_JSR
                                          4693  #     $40 RTI -         but gets mapped to #$DD      handled in v6502_mode0
                                          4694  #     $60 RTS -         but gets mapped to #$DD      handled in v6502_mode0
                                          4695  #     $6C JMP ($DDDD)   but gets mapped to $DDDD     handled in v6502_JMP2
                                          4696  #     $96 STX $DD,Y     but gets mapped to $DD,X     handled in v6502_STX2
                                          4697  #     $B6 LDX $DD,Y     but gets mapped to $DD,X     handled in v6502_LDX2
                                          4698  #     $BE LDX $DDDD,Y   but gets mapped to $DDDD,X   handled in v6502_modeABX
                                          4699
                                          4700  label('v6502_next')
v6502_next:   0e20 8115  adda [$15]       4701  adda([vTicks])                  #0
                                          4702  blt('v6502_exitBefore')         #1 No more ticks
              0e21 e83a  blt  v6502_exitBefore
                                          4703  label('v6502_next2')
v6502_next2:  0e22 c215  st   [$15]       4704  st([vTicks])                    #2
                                          4705  #
                                          4706  # Fetch opcode
              0e23 111a  ld   [$1a],x     4707  ld([v6502_PCL],X)               #3
              0e24 151b  ld   [$1b],y     4708  ld([v6502_PCH],Y)               #4
              0e25 0d00  ld   [y,x]       4709  ld([Y,X])                       #5 Fetch IR
              0e26 c226  st   [$26]       4710  st([v6502_IR])                  #6
              0e27 011a  ld   [$1a]       4711  ld([v6502_PCL])                 #7 PC++
              0e28 8001  adda $01         4712  adda(1)                         #8
              0e29 d21a  st   [$1a],x     4713  st([v6502_PCL],X)               #9
              0e2a f02d  beq  $0e2d       4714  beq(pc()+3)                     #10
              0e2b fc2e  bra  $0e2e       4715  bra(pc()+3)                     #11
              0e2c 0000  ld   $00         4716  ld(0)                           #12
              0e2d 0001  ld   $01         4717  ld(1)                           #12(!)
              0e2e 811b  adda [$1b]       4718  adda([v6502_PCH])               #13
              0e2f d61b  st   [$1b],y     4719  st([v6502_PCH],Y)               #14
                                          4720  #
                                          4721  # Get addressing mode and fetch operands
              0e30 0126  ld   [$26]       4722  ld([v6502_IR])                  #15 Get addressing mode
              0e31 201f  anda $1f         4723  anda(31)                        #16
              0e32 fe00  bra  ac          4724  bra(AC)                         #17
              0e33 fc34  bra  .next20     4725  bra('.next20')                  #18
                                          4726  # (jump table)                  #19
                                          4727  label('.next20')
.next20:      0e34 0d00  ld   [y,x]       4728  ld([Y,X])                       #20 Fetch L
                                          4729  # Most opcodes branch away at this point, but IR & 31 == 0 falls through
                                          4730  #
                                          4731  # Implicit Mode for  BRK JSR RTI RTS (<  0x80) -- 26 cycles
                                          4732  # Immediate Mode for LDY CPY CPX     (>= 0x80) -- 36 cycles
                                          4733  label('v6502_mode0')
v6502_mode0:  0e35 0126  ld   [$26]       4734  ld([v6502_IR])                  #21 'xxx0000'
              0e36 e845  blt  .imm24      4735  bmi('.imm24')                   #22
              0e37 011b  ld   [$1b]       4736  ld([v6502_PCH])                 #23
              0e38 fcf2  bra  v6502_check 4737  bra('v6502_check')              #24
              0e39 00f3  ld   $f3         4738  ld(-26/2)                       #25
                                          4739
                                          4740  # Resync with video driver. At this point we're returning BEFORE
                                          4741  # fetching and executing the next instruction.
                                          4742  label('v6502_exitBefore')
v6502_exitBefore:
              0e3a 8013  adda $13         4743  adda(v6502_maxTicks)            #3 Exit BEFORE fetch
              0e3b e43b  bgt  $0e3b       4744  bgt(pc()&255)                   #4 Resync
              0e3c a001  suba $01         4745  suba(1)                         #5
              0e3d 000d  ld   $0d         4746  ld(hi('v6502_ENTER'))           #6 Set entry point to before 'fetch'
              0e3e c205  st   [$05]       4747  st([vCpuSelect])                #7
              0e3f 1401  ld   $01,y       4748  ld(hi('vBlankStart'),Y)         #8
              0e40 e11e  jmp  y,[$1e]     4749  jmp(Y,[vReturn])                #9 To video driver
              0e41 0102  ld   [$02]       4750  ld([channel])                   #10
                                          4751  assert v6502_overhead ==         11
                                          4752
                                          4753  # Immediate Mode: #$FF -- 36 cycles
                                          4754  label('v6502_modeIMM')
v6502_modeIMM:
              0e42 0200  nop              4755  nop()                           #21 Wait for v6502_mode0 to join
              0e43 0200  nop              4756  nop()                           #22
              0e44 011b  ld   [$1b]       4757  ld([v6502_PCH])                 #23 Copy PC
                                          4758  label('.imm24')
.imm24:       0e45 c225  st   [$25]       4759  st([v6502_ADH])                 #24
              0e46 011a  ld   [$1a]       4760  ld([v6502_PCL])                 #25
              0e47 d224  st   [$24],x     4761  st([v6502_ADL],X)               #26
              0e48 8001  adda $01         4762  adda(1)                         #27 PC++
              0e49 c21a  st   [$1a]       4763  st([v6502_PCL])                 #28
              0e4a f04d  beq  $0e4d       4764  beq(pc()+3)                     #29
              0e4b fc4e  bra  $0e4e       4765  bra(pc()+3)                     #30
              0e4c 0000  ld   $00         4766  ld(0)                           #31
              0e4d 0001  ld   $01         4767  ld(1)                           #31(!)
              0e4e 811b  adda [$1b]       4768  adda([v6502_PCH])               #32
              0e4f c21b  st   [$1b]       4769  st([v6502_PCH])                 #33
              0e50 fcf2  bra  v6502_check 4770  bra('v6502_check')              #34
              0e51 00ee  ld   $ee         4771  ld(-36/2)                       #35
                                          4772
                                          4773  # Accumulator Mode: ROL ROR LSL ASR -- 28 cycles
                                          4774  label('v6502_modeACC')
v6502_modeACC:
              0e52 0018  ld   $18         4775  ld(v6502_A&255)                 #21 Address of AC
              0e53 d224  st   [$24],x     4776  st([v6502_ADL],X)               #22
              0e54 0000  ld   $00         4777  ld(v6502_A>>8)                  #23
              0e55 c225  st   [$25]       4778  st([v6502_ADH])                 #24
              0e56 00f2  ld   $f2         4779  ld(-28/2)                       #25
              0e57 fcf2  bra  v6502_check 4780  bra('v6502_check')              #26
                                          4781  #nop()                          #27 Overlap
                                          4782  #
                                          4783  # Implied Mode: no operand -- 24 cycles
                                          4784  label('v6502_modeILL')
                                          4785  label('v6502_modeIMP')
v6502_modeILL:
v6502_modeIMP:
              0e58 0200  nop              4786  nop()                           #21,27
              0e59 fcf2  bra  v6502_check 4787  bra('v6502_check')              #22
              0e5a 00f4  ld   $f4         4788  ld(-24/2)                       #23
                                          4789
                                          4790  # Zero Page Modes: $DD $DD,X $DD,Y -- 36 cycles
                                          4791  label('v6502_modeZPX')
