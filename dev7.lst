.sysDpx0:     0c11 c226  st   [$26]       4249  st([sysArgs+2])                 #20 Gobble 6 pixels into buffer
              0c12 0d00  ld   [y,x]       4250  ld([Y,X])                       #21
              0c13 de00  st   [y,x++]     4251  st([Y,Xpp])                     #22 Just X++
              0c14 c227  st   [$27]       4252  st([sysArgs+3])                 #23
              0c15 0d00  ld   [y,x]       4253  ld([Y,X])                       #24
              0c16 de00  st   [y,x++]     4254  st([Y,Xpp])                     #25 Just X++
              0c17 c228  st   [$28]       4255  st([sysArgs+4])                 #26
              0c18 0d00  ld   [y,x]       4256  ld([Y,X])                       #27
              0c19 de00  st   [y,x++]     4257  st([Y,Xpp])                     #28 Just X++
              0c1a c229  st   [$29]       4258  st([sysArgs+5])                 #29
              0c1b 0d00  ld   [y,x]       4259  ld([Y,X])                       #30
              0c1c de00  st   [y,x++]     4260  st([Y,Xpp])                     #31 Just X++
              0c1d c22a  st   [$2a]       4261  st([sysArgs+6])                 #32
              0c1e 0d00  ld   [y,x]       4262  ld([Y,X])                       #33
              0c1f de00  st   [y,x++]     4263  st([Y,Xpp])                     #34 Just X++
              0c20 c22b  st   [$2b]       4264  st([sysArgs+7])                 #35
                                          4265
              0c21 1118  ld   [$18],x     4266  ld([vAC],X)                     #36 Screen memory destination address
              0c22 1519  ld   [$19],y     4267  ld([vAC+1],Y)                   #37
              0c23 0126  ld   [$26]       4268  ld([sysArgs+2])                 #38 Write 6 pixels
              0c24 de00  st   [y,x++]     4269  st([Y,Xpp])                     #39
              0c25 0127  ld   [$27]       4270  ld([sysArgs+3])                 #40
              0c26 de00  st   [y,x++]     4271  st([Y,Xpp])                     #41
              0c27 0128  ld   [$28]       4272  ld([sysArgs+4])                 #42
              0c28 de00  st   [y,x++]     4273  st([Y,Xpp])                     #43
              0c29 0129  ld   [$29]       4274  ld([sysArgs+5])                 #44
              0c2a de00  st   [y,x++]     4275  st([Y,Xpp])                     #45
              0c2b 012a  ld   [$2a]       4276  ld([sysArgs+6])                 #46
              0c2c de00  st   [y,x++]     4277  st([Y,Xpp])                     #47
              0c2d 012b  ld   [$2b]       4278  ld([sysArgs+7])                 #48
              0c2e de00  st   [y,x++]     4279  st([Y,Xpp])                     #49
                                          4280
