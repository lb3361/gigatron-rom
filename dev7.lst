                                          4783
                                          4784  # All interpreter entry points must share the same page offset, because
                                          4785  # this offset is hard-coded as immediate operand in the video driver.
                                          4786  # The Gigatron's original vCPU's 'ENTER' label is already at $2ff, so we
                                          4787  # just use $dff for 'v6502_ENTER'. v6502 actually has two entry points.
                                          4788  # The other is 'v6502_RESUME' at $10ff. It is used for instructions
                                          4789  # that were fetched but not yet executed. Allowing the split gives finer
                                          4790  # granulariy, and hopefully more throughput for the simpler instructions.
                                          4791  # (There is no "overhead" for allowing instruction splitting, because
                                          4792  #  both emulation phases must administer [vTicks] anyway.)
                                          4793
              0dfa 0200  nop              4794  fillers(until=0xff)
              0dfb 0200  nop
              0dfc 0200  nop
              * 5 times
