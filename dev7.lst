                                          3427
                                          3428  #-----------------------------------------------------------------------
                                          3429  #
                                          3430  #  $0900 ROM page 9: Key table for music
                                          3431  #
                                          3432  #-----------------------------------------------------------------------
                                          3433
                                          3434  align(0x100, size=0x100)
                                          3435  notes = 'CCDDEFFGGAAB'
                                          3436  sampleRate = cpuClock / 200.0 / 4
                                          3437  label('notesTable')
notesTable:   0900 0000  ld   $00         3438  ld(0)
              0901 0000  ld   $00         3439  ld(0)
                                          3440  for i in range(0, 250, 2):
                                          3441    j = i//2-1
                                          3442    freq = 440.0*2.0**((j-57)/12.0)
                                          3443    if j>=0 and freq <= sampleRate/2.0:
                                          3444      key = int(round(32768 * freq / sampleRate))
                                          3445      octave, note = j//12, notes[j%12]
                                          3446      sharp = '-' if notes[j%12-1] != note else '#'
                                          3447      comment = '%s%s%s (%0.1f Hz)' % (note, sharp, octave, freq)
                                          3448      ld(key&127); C(comment); ld(key>>7)
