                                          10541  # trampoline code which cannot be changed because asm.py must
                                          10542  # remain able to compile older roms.
                                          10543  label('lupReturn#19')           # name hardcoded in the trampoline code
                                          10544  label('lupReturn#23')           # same name with the proper timing suffix
