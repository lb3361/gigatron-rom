                                          10667  # trampoline code which cannot be changed because asm.py must
                                          10668  # remain able to compile older roms.
                                          10669  label('lupReturn#19')           # name hardcoded in the trampoline code
                                          10670  label('lupReturn#23')           # same name with the proper timing suffix
lupReturn#19:
lupReturn#23: 2004 0105  ld   [$05]       10671  ld([vCpuSelect])                #23 to current interpreter
