                                          2111  #-----------------------------------------------------------------------
                                          2112  #
                                          2113  #  $0300 ROM page 3: Application interpreter primary page
                                          2114  #
                                          2115  #-----------------------------------------------------------------------
                                          2116
                                          2117  # Enter the timing-aware application interpreter (aka virtual CPU, vCPU)
                                          2118  #
                                          2119  # This routine will execute as many as possible instructions in the
                                          2120  # allotted time. When time runs out, it synchronizes such that the total
                                          2121  # duration matches the caller's request. Durations are counted in `ticks',
                                          2122  # which are multiples of 2 clock cycles.
                                          2123  #
                                          2124  # Synopsis: Use the runVcpu() macro as entry point
                                          2125
                                          2126  # We let 'ENTER' begin one word before the page boundary, for a bit extra
                                          2127  # precious space in the packed interpreter code page. Although ENTER's
                                          2128  # first instruction is bra() which normally doesn't cross page boundaries,
                                          2129  # in this case it will still jump into the right space, because branches
                                          2130  # from $xxFF land in the next page anyway.
                                          2131
              02fb 0200  nop              2132  fillers(until=0xff)
              02fc 0200  nop
              02fd 0200  nop
              02fe 0200  nop
                                          2133  label('ENTER')
ENTER:        02ff fc03  bra  .next2      2134  bra('.next2')                   #0 Enter at '.next2' (so no startup overhead)
                                          2135  # --- Page boundary ---
                                          2136  align(0x100,size=0x100)
                                          2137  label('NEXTY')                  # Alternative for REENTER
NEXTY:        0300 1517  ld   [$17],y     2138  ld([vPC+1],Y)                   #1
                                          2139
                                          2140  # Fetch next instruction and execute it, but only if there are sufficient
                                          2141  # ticks left for the slowest instruction.
                                          2142  label('NEXT')
NEXT:         0301 8115  adda [$15]       2143  adda([vTicks])                  #0 Track elapsed ticks (actually counting down: AC<0)
              0302 e80b  blt  EXIT        2144  blt('EXIT')                     #1 Escape near time out
                                          2145  label('.next2')
.next2:       0303 c215  st   [$15]       2146  st([vTicks])                    #2
              0304 0116  ld   [$16]       2147  ld([vPC])                       #3 Advance vPC
              0305 8002  adda $02         2148  adda(2)                         #4
              0306 d216  st   [$16],x     2149  st([vPC],X)                     #5
              0307 0d00  ld   [y,x]       2150  ld([Y,X])                       #6 Fetch opcode (actually a branch target)
              0308 de00  st   [y,x++]     2151  st([Y,Xpp])                     #7 Just X++
              0309 fe00  bra  ac          2152  bra(AC)                         #8 Dispatch
              030a 0d00  ld   [y,x]       2153  ld([Y,X])                       #9 Prefetch operand
                                          2154
                                          2155  # Resync with video driver and transfer control
                                          2156  label('EXIT')
EXIT:         030b 800f  adda $0f         2157  adda(maxTicks)                  #3
                                          2158  label('RESYNC')
RESYNC:       030c e40c  bgt  RESYNC      2159  bgt(pc()&255)                   #4 Resync
              030d a001  suba $01         2160  suba(1)                         #5
              030e 1401  ld   $01,y       2161  ld(hi('vBlankStart'),Y)         #6
              030f e11e  jmp  y,[$1e]     2162  jmp(Y,[vReturn])                #7 To video driver
              0310 0102  ld   [$02]       2163  ld([channel])                   #8 with channel in AC
                                          2164  assert vCPU_overhead ==          9
                                          2165
                                          2166  # Instruction LDWI: Load immediate word constant (vAC=D), 20 cycles
                                          2167  label('LDWI')
LDWI:         0311 c218  st   [$18]       2168  st([vAC])                       #10
              0312 de00  st   [y,x++]     2169  st([Y,Xpp])                     #11 Just X++
              0313 0116  ld   [$16]       2170  ld([vPC])                       #12 Advance vPC one more
              0314 8001  adda $01         2171  adda(1)                         #13
              0315 c216  st   [$16]       2172  st([vPC])                       #14
              0316 fc28  bra  ldw#17      2173  bra('ldw#17')                   #15
              0317 0d00  ld   [y,x]       2174  ld([Y,X])                       #16 Fetch second operand
                                          2175
                                          2176  # Instruction NEGV (18 vv) [26 cycles]
                                          2177  # * Negates word [vv]:=-[vv]
                                          2178  label('NEGV_v7')
NEGV_v7:      0318 141f  ld   $1f,y       2179  ld(hi('negv#13'),Y)             #10
              0319 e0e3  jmp  y,$e3       2180  jmp(Y,'negv#13')                #11+overlap
                                          2181
                                          2182  # Instruction LD: Load byte from zero page (vAC=[D]), 18 cycles
                                          2183  label('LD')
LD:           031a 1200  ld   ac,x        2184  ld(AC,X)                        #10
              031b fcc1  bra  ld#13       2185  bra('ld#13')                    #11
              031c 0500  ld   [x]         2186  ld([X])                         #13
                                          2187
                                          2188  # Helper for INC.
                                          2189  label('inc#14')
inc#14:       031d fcc4  bra  ld#16       2190  bra('ld#16')                    #14
              031e c600  st   [x]         2191  st([X])                         #15
                                          2192
                                          2193  # Instruction CMPHS: Adjust high byte for signed compare (vACH=XXX), 20-26 cycles
                                          2194  label('CMPHS_v5')
CMPHS_v5:     031f 140b  ld   $0b,y       2195  ld(hi('cmphs#13'),Y)            #10
              0320 e0d8  jmp  y,$d8       2196  jmp(Y,'cmphs#13')               #11
                                          2197  #ld(AC,X)                       #12 Overlap
                                          2198  #
                                          2199  # Instruction LDW: Load word from zero page (vAC=[D]+256*[D+1]), 20 cycles
                                          2200  label('LDW')
LDW:          0321 1200  ld   ac,x        2201  ld(AC,X)                        #10,12
              0322 8001  adda $01         2202  adda(1)                         #11
              0323 c22f  st   [$2f]       2203  st([vTmp])                      #12 Address of high byte
              0324 0500  ld   [x]         2204  ld([X])                         #13
              0325 112f  ld   [$2f],x     2205  ld([vTmp],X)                    #14
              0326 c218  st   [$18]       2206  st([vAC])                       #15
              0327 0500  ld   [x]         2207  ld([X])                         #16
                                          2208  label('ldw#17')
ldw#17:       0328 c219  st   [$19]       2209  st([vAC+1])                     #17
              0329 fc01  bra  NEXT        2210  bra('NEXT')                     #18
              032a 00f6  ld   $f6         2211  ld(-20/2)                       #19
                                          2212
                                          2213  # Instruction STW: Store word in zero page ([D],[D+1]=vAC&255,vAC>>8), 20 cycles
                                          2214  label('STW')
STW:          032b 1200  ld   ac,x        2215  ld(AC,X)                        #10
              032c 1400  ld   $00,y       2216  ld(0,Y)                         #11
              032d 0118  ld   [$18]       2217  ld([vAC])                       #12
              032e de00  st   [y,x++]     2218  st([Y,Xpp])                     #13
              032f 0119  ld   [$19]       2219  ld([vAC+1])                     #14
              0330 ce00  st   [y,x]       2220  st([Y,X])                       #15
              0331 fccb  bra  REENTER     2221  bra('REENTER')                  #16
              0332 00f6  ld   $f6         2222  ld(-20/2)                       #17
                                          2223
                                          2224  # Instruction ADDHI (33 xx), 16 cycles
