                                          4636  #-----------------------------------------------------------------------
                                          4637  #       MOS 6502 emulator
                                          4638  #-----------------------------------------------------------------------
                                          4639
                                          4640  # Some quirks:
                                          4641  # - Stack in zero page instead of page 1
                                          4642  # - No interrupts
                                          4643  # - No decimal mode (may never be added). D flag is emulated but ignored.
                                          4644  # - BRK switches back to running 16-bits vCPU
                                          4645  # - Illegal opcodes map to BRK, but can read ghost operands before trapping
                                          4646  # - Illegal opcode $ff won't be trapped and cause havoc instead
                                          4647
                                          4648  # Big things TODO:
                                          4649  # XXX Tuning, put most frequent instructions in the primary page
                                          4650
