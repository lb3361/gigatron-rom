              158b fc1f  bra  fsm15:CHANMASK
              158c 008d  ld   $8d
              158d fc52  bra  fsm15:SLCHK 7101  fsmAsm('SLCHK')                 # checks
              158e 008f  ld   $8f
              158f fc14  bra  fsm15:BNZ   7102  fsmAsm('BNZ', 'sl:loader')      # invalid packet
              1590 0061  ld   $61
                                          7103  label('sl:data')
sl:data:      1591 fc22  bra  fsm15:SRIN  7104  fsmAsm('SRIN')
