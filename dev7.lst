                                          824   # Extension SYS_Multiply_s16_v6_66: 16 bit multiplication
                                          825   # Also known as SYS_Multiply_s16_v7_34.
                                          826   #-----------------------------------------------------------------------
                                          827   #
                                          828   # Computes C = C + A * B where A,B,C are 16 bits integers.
                                          829   # Returns product in vAC as well
                                          830   #
                                          831   #       sysArgs[0:1]    Multiplicand A (in)
                                          832   #       sysArgs[2:3]    Multiplicand B (in)
                                          833   #       sysArgs[4:5]    C (inout)
                                          834   #       sysArgs[6:7]    (changed)
                                          835   #
                                          836   # Original design: at67
                                          837   #
                                          838   # The improved dev7rom version is substantially faster.
                                          839   # Alternatively use the new opcode MULW.
                                          840
                                          841   label('SYS_Multiply_s16_v6_66')
                                          842   label('SYS_Multiply_s16_v7_34')
SYS_Multiply_s16_v6_66:
SYS_Multiply_s16_v7_34:
