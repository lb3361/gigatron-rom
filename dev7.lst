                                          3961  # -------------------------------------------------------------
                                          3962  # vCPU instructions for comparisons between two 16-bit operands
                                          3963  # -------------------------------------------------------------
                                          3964  #
                                          3965  # vCPU's conditional branching (BCC) always compares vAC against 0,
                                          3966  # treating vAC as a two's complement 16-bit number. When we need to
                                          3967  # compare two arbitrary numnbers we normally first take their difference
                                          3968  # with SUBW.  However, when this difference is too large, the subtraction
                                          3969  # overflows and we get the wrong outcome. To get it right over the
                                          3970  # entire range, an elaborate sequence is needed. TinyBASIC uses this
                                          3971  # blurp for its relational operators. (It compares stack variable $02
                                          3972  # with zero page variable $3a.)
                                          3973  #
                                          3974  #       0461  ee 02            LDLW  $02
                                          3975  #       0463  fc 3a            XORW  $3a
                                          3976  #       0465  35 53 6a         BGE   $046c
                                          3977  #       0468  ee 02            LDLW  $02
                                          3978  #       046a  90 6e            BRA   $0470
                                          3979  #       046c  ee 02            LDLW  $02
                                          3980  #       046e  b8 3a            SUBW  $3a
                                          3981  #       0470  35 56 73         BLE   $0475
                                          3982  #
                                          3983  # The CMPHS and CMPHU instructions were introduced to simplify this.
                                          3984  # They inspect both operands to see if there is an overflow risk. If
                                          3985  # so, they modify vAC such that their difference gets smaller, while
                                          3986  # preserving the relation between the two operands. After that, the
                                          3987  # SUBW instruction can't overflow and we achieve a correct comparison.
                                          3988  # Use CMPHS for signed comparisons and CMPHU for unsigned. With these,
                                          3989  # the sequence above becomes:
                                          3990  #
                                          3991  #       0461  ee 02            LDLW  $02
                                          3992  #       0463  1f 3b            CMPHS $3b        Note: high byte of operand
                                          3993  #       0465  b8 3a            SUBW  $3a
                                          3994  #       0467  35 56 73         BLE   $0475
                                          3995  #
                                          3996  # CMPHS/CMPHU don't make much sense other than in combination with
                                          3997  # SUBW. These modify vACH, if needed, as given in the following table:
                                          3998  #
                                          3999  #       vACH  varH  |     vACH
                                          4000  #       bit7  bit7  | CMPHS  CMPHU
                                          4001  #       ---------------------------
                                          4002  #         0     0   |  vACH   vACH      no change needed
                                          4003  #         0     1   | varH+1 varH-1     narrowing the range
                                          4004  #         1     0   | varH-1 varH+1     narrowing the range
                                          4005  #         1     1   |  vACH   vACH      no change needed
                                          4006  #       ---------------------------
                                          4007
                                          4008
                                          4009  # CMPHS implementation (vCPU instruction)
                                          4010  label('cmphs#13')
cmphs#13:     0bd8 0119  ld   [$19]       4011  ld([vAC+1])                     #13
              0bd9 6500  xora [x]         4012  xora([X])                       #14
              0bda f4f0  bge  cmphu#17    4013  bpl('cmphu#17')                 #15
              0bdb 1403  ld   $03,y       4014  ld(hi('NEXTY'),Y)               #16
              0bdc 0500  ld   [x]         4015  ld([X])                         #17
              0bdd e8e0  blt  $0be0       4016  bmi(pc()+3)                     #18
              0bde fce1  bra  $0be1       4017  bra(pc()+3)                     #19
              0bdf a001  suba $01         4018  suba(1)                         #20
              0be0 8001  adda $01         4019  adda(1)                         #20
              0be1 c219  st   [$19]       4020  st([vAC+1])                     #21
              0be2 e0cb  jmp  y,$cb       4021  jmp(Y,'REENTER')                #22
              0be3 00f3  ld   $f3         4022  ld(-26/2)                       #23
                                          4023
                                          4024  # CMPHU implementation (vCPU instruction)
                                          4025  label('cmphu#13')
cmphu#13:     0be4 0119  ld   [$19]       4026  ld([vAC+1])                     #13
              0be5 6500  xora [x]         4027  xora([X])                       #14
              0be6 f4f0  bge  cmphu#17    4028  bpl('cmphu#17')                 #15
              0be7 1403  ld   $03,y       4029  ld(hi('NEXTY'),Y)               #16
              0be8 0500  ld   [x]         4030  ld([X])                         #17
              0be9 e8ec  blt  $0bec       4031  bmi(pc()+3)                     #18
              0bea fced  bra  $0bed       4032  bra(pc()+3)                     #19
              0beb 8001  adda $01         4033  adda(1)                         #20
              0bec a001  suba $01         4034  suba(1)                         #20
              0bed c219  st   [$19]       4035  st([vAC+1])                     #21
              0bee e0cb  jmp  y,$cb       4036  jmp(Y,'REENTER')                #22
              0bef 00f3  ld   $f3         4037  ld(-26/2)                       #23
