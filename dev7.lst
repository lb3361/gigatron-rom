                                          4081
                                          4082  # -------------------------------------------------------------
                                          4083  # vCPU instructions for comparisons between two 16-bit operands
                                          4084  # -------------------------------------------------------------
                                          4085  #
                                          4086  # vCPU's conditional branching (BCC) always compares vAC against 0,
                                          4087  # treating vAC as a two's complement 16-bit number. When we need to
                                          4088  # compare two arbitrary numnbers we normally first take their difference
                                          4089  # with SUBW.  However, when this difference is too large, the subtraction
                                          4090  # overflows and we get the wrong outcome. To get it right over the
                                          4091  # entire range, an elaborate sequence is needed. TinyBASIC uses this
                                          4092  # blurp for its relational operators. (It compares stack variable $02
                                          4093  # with zero page variable $3a.)
                                          4094  #
                                          4095  #       0461  ee 02            LDLW  $02
                                          4096  #       0463  fc 3a            XORW  $3a
                                          4097  #       0465  35 53 6a         BGE   $046c
                                          4098  #       0468  ee 02            LDLW  $02
                                          4099  #       046a  90 6e            BRA   $0470
                                          4100  #       046c  ee 02            LDLW  $02
                                          4101  #       046e  b8 3a            SUBW  $3a
                                          4102  #       0470  35 56 73         BLE   $0475
                                          4103  #
                                          4104  # The CMPHS and CMPHU instructions were introduced to simplify this.
                                          4105  # They inspect both operands to see if there is an overflow risk. If
                                          4106  # so, they modify vAC such that their difference gets smaller, while
                                          4107  # preserving the relation between the two operands. After that, the
                                          4108  # SUBW instruction can't overflow and we achieve a correct comparison.
                                          4109  # Use CMPHS for signed comparisons and CMPHU for unsigned. With these,
                                          4110  # the sequence above becomes:
                                          4111  #
                                          4112  #       0461  ee 02            LDLW  $02
                                          4113  #       0463  1f 3b            CMPHS $3b        Note: high byte of operand
                                          4114  #       0465  b8 3a            SUBW  $3a
                                          4115  #       0467  35 56 73         BLE   $0475
                                          4116  #
                                          4117  # CMPHS/CMPHU don't make much sense other than in combination with
                                          4118  # SUBW. These modify vACH, if needed, as given in the following table:
                                          4119  #
                                          4120  #       vACH  varH  |     vACH
                                          4121  #       bit7  bit7  | CMPHS  CMPHU
                                          4122  #       ---------------------------
                                          4123  #         0     0   |  vACH   vACH      no change needed
                                          4124  #         0     1   | varH+1 varH-1     narrowing the range
                                          4125  #         1     0   | varH-1 varH+1     narrowing the range
                                          4126  #         1     1   |  vACH   vACH      no change needed
                                          4127  #       ---------------------------
                                          4128
                                          4129
                                          4130  # CMPHS implementation (vCPU instruction)
                                          4131  label('cmphs#13')
cmphs#13:     0bd8 0119  ld   [$19]       4132  ld([vAC+1])                     #13
              0bd9 6500  xora [x]         4133  xora([X])                       #14
              0bda f4f0  bge  cmphu#17    4134  bpl('cmphu#17')                 #15
              0bdb 1403  ld   $03,y       4135  ld(hi('NEXTY'),Y)               #16
              0bdc 0500  ld   [x]         4136  ld([X])                         #17
              0bdd e8e0  blt  $0be0       4137  bmi(pc()+3)                     #18
              0bde fce1  bra  $0be1       4138  bra(pc()+3)                     #19
              0bdf a001  suba $01         4139  suba(1)                         #20
              0be0 8001  adda $01         4140  adda(1)                         #20
              0be1 c219  st   [$19]       4141  st([vAC+1])                     #21
              0be2 e0cb  jmp  y,$cb       4142  jmp(Y,'REENTER')                #22
              0be3 00f3  ld   $f3         4143  ld(-26/2)                       #23
                                          4144
                                          4145  # CMPHU implementation (vCPU instruction)
                                          4146  label('cmphu#13')
cmphu#13:     0be4 0119  ld   [$19]       4147  ld([vAC+1])                     #13
              0be5 6500  xora [x]         4148  xora([X])                       #14
              0be6 f4f0  bge  cmphu#17    4149  bpl('cmphu#17')                 #15
              0be7 1403  ld   $03,y       4150  ld(hi('NEXTY'),Y)               #16
              0be8 0500  ld   [x]         4151  ld([X])                         #17
              0be9 e8ec  blt  $0bec       4152  bmi(pc()+3)                     #18
              0bea fced  bra  $0bed       4153  bra(pc()+3)                     #19
              0beb 8001  adda $01         4154  adda(1)                         #20
              0bec a001  suba $01         4155  suba(1)                         #20
              0bed c219  st   [$19]       4156  st([vAC+1])                     #21
              0bee e0cb  jmp  y,$cb       4157  jmp(Y,'REENTER')                #22
              0bef 00f3  ld   $f3         4158  ld(-26/2)                       #23
                                          4159
                                          4160  # No-operation for CMPHS/CMPHU when high bits are equal
                                          4161  label('cmphu#17')
cmphu#17:     0bf0 e000  jmp  y,$00       4162  jmp(Y,'NEXTY')                  #17
              0bf1 00f6  ld   $f6         4163  ld(-20/2)                       #18
