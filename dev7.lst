              11c3 c228  st   [$28]       5888  st([v6502_Qz])                  #17 Z flag
              11c4 c229  st   [$29]       5889  st([v6502_Qn])                  #18 N flag
              11c5 fccb  bra  .cmp21      5890  bra('.cmp21')                   #19
              11c6 4d00  ora  [y,x]       5891  ora([Y,X])                      #20
                                          5892  label('.cmp17')
.cmp17:       11c7 c228  st   [$28]       5893  st([v6502_Qz])                  #17 Z flag
              11c8 c229  st   [$29]       5894  st([v6502_Qn])                  #18 N flag
              11c9 2d00  anda [y,x]       5895  anda([Y,X])                     #19
