v6502_plp:    11d4 011c  ld   [$1c]       5911  ld([v6502_S])                   #12
              11d5 1200  ld   ac,x        5912  ld(AC,X)                        #13
              11d6 8001  adda $01         5913  adda(1)                         #14
              11d7 c21c  st   [$1c]       5914  st([v6502_S])                   #15
              11d8 0500  ld   [x]         5915  ld([X])                         #16
              11d9 c229  st   [$29]       5916  st([v6502_Qn])                  #17 N flag
              11da 2002  anda $02         5917  anda(v6502_Zflag)               #18
              11db 6002  xora $02         5918  xora(v6502_Zflag)               #19
              11dc c228  st   [$28]       5919  st([v6502_Qz])                  #20 Z flag
              11dd 0500  ld   [x]         5920  ld([X])                         #21
              11de 207f  anda $7f         5921  anda(~v6502_Vemu)               #22 V to bit 7
              11df 8040  adda $40         5922  adda(v6502_Vflag)               #23
              11e0 c227  st   [$27]       5923  st([v6502_P])                   #24 All other flags
              11e1 140e  ld   $0e,y       5924  ld(hi('v6502_next'),Y)          #25
              11e2 e020  jmp  y,$20       5925  jmp(Y,'v6502_next')             #26
