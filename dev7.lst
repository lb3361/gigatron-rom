                                          5242  #
                                          5243  label('v6502_SBC')
                                          5244  # No matter how hard we try, v6502_SBC always comes out a lot clumsier
                                          5245  # than v6502_ADC. And that one already barely fits in 38 cycles and is
                                          5246  # hard to follow. So we use a hack: transmorph our SBC into an ADC with
                                          5247  # inverted operand, and then dispatch again. Simple and effective.
v6502_SBC:    1029 1525  ld   [$25],y     5248  ld([v6502_ADH],Y)               #9,24
              102a 0d00  ld   [y,x]       5249  ld([Y,X])                       #10
              102b 60ff  xora $ff         5250  xora(255)                       #11 Invert right-hand side operand
              102c c219  st   [$19]       5251  st([v6502_BI])                  #12 Park modified operand for v6502_ADC
              102d 0019  ld   $19         5252  ld(v6502_BI&255)                #13 Address of BI
              102e d224  st   [$24],x     5253  st([v6502_ADL],X)               #14
              102f 0000  ld   $00         5254  ld(v6502_BI>>8)                 #15
              1030 c225  st   [$25]       5255  st([v6502_ADH])                 #16
