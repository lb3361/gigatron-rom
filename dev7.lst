                                          5115  align(0x100,size=0x100)
                                          5116  label('v6502_execute')
                                          5117  # This page works as a 255-entry (0..254) jump table for 6502 opcodes.
                                          5118  # Jumping into this page must have 'bra 255' in the branch delay slot
                                          5119  # in order to get out again and dispatch to the right continuation.
