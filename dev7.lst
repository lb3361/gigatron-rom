              16ba fc0c  bra  fsm16:LD    7354  fsmAsm('LD', [vAC+1])           # token
              16bb 0119  ld   [$19]
              16bc fc11  bra  fsm16:AND   7355  fsmAsm('AND', 0x80)
              16bd 0080  ld   $80
              16be fc1a  bra  fsm16:BZ    7356  fsmAsm('BZ', 'se:loadGt1z:match')
              16bf 00cc  ld   $cc
              16c0 fc28  bra  fsm16:LUP   7357  fsmAsm('LUP')                   # hi offset byte
              16c1 00c2  ld   $c2
              16c2 fc0a  bra  fsm16:ST    7358  fsmAsm('ST', sysFn+1)
              16c3 0023  ld   $23
              16c4 fc11  bra  fsm16:AND   7359  fsmAsm('AND', 0x80)             # short offset?
              16c5 0080  ld   $80
              16c6 fc17  bra  fsm16:BNZ   7360  fsmAsm('BNZ', 'se:loadGt1z:short')
              16c7 00e1  ld   $e1
              16c8 fc28  bra  fsm16:LUP   7361  fsmAsm('LUP')                   # lo offset byte
              16c9 00ca  ld   $ca
              16ca fc0a  bra  fsm16:ST    7362  fsmAsm('ST', sysFn)
