                                          5963  #-----------------------------------------------------------------------
                                          5964  #       Extended vertical blank logic: interrupts
                                          5965  #-----------------------------------------------------------------------
                                          5966
                                          5967  # Manual runVcpu with vReturn already set
                                          5968  label('vBlankFirst#vCPU1')      # with halfTick
vBlankFirst#vCPU1:
              1200 c000  st   $00,[$00]   5969  st(0,[0])
                                          5970  label('vBlankFirst#vCPU0')      # witout halfTick
vBlankFirst#vCPU0:
              1201 1505  ld   [$05],y     5971  ld([vCpuSelect],Y)
              1202 e0ff  jmp  y,$ff       5972  jmp(Y,'ENTER')
              1203 0200  nop              5973  nop()
                                          5974
                                          5975  # IRQ logic
                                          5976  label('vBlankFirst#77')
vBlankFirst#77:
              1204 09f6  ld   [y,$f6]     5977  ld([Y,vIRQ_v5])                 #77 check if there is a irq handler
              1205 49f7  ora  [y,$f7]     5978  ora([Y,vIRQ_v5+1])              #78
                                          5979  n,m = runVcpu_ticks(190-79-extra, 5, '---D line 0 timeout no irq')
                                          5980  beq('vBlankFirst#vCPU%d' % m)   #79
              1206 f000  beq  vBlankFirst#vCPU1
              1207 0021  ld   $21         5981  ld(n)                           #80
                                          5982
              1208 09f5  ld   [y,$f5]     5983  ld([Y, vIrqCtx_v7])             #81 check if ctx-style irq
                                          5984  bne('vBlankFirst#84')           #82
              1209 ec1d  bne  vBlankFirst#84
              120a 0116  ld   [$16]       5985  ld([vPC])                       #83
              120b c230  st   [$30]       5986  st([vIrqSave+0])                #84 Save vPC
              120c 0117  ld   [$17]       5987  ld([vPC+1])                     #85
              120d c231  st   [$31]       5988  st([vIrqSave+1])                #86
              120e 0118  ld   [$18]       5989  ld([vAC])                       #87 Save vAC
              120f c232  st   [$32]       5990  st([vIrqSave+2])                #88
              1210 0119  ld   [$19]       5991  ld([vAC+1])                     #89
              1211 c233  st   [$33]       5992  st([vIrqSave+3])                #90
              1212 0105  ld   [$05]       5993  ld([vCpuSelect])                #91 Save vCpuSelect
              1213 c234  st   [$34]       5994  st([vIrqSave+4])                #92
              1214 09f6  ld   [y,$f6]     5995  ld([Y,vIRQ_v5])                 #93 Set vPC to vIRQ
              1215 a002  suba $02         5996  suba(2)                         #94
              1216 c216  st   [$16]       5997  st([vPC])                       #95
              1217 09f7  ld   [y,$f7]     5998  ld([Y,vIRQ_v5+1])               #96
              1218 c217  st   [$17]       5999  st([vPC+1])                     #97
              1219 0002  ld   $02         6000  ld(hi('ENTER'))                 #98 Set vCpuSelect to ENTER (=regular vCPU)
              121a c205  st   [$05]       6001  st([vCpuSelect])                #99
                                          6002  n,m = runVcpu_ticks(190-100-extra, 5, '---D line 0 timeout std irq')
                                          6003  bra('vBlankFirst#vCPU%d' % m)   #100
              121b fc01  bra  vBlankFirst#vCPU0
              121c 0017  ld   $17         6004  ld(n)                           #101
