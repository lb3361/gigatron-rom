                                          4811  # Special encoding cases for emulator:
                                          4812  #     $00 BRK -         but gets mapped to #$DD      handled in v6502_mode0
                                          4813  #     $20 JSR $DDDD     but gets mapped to #$DD      handled in v6502_mode0 and v6502_JSR
                                          4814  #     $40 RTI -         but gets mapped to #$DD      handled in v6502_mode0
                                          4815  #     $60 RTS -         but gets mapped to #$DD      handled in v6502_mode0
                                          4816  #     $6C JMP ($DDDD)   but gets mapped to $DDDD     handled in v6502_JMP2
                                          4817  #     $96 STX $DD,Y     but gets mapped to $DD,X     handled in v6502_STX2
                                          4818  #     $B6 LDX $DD,Y     but gets mapped to $DD,X     handled in v6502_LDX2
                                          4819  #     $BE LDX $DDDD,Y   but gets mapped to $DDDD,X   handled in v6502_modeABX
