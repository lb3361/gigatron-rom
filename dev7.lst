                                          7433  # Entry point
                                          7434  # - Note that sysFn must be set to 0x0001 before this
                                          7435  label('se:exec')
se:exec:      1672 fc28  bra  fsm16:LUP   7436  fsmAsm('LUP')
              1673 0074  ld   $74
              1674 fc0a  bra  fsm16:ST    7437  fsmAsm('ST', sysArgs+3)
              1675 0027  ld   $27
              1676 fc17  bra  fsm16:BNZ   7438  fsmAsm('BNZ', 'se:loadGt1:al')
              1677 004c  ld   $4c
              1678 fc28  bra  fsm16:LUP   7439  fsmAsm('LUP')
              1679 007a  ld   $7a
              167a fc0a  bra  fsm16:ST    7440  fsmAsm('ST', sysArgs+2)
              167b 0026  ld   $26
              167c fc0e  bra  fsm16:ADD   7441  fsmAsm('ADD', 1)
              167d 0001  ld   $01
              167e fc17  bra  fsm16:BNZ   7442  fsmAsm('BNZ', 'se:loadGt1:len')
