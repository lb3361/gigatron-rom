                                          4068  #-----------------------------------------------------------------------
                                          4069  # Extension SYS_Sprite6_v3_64
                                          4070  # Extension SYS_Sprite6x_v3_64
                                          4071  # Extension SYS_Sprite6y_v3_64
                                          4072  # Extension SYS_Sprite6xy_v3_64
                                          4073  #-----------------------------------------------------------------------
                                          4074
                                          4075  # Blit sprite in screen memory
                                          4076  #
                                          4077  # Variables
                                          4078  #       vAC             Destination address in screen
                                          4079  #       sysArgs[0:1]    Source address of 6xY pixels (colors 0..63) terminated
                                          4080  #                       by negative byte value N (typically N = -Y)
                                          4081  #       sysArgs[2:7]    Scratch (user as copy buffer)
                                          4082  #
                                          4083  # This SYS function draws a sprite of 6 pixels wide and Y pixels high.
                                          4084  # The pixel data is read sequentually from RAM, in horizontal chunks
                                          4085  # of 6 pixels at a time, and then written to the screen through the
                                          4086  # destination pointer (each chunk underneath the previous), thus
                                          4087  # drawing a 6xY stripe. Pixel values should be non-negative. The first
                                          4088  # negative byte N after a chunk signals the end of the sprite data.
                                          4089  # So the sprite's height Y is determined by the source data and is
                                          4090  # therefore flexible. This negative byte value, typically N == -Y,
                                          4091  # is then used to adjust the destination pointer's high byte, to make
                                          4092  # it easier to draw sprites wider than 6 pixels: just repeat the SYS
                                          4093  # call for as many 6-pixel wide stripes you need. All arguments are
                                          4094  # already left in place to facilitate this. After one call, the source
                                          4095  # pointer will point past that source data, effectively:
                                          4096  #       src += Y * 6 + 1
                                          4097  # The destination pointer will have been adjusted as:
                                          4098  #       dst += (Y + N) * 256 + 6
                                          4099  # (With arithmetic wrapping around on the same memory page)
                                          4100  #
                                          4101  # Y is only limited by source memory, not by CPU cycles. The
                                          4102  # implementation is such that the SYS function self-repeats, each
                                          4103  # time drawing the next 6-pixel chunk. It can typically draw 12
                                          4104  # pixels per scanline this way.
                                          4105
                                          4106  label('SYS_Sprite6_v3_64')
                                          4107
SYS_Sprite6_v3_64:
              0c00 1124  ld   [$24],x     4108  ld([sysArgs+0],X)               #15 Pixel data source address
              0c01 1525  ld   [$25],y     4109  ld([sysArgs+1],Y)               #16
              0c02 0d00  ld   [y,x]       4110  ld([Y,X])                       #17 Next pixel or stop
              0c03 f411  bge  .sysDpx0    4111  bpl('.sysDpx0')                 #18
              0c04 de00  st   [y,x++]     4112  st([Y,Xpp])                     #19 Just X++
                                          4113
              0c05 8119  adda [$19]       4114  adda([vAC+1])                   #20 Adjust dst for convenience
              0c06 c219  st   [$19]       4115  st([vAC+1])                     #21
              0c07 0118  ld   [$18]       4116  ld([vAC])                       #22
              0c08 8006  adda $06         4117  adda(6)                         #23
              0c09 c218  st   [$18]       4118  st([vAC])                       #24
              0c0a 0124  ld   [$24]       4119  ld([sysArgs+0])                 #25 Adjust src for convenience
              0c0b 8001  adda $01         4120  adda(1)                         #26
