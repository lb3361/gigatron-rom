              01c6 ecc9  bne  $01c9       1548  bne(pc()+3)                     #72
              01c7 fcca  bra  $01ca       1549  bra(pc()+3)                     #73
              01c8 0001  ld   $01         1550  ld('videoA')                    #74
              01c9 00ec  ld   $ec         1551  ld('videoF')                    #74(!)
              01ca c20d  st   [$0d]       1552  st([nextVideo])                 #75
              01cb 0102  ld   [$02]       1553  ld([channel])                   #76 Normalize channel for robustness
              01cc 2003  anda $03         1554  anda(0b00000011)                #77
              01cd c202  st   [$02]       1555  st([channel])                   #78
