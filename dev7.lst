                                          847   #-----------------------------------------------------------------------
                                          848   # Extension SYS_Divide_s16_v6_80: 15 bit division
                                          849   # Also known as SYS_Divide_u16_v7_34
                                          850   #-----------------------------------------------------------------------
                                          851   #
                                          852   # Computes the Euclidean division of 0<=A<65536 and 0<B<65536.
                                          853   # The s16 component of the name is a misnomer (should be u15).
                                          854   # For 16 bits signed division, additional code must handle the signs
                                          855   # Return the quotient in vAC as well as sysArgs[01]
                                          856   # Return the remainder in sysArgs[45]
                                          857   #
                                          858   #       sysArgs[0:1]    Dividend A (in) Quotient (out)
                                          859   #       sysArgs[2:3]    Divisor B (in)
                                          860   #       sysArgs[4:5]    Remainder (out)
                                          861   #       sysArgs[6:7]    (changed)
                                          862   #
                                          863   # Original design by at67.
                                          864   #
                                          865   # The improced dev7rom version handles unrestricted 16 bits unsigned division
                                          866   # that is 0 <= A,B <= 65535. An external wrapper is still needed for signed
                                          867   # division. Alternatively any of the new opcodes RDIVU or RDIVS.
                                          868
                                          869   label('SYS_Divide_s16_v6_80')
                                          870   label('SYS_Divide_u16_v7_34')
SYS_Divide_s16_v6_80:
SYS_Divide_u16_v7_34:
