                                          3267  #-----------------------------------------------------------------------
                                          3268  # Extension SYS_Read3_40
                                          3269  #-----------------------------------------------------------------------
                                          3270
                                          3271  # Read 3 consecutive bytes from ROM
                                          3272  #
                                          3273  # Note: This function a bit obsolete, as it has very limited use. It's
                                          3274  #       effectively an application-specific SYS function for the Pictures
                                          3275  #       application from ROM v1. It requires the ROM data be organized
                                          3276  #       with trampoline3a and trampoline3b fragments, and their address
                                          3277  #       in ROM to be known. Better avoid using this.
                                          3278  # Variables:
                                          3279  #       sysArgs[0:2]    Bytes (out)
                                          3280  #       sysArgs[6:7]    ROM pointer (in)
                                          3281
                                          3282  fillers(until = 0xb9)
                                          3283  assert pc() == 0x6b9
                                          3284
                                          3285  label('SYS_Read3_40')
SYS_Read3_40: 06b9 152b  ld   [$2b],y     3286  ld([sysArgs+7],Y)               #15,43
              06ba e079  jmp  y,$79       3287  jmp(Y,128-7)                    #16 trampoline3a
              06bb 012a  ld   [$2a]       3288  ld([sysArgs+6])                 #17
                                          3289  label('txReturn')
txReturn:     06bc c226  st   [$26]       3290  st([sysArgs+2])                 #34
              06bd 1403  ld   $03,y       3291  ld(hi('REENTER'),Y)             #35
              06be e0cb  jmp  y,$cb       3292  jmp(Y,'REENTER')                #36
              06bf 00ec  ld   $ec         3293  ld(-40/2)                       #37
                                          3294
                                          3295  def trampoline3a():
                                          3296    """Read 3 bytes from ROM page"""
                                          3297    while pc()&255 < 128-7:
                                          3298      nop()
                                          3299    bra(AC)                       #18
                                          3300    C('Trampoline for page $%02x00 reading (entry)' % (pc()>>8))
                                          3301    bra(123)                      #19
                                          3302    st([sysArgs+0])               #21
                                          3303    ld([sysArgs+6])               #22
                                          3304    adda(1)                       #23
                                          3305    bra(AC)                       #24
                                          3306    bra(250)                      #25 trampoline3b
                                          3307    align(1, size=0x80)
                                          3308
                                          3309  def trampoline3b():
                                          3310    """Read 3 bytes from ROM page (continue)"""
                                          3311    while pc()&255 < 256-6:
                                          3312      nop()
                                          3313    st([sysArgs+1])               #27
                                          3314    C('Trampoline for page $%02x00 reading (continue)' % (pc()>>8))
                                          3315    ld([sysArgs+6])               #28
                                          3316    adda(2)                       #29
                                          3317    ld(hi('txReturn'),Y)          #30
                                          3318    bra(AC)                       #31
                                          3319    jmp(Y,'txReturn')             #32
                                          3320    align(1, size=0x100)
