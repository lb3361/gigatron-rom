                                          3444  # Extension SYS_Unpack_56
                                          3445  #-----------------------------------------------------------------------
                                          3446
                                          3447  # Unpack 3 bytes into 4 pixels
                                          3448  #
                                          3449  # Variables:
                                          3450  #       sysArgs[0:2]    Packed bytes (in)
                                          3451  #       sysArgs[0:3]    Pixels (out)
                                          3452
                                          3453  fillers(until = 0xc0)
                                          3454  assert pc() == 0x6c0
