                                          3831  #-----------------------------------------------------------------------
                                          3832  # Extension SYS_ReceiveSerial1_v6_32
                                          3833  #-----------------------------------------------------------------------
                                          3834
                                          3835  # SYS function for receiving one byte over the serial controller port.
                                          3836  # This is a public version of SYS_NextByteIn from the loader private
                                          3837  # extension.  A byte is read from IN when videoY reaches
                                          3838  # sysArgs[3]. The byte is added to the checksum sysArgs[2] then stored
                                          3839  # at address sysArgs[0:1] which gets incremented.
                                          3840  #
                                          3841  # The 65 bytes of a serial frame can be read for the following values
                                          3842  # of videoY: 207 (protocol byte) 219 (length, 6 bits only) 235, 251
                                          3843  # (address) then 2, 6, 10, .. 238 stepping by four, then 185.
                                          3844  #
                                          3845  # Variables:
                                          3846  #     sysArgs[0:1] Address
                                          3847  #     sysArgs[2]   Checksum
                                          3848  #     sysArgs[3]   Wait value (videoY)
                                          3849
                                          3850  label('SYS_ReceiveSerial1_v6_32')
SYS_ReceiveSerial1_v6_32:                 3851  bra('sys_ReceiveSerial1')       #15
              0b18 fcb9  bra  sys_ReceiveSerial1
              0b19 0127  ld   [$27]       3852  ld([sysArgs+3])                 #16
