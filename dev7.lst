.select#83:   01d4 010b  ld   [$0b]       1568    ld([videoModeC])              #83
              01d5 e8db  blt  .select#86  1569    bmi('.select#86')             #84 Branch when line C is off
              01d6 010a  ld   [$0a]       1570    ld([videoModeB])              #85 Rotate: Off->D->B->C
              01d7 c20b  st   [$0b]       1571    st([videoModeC])              #86
