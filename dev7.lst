                                          1900    st([nextVideo])                 #30
                                          1901    ld([sample])                    #31 New sound sample is ready (didn't fit in audio loop)
                                          1902    ora(0x0f)                       #32
                                          1903    anda([xoutMask])                #33
                                          1904    st([xout])                      #34 Update [xout] with new sample (4 channels just updated)
