                                          7074  # Loader microprogram
                                          7075  label('sl:loader')
sl:loader:    1561 fc0c  bra  fsm15:LD    7076  fsmAsm('LD', 0x15)              # echo color gray
              1562 0015  ld   $15
                                          7077  label('sl:frame')
                                          7078  fsmAsm('SLECHO')
sl:frame:     1563 fc3f  bra  fsm15:SLECHO
              1564 0065  ld   $65
              1565 fc0c  bra  fsm15:LD    7079  fsmAsm('LD', 207)
              1566 00cf  ld   $cf
              1567 fc0a  bra  fsm15:ST    7080  fsmAsm('ST', sysArgs+6)         # reset serial index
              1568 002a  ld   $2a
              1569 fc22  bra  fsm15:SRIN  7081  fsmAsm('SRIN')
              156a 006b  ld   $6b
              156b fc0e  bra  fsm15:XOR   7082  fsmAsm('XOR', ord('L'))
              156c 004c  ld   $4c
              156d fc14  bra  fsm15:BNZ   7083  fsmAsm('BNZ', 'sl:loader')      # invalid packet
              156e 0061  ld   $61
              156f fc22  bra  fsm15:SRIN  7084  fsmAsm('SRIN')
              1570 0071  ld   $71
              1571 fc11  bra  fsm15:AND   7085  fsmAsm('AND', 0x3f)             # six valid bits only
              1572 003f  ld   $3f
              1573 fc0a  bra  fsm15:ST    7086  fsmAsm('ST', sysArgs+4)         # len
              1574 0028  ld   $28
              1575 fc14  bra  fsm15:BNZ   7087  fsmAsm('BNZ', 'sl:packet')
              1576 0083  ld   $83
              1577 fc22  bra  fsm15:SRIN  7088  fsmAsm('SRIN')
              1578 0079  ld   $79
              1579 fc0a  bra  fsm15:ST    7089  fsmAsm('ST', vLR)               # execl
              157a 001a  ld   $1a
              157b fc22  bra  fsm15:SRIN  7090  fsmAsm('SRIN')
              157c 007d  ld   $7d
              157d fc0a  bra  fsm15:ST    7091  fsmAsm('ST', vLR+1)             # exech
              157e 001b  ld   $1b
                                          7092  fsmAsm('VRETNZ')
              157f fc1a  bra  fsm15:VRETNZ
              1580 0081  ld   $81
                                          7093  label('sl:loop')
sl:loop:      1581 fc17  bra  fsm15:B     7094  fsmAsm('B','sl:loop')
              1582 0081  ld   $81
                                          7095  label('sl:packet')
sl:packet:    1583 fc22  bra  fsm15:SRIN  7096  fsmAsm('SRIN')
              1584 0085  ld   $85
              1585 fc0a  bra  fsm15:ST    7097  fsmAsm('ST', sysArgs+2)         # addrl
              1586 0026  ld   $26
              1587 fc22  bra  fsm15:SRIN  7098  fsmAsm('SRIN')
              1588 0089  ld   $89
              1589 fc0a  bra  fsm15:ST    7099  fsmAsm('ST', sysArgs+3)         # addrh
              158a 0027  ld   $27
