                                          7245
                                          7246
              15fe 0200  nop              7247  fillers(until=0xff)
                                          7248  label('FSM16_ENTER')
FSM16_ENTER:  15ff fc03  bra  $1603       7249  bra(pc()+4)                     #0
                                          7250  align(0x100, size=0x100)
              1600 fd2b  bra  [$2b]       7251  bra([fsmState])                 #1
                                          7252  assert (pc() & 255) == (symbol('NEXT') & 255)
                                          7253  label('FSM16_NEXT')
FSM16_NEXT:   1601 8115  adda [$15]       7254  adda([vTicks])                  #0
              1602 f52b  bge  [$2b]       7255  bge([fsmState],warn=False)      #1
              1603 c215  st   [$15]       7256  st([vTicks])                    #2
              1604 800f  adda $0f         7257  adda(maxTicks)                  #3
              1605 e405  bgt  $1605       7258  bgt(pc()&255)                   #4
              1606 a001  suba $01         7259  suba(1)                         #5
              1607 1401  ld   $01,y       7260  ld(hi('vBlankStart'),Y)         #6
              1608 e11e  jmp  y,[$1e]     7261  jmp(Y,[vReturn])                #7
              1609 0102  ld   [$02]       7262  ld([channel])                   #8
