              11f4 de00  st   [y,x++]     5945  st([Y,Xpp])                     #28 Just X++
              11f5 c21a  st   [$1a]       5946  st([v6502_PCL])                 #29
              11f6 0d00  ld   [y,x]       5947  ld([Y,X])                       #30
              11f7 c21b  st   [$1b]       5948  st([v6502_PCH])                 #31
              11f8 0200  nop              5949  nop()                           #32
