              1283 0d00  ld   [y,x]       6176  ld([Y,X])                       #22
              1284 1118  ld   [$18],x     6177  ld([vAC+0],X)                   #23
              1285 ce00  st   [y,x]       6178  st([Y,X])                       #24
              1286 8200  adda ac          6179  adda(AC)                        #25 j += T[4i]
              1287 8200  adda ac          6180  adda(AC,)                       #26
              1288 8118  adda [$18]       6181  adda([vAC+0])                   #27
              1289 c218  st   [$18]       6182  st([vAC+0])                     #28
              128a 1119  ld   [$19],x     6183  ld([vAC+1],X)                   #29 T[4i] = tmp
              128b 012f  ld   [$2f]       6184  ld([vTmp])                      #30
              128c ce00  st   [y,x]       6185  st([Y,X])                       #31
              128d 0119  ld   [$19]       6186  ld([vAC+1])                     #32 i += 1
              128e 8004  adda $04         6187  adda(4)                         #33
              128f c219  st   [$19]       6188  st([vAC+1])                     #34
              1290 f093  beq  $1293       6189  beq(pc()+3)                     #35 For 64 iterations
              1291 fc94  bra  $1294       6190  bra(pc()+3)                     #36
              1292 00fe  ld   $fe         6191  ld(-2)                          #37
              1293 0000  ld   $00         6192  ld(0)                           #37(!)
              1294 8116  adda [$16]       6193  adda([vPC])                     #38
              1295 c216  st   [$16]       6194  st([vPC])                       #39
