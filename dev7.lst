                                          3467  #-----------------------------------------------------------------------
                                          3468  #
                                          3469  #  $0d00 ROM page 11: More SYS functions
                                          3470  #
                                          3471  #-----------------------------------------------------------------------
                                          3472
                                          3473  align(0x100, size=0x100)
                                          3474
                                          3475  #-----------------------------------------------------------------------
                                          3476  # Extension SYS_SetMode_v2_80
                                          3477  #-----------------------------------------------------------------------
                                          3478
                                          3479  # Set video mode to 0 to 3 black scanlines per pixel line.
                                          3480  #
                                          3481  # Mainly for making the MODE command available in Tiny BASIC, so that
                                          3482  # the user can experiment. It's adviced to refrain from using
                                          3483  # SYS_SetMode_v2_80 in regular applications. Video mode is a deeply
                                          3484  # personal preference, and the programmer shouldn't overrule the user
                                          3485  # in that choice. The Gigatron philisophy is that the end user has
                                          3486  # the final say on what happens on the system, not the application,
                                          3487  # even if that implies a degraded performance. This doesn't mean that
                                          3488  # all applications must work well in all video modes: mode 1 is still
                                          3489  # the default. If an application really doesn't work at all in that
                                          3490  # mode, it's acceptable to change mode once after loading.
                                          3491  #
                                          3492  # There's no "SYS_GetMode" function.
                                          3493  #
                                          3494  # Variables:
                                          3495  #       vAC bit 0:1     Mode:
                                          3496  #                         0      "ABCD" -> Full mode (slowest)
                                          3497  #                         1      "ABC-" -> Default mode after reset
                                          3498  #                         2      "A-C-" -> at67's mode
                                          3499  #                         3      "A---" -> HGM's mode
                                          3500  #       vAC bit 2:15    Ignored bits and should be 0
                                          3501  #
                                          3502  # Special values (ROM v4):
                                          3503  #       vAC = 1975      Zombie mode (no video signals, no input,
                                          3504  #                        no blinkenlights).
                                          3505  #       vAC = -1        Leave zombie mode and restore previous mode.
                                          3506
                                          3507  # Actual duration is <80 cycles, but keep some room for future extensions
                                          3508  label('SYS_SetMode_v2_80')
SYS_SetMode_v2_80:
              0b00 140b  ld   $0b,y       3509  ld(hi('sys_SetMode'),Y)         #15
              0b01 e05d  jmp  y,$5d       3510  jmp(Y,'sys_SetMode')            #16
              0b02 011e  ld   [$1e]       3511  ld([vReturn])                   #17
                                          3512
                                          3513  #-----------------------------------------------------------------------
                                          3514  # Extension SYS_SetMemory_v2_54
                                          3515  #-----------------------------------------------------------------------
                                          3516
                                          3517  # SYS function for setting 1..256 bytes
                                          3518  #
                                          3519  # sysArgs[0]   Copy count (in, changed)
                                          3520  # sysArgs[1]   Copy value (in)
                                          3521  # sysArgs[2:3] Destination address (in, changed)
                                          3522  #
                                          3523  # Sets up to 8 bytes per invocation before restarting itself through vCPU.
                                          3524  # Doesn't wrap around page boundary. Can run 3 times per 148-cycle time slice.
                                          3525  # All combined that gives a 300% speedup over ROMv4 and before.
                                          3526
                                          3527  label('SYS_SetMemory_v2_54')
SYS_SetMemory_v2_54:
              0b03 0124  ld   [$24]       3528  ld([sysArgs+0])                 #15
                                          3529  bra('sys_SetMemory#18')         #16
              0b04 fc1a  bra  sys_SetMemory#18
              0b05 1126  ld   [$26],x     3530  ld([sysArgs+2],X)               #17
                                          3531
                                          3532  #-----------------------------------------------------------------------
                                          3533  # Extension SYS_SendSerial1_v3_80
                                          3534  #-----------------------------------------------------------------------
                                          3535
                                          3536  # SYS function for sending data over serial controller port using
                                          3537  # pulse width modulation of the vertical sync signal.
                                          3538  #
                                          3539  # Variables:
                                          3540  #       sysArgs[0:1]    Source address               (in, changed)
                                          3541  #       sysArgs[2]      Start bit mask (typically 1) (in, changed)
                                          3542  #       sysArgs[3]      Number of send frames X      (in, changed)
                                          3543  #
                                          3544  # The sending will abort if input data is detected on the serial port.
                                          3545  # Returns 0 in case of all bits sent, or <>0 in case of abort
                                          3546  #
                                          3547  # This modulates the next upcoming X vertical pulses with the supplied
                                          3548  # data. A zero becomes a 7 line vPulse, a one will be 9 lines.
                                          3549  # After that, the vPulse width falls back to 8 lines (idle).
                                          3550
                                          3551  label('SYS_SendSerial1_v3_80')
SYS_SendSerial1_v3_80:
              0b06 0109  ld   [$09]       3552  ld([videoY])                    #15
                                          3553  bra('sys_SendSerial1')          #16
              0b07 fc8c  bra  sys_SendSerial1
              0b08 60b3  xora $b3         3554  xora(videoYline0)               #17 First line of vertical blank
                                          3555
                                          3556  #-----------------------------------------------------------------------
                                          3557  # Extension SYS_ExpanderControl_v4_40
                                          3558  #-----------------------------------------------------------------------
                                          3559
                                          3560  # Sets the I/O and RAM expander's control register
                                          3561  #
                                          3562  # Variables:
                                          3563  #       vAC bit 2       Device enable /SS0
                                          3564  #           bit 3       Device enable /SS1
                                          3565  #           bit 4       Device enable /SS2
                                          3566  #           bit 5       Device enable /SS3
                                          3567  #           bit 6       Banking B0
                                          3568  #           bit 7       Banking B1
                                          3569  #           bit 15      Data out MOSI
                                          3570  #       sysArgs[7]      Cache for control state (written to)
