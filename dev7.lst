              02d5 0103  ld   [$03]       2049    ld([sample])                    #31 New sound sample is ready (didn't fit in audio loop)
              02d6 400f  ora  $0f         2050    ora(0x0f)                       #32
              02d7 2114  anda [$14]       2051    anda([xoutMask])                #33
              02d8 c213  st   [$13]       2052    st([xout])                      #34 Update [xout] with new sample (4 channels just updated)
