nopixels:     02f6 1505  ld   [$05],y     2106    runVcpu(200-38,
              02f7 00ff  ld   $ff
              02f8 c21e  st   [$1e]
              02f9 e0ff  jmp  y,$ff
              02fa 003b  ld   $3b
                                          2107            'FBCD line 40-520',
