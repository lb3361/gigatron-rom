                                          6895  #
                                          6896  #  $1500 ROM page 21: SYS_Loader
                                          6897  #
                                          6898  #-----------------------------------------------------------------------
                                          6899
              14f9 0200  nop              6900  fillers(until=0xff)
              14fa 0200  nop
              14fb 0200  nop
              * 6 times
                                          6901  label('FSM15_ENTER')
FSM15_ENTER:  14ff fc03  bra  $1503       6902  bra(pc()+4)                     #0
                                          6903  align(0x100, size=0x100)
              1500 fd2b  bra  [$2b]       6904  bra([fsmState])                 #1
                                          6905  assert (pc() & 255) == (symbol('NEXT') & 255)
                                          6906  label('FSM15_NEXT')
FSM15_NEXT:   1501 8115  adda [$15]       6907  adda([vTicks])                  #0
              1502 f52b  bge  [$2b]       6908  bge([fsmState],warn=False)      #1
              1503 c215  st   [$15]       6909  st([vTicks])                    #2
              1504 800f  adda $0f         6910  adda(maxTicks)                  #3
              1505 e405  bgt  $1505       6911  bgt(pc()&255)                   #4
              1506 a001  suba $01         6912  suba(1)                         #5
              1507 1401  ld   $01,y       6913  ld(hi('vBlankStart'),Y)         #6
              1508 e11e  jmp  y,[$1e]     6914  jmp(Y,[vReturn])                #7
              1509 0102  ld   [$02]       6915  ld([channel])                   #8
                                          6916
                                          6917  # Ensure labels defined here do not conflict
                                          6918  def fsmLab(n):
                                          6919      return f'fsm15:{n}'
                                          6920
                                          6921  # Assemble u-opcode
                                          6922  def fsmAsm(op,arg=None):
                                          6923      bra(fsmLab(op))
                                          6924      ld(pc()+1) if arg is None else ld(arg)
                                          6925
                                          6926  # Usage fsmAsm('ST', arg)
                                          6927  # - [arg] := vACL
                                          6928  label(fsmLab('ST'))
fsm15:ST:     150a 1415  ld   $15,y       6929  ld(hi('fsmST#8'),Y)             #5
              150b e0a8  jmp  y,$a8       6930  jmp(Y,'fsmST#8')                #6 + overlap
                                          6931
                                          6932  # Usage fsmAsm('LD', arg)
                                          6933  # - vACL = arg with arg=d or arg=[d]
                                          6934  label(fsmLab('LD'))
fsm15:LD:     150c 1415  ld   $15,y       6935  ld(hi('fsmOP#8'),Y)             #5,7
              150d e0b2  jmp  y,$b2       6936  jmp(Y,'fsmOP#8')                #6 + overlap
                                          6937
                                          6938  # Usage fsmAsm('XOR', arg)
                                          6939  # - vACL += arg with arg=d or arg=[d]
                                          6940  label(fsmLab('XOR'))
fsm15:XOR:    150e 1415  ld   $15,y       6941  ld(hi('fsmOP#8'),Y)             #5,7
              150f e0b2  jmp  y,$b2       6942  jmp(Y,'fsmOP#8')                #6
              1510 6118  xora [$18]       6943  xora([vAC])                     #7
                                          6944
                                          6945  # Usage fsmAsm('AND', arg)
                                          6946  # - vACL &= arg with arg=d or arg=[d]
                                          6947  label(fsmLab('AND'))
fsm15:AND:    1511 1415  ld   $15,y       6948  ld(hi('fsmOP#8'),Y)             #5
              1512 e0b2  jmp  y,$b2       6949  jmp(Y,'fsmOP#8')                #6
              1513 2118  anda [$18]       6950  anda([vAC])                     #7
                                          6951
                                          6952  # Usage fsmAsm('BNZ', arg)
                                          6953  # - branch if [vACL] is nonzero
                                          6954  label(fsmLab('BNZ'))
fsm15:BNZ:    1514 1415  ld   $15,y       6955  ld(hi('fsmBNZ#8'),Y)            #5
              1515 e0bd  jmp  y,$bd       6956  jmp(Y,'fsmBNZ#8')               #6
              1516 c22f  st   [$2f]       6957  st([vTmp])                      #7
                                          6958
                                          6959  # Usage fsmAsm('B', arg)
                                          6960  # - unconditional branch
                                          6961  # - can be the same as BL is fsmLink can be trashed
                                          6962  label(fsmLab('B'))
fsm15:B:      1517 c22b  st   [$2b]       6963  st([fsmState])                  #5
              1518 fc01  bra  FSM15_NEXT  6964  bra('NEXT')                     #6
              1519 00fc  ld   $fc         6965  ld(-8/2)                        #7
                                          6966
                                          6967  # Usage: fsmAsm('VRETNZ')
                                          6968  # - if vLR is nonzero, return to vCPU at address vLR.
                                          6969  label(fsmLab('VRETNZ'))
fsm15:VRETNZ: 151a 1415  ld   $15,y       6970  ld(hi('fsmVRETNZ#8'),Y)         #5
              151b e0cc  jmp  y,$cc       6971  jmp(Y,'fsmVRETNZ#8')            #6
              151c c22b  st   [$2b]       6972  st([fsmState])                  #7
                                          6973
                                          6974  # Usage: fsmAsm('ST+')
                                          6975  # - store vACL into [sysArgs23]
                                          6976  # - increment low address byte sysArgs2
                                          6977  # - decrements count sysArgs+4 and return it in vACL
                                          6978  label(fsmLab('ST+'))
fsm15:ST+:    151d 1415  ld   $15,y       6979  ld(hi('fsmST+#8'),Y)            #5
              151e e0ee  jmp  y,$ee       6980  jmp(Y,'fsmST+#8')               #6 + overlap
                                          6981
                                          6982  # Usage: fsmAsm('CHANMASK')
                                          6983  # - clear channelMask if segment [sysArgs[23],sysArgs[23]+sysArgs[4]]
                                          6984  #   overlaps OSCL/OSCH for audio channel 1-3
                                          6985  label(fsmLab('CHANMASK'))
fsm15:CHANMASK:
              151f 1415  ld   $15,y       6986  ld(hi('fsmCHANMASK#8'),Y)       #5,7
              1520 e0db  jmp  y,$db       6987  jmp(Y,'fsmCHANMASK#8')          #6
              1521 c22b  st   [$2b]       6988  st([fsmState])                  #7
                                          6989
                                          6990  # Usage: fsmAsm('SRIN')
                                          6991  # - get one serial byte
                                          6992  # - wait until videoY==sysArgs6 and save IN into vAC
                                          6993  # - increment sysArgs6 to the next payload scanline
                                          6994  label(fsmLab('SRIN'))
fsm15:SRIN:   1522 c22f  st   [$2f]       6995  st([vTmp])                      #5
              1523 012a  ld   [$2a]       6996  ld([sysArgs+6])                 #6
              1524 6109  xora [$09]       6997  xora([videoY])                  #7
              1525 ec01  bne  FSM15_NEXT  6998  bne('NEXT')                     #8 restart until videoY==sysArgs0
              1526 00fb  ld   $fb         6999  ld(-10/2)                       #9
              1527 012f  ld   [$2f]       7000  ld([vTmp])                      #10
              1528 c22b  st   [$2b]       7001  st([fsmState])                  #11
              1529 012a  ld   [$2a]       7002  ld([sysArgs+6])                 #12 next position
              152a 2001  anda $01         7003  anda(1)                         #13 - even or odd?
              152b ec35  bne  sl:srin#16  7004  bne('sl:srin#16')               #14
              152c 012a  ld   [$2a]       7005  ld([sysArgs+6])                 #15
              152d 8004  adda $04         7006  adda(4)                         #16 even
              152e 60f2  xora $f2         7007  xora(242)                       #17
              152f f032  beq  $1532       7008  beq(pc()+3)                     #18
              1530 fc33  bra  $1533       7009  bra(pc()+3)                     #19
              1531 60f2  xora $f2         7010  xora(242)                       #20
              1532 00b9  ld   $b9         7011  ld(185)                         #20!
              1533 fc3c  bra  sl:srin#23  7012  bra('sl:srin#23')               #21
              1534 c22a  st   [$2a]       7013  st([sysArgs+6])                 #22
                                          7014  label('sl:srin#16')
sl:srin#16:   1535 200f  anda $0f         7015  anda(0xf)                       #16 odd magic
              1536 812a  adda [$2a]       7016  adda([sysArgs+6])               #17
              1537 6004  xora $04         7017  xora(4)                         #18
              1538 f43b  bge  $153b       7018  bpl(pc()+3)                     #19
              1539 fc3b  bra  $153b       7019  bra(pc()+2)                     #20
              153a 400b  ora  $0b         7020  ora(11)                         #21
              153b c22a  st   [$2a]       7021  st([sysArgs+6])                 #22,21
                                          7022  label('sl:srin#23')
sl:srin#23:   153c c318  st   in,[$18]    7023  st(IN,[vAC])                    #23 finally read byte
              153d fc01  bra  FSM15_NEXT  7024  bra('NEXT')                     #24
              153e 00f3  ld   $f3         7025  ld(-26/2)                       #25
                                          7026
                                          7027  # Usage: fsmAsm('SLECHO')
                                          7028  # - handle loader echo on the screen
                                          7029  # - sysArgs0 is the x address, 0 to disable
                                          7030  # - sysArgs1 is the pixel row.
                                          7031  # - vAC the pixel color
                                          7032  label(fsmLab('SLECHO'))
fsm15:SLECHO: 153f c22b  st   [$2b]       7033  st([fsmState])                  #5
              1540 0124  ld   [$24]       7034  ld([sysArgs+0])                 #6
              1541 1200  ld   ac,x        7035  ld(AC,X)                        #7
              1542 f050  beq  sl:next#10  7036  beq('sl:next#10')               #8
              1543 1525  ld   [$25],y     7037  ld([sysArgs+1],Y)               #9
              1544 a00b  suba $0b         7038  suba(11)                        #10
              1545 207f  anda $7f         7039  anda(127)                       #11
              1546 800c  adda $0c         7040  adda(12)                        #12
              1547 c224  st   [$24]       7041  st([sysArgs+0])                 #13
              1548 0118  ld   [$18]       7042  ld([vAC])                       #14
              1549 ce00  st   [y,x]       7043  st([Y,X])                       #15
              154a 1124  ld   [$24],x     7044  ld([sysArgs+0],X)               #16
              154b 603f  xora $3f         7045  xora(0x3f)                      #17
              154c fc4e  bra  sl:next#20  7046  bra('sl:next#20')               #18
              154d ce00  st   [y,x]       7047  st([Y,X])                       #19
                                          7048  label('sl:next#20')
sl:next#20:   154e fc01  bra  FSM15_NEXT  7049  bra('NEXT')                     #20
              154f 00f5  ld   $f5         7050  ld(-22/2)                       #21
                                          7051  label('sl:next#10')
sl:next#10:   1550 fc01  bra  FSM15_NEXT  7052  bra('NEXT')                     #10
              1551 00fa  ld   $fa         7053  ld(-12/2)                       #11
                                          7054
                                          7055  # Usage: fsmAsm('SLCHK')
                                          7056  # - checks for loader program
                                          7057  label(fsmLab('SLCHK'))
fsm15:SLCHK:  1552 c22b  st   [$2b]       7058  st([fsmState])                  #5
              1553 0128  ld   [$28]       7059  ld([sysArgs+4])                 #6 len>60?
              1554 8043  adda $43         7060  adda(67)                        #7
              1555 2080  anda $80         7061  anda(0x80)                      #8
              1556 c218  st   [$18]       7062  st([vAC])                       #9
              1557 0126  ld   [$26]       7063  ld([sysArgs+2])                 #10 writing echo area?
              1558 a020  suba $20         7064  suba(0x20)                      #11
              1559 2126  anda [$26]       7065  anda([sysArgs+2])               #12
              155a 3080  anda $80,x       7066  anda(0x80,X)                    #13 X=0 [no] X=0x80 [maybe]
              155b 0127  ld   [$27]       7067  ld([sysArgs+3])                 #14
              155c 6125  xora [$25]       7068  xora([sysArgs+1])               #15
              155d 4500  ora  [x]         7069  ora([X])                        #16
              155e ec5d  bne  $155d       7070  bne(pc()-1)                     #17
              155f fc4e  bra  sl:next#20  7071  bra('sl:next#20')               #18
              1560 c224  st   [$24]       7072  st([sysArgs+0])                 #19
