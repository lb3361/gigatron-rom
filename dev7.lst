                                          7342  label('se:loadGt1z:mcnt')
se:loadGt1z:mcnt:
              16a6 fc0c  bra  fsm16:LD    7343  fsmAsm('LD', [vAC+1])           # token
              16a7 0119  ld   [$19]
              16a8 fc11  bra  fsm16:AND   7344  fsmAsm('AND', 0xf)
              16a9 000f  ld   $0f
              16aa fc1a  bra  fsm16:BZ    7345  fsmAsm('BZ', 'se:loadGt1z:seg')
              16ab 00d4  ld   $d4
              16ac fc0e  bra  fsm16:ADD   7346  fsmAsm('ADD', 1)
              16ad 0001  ld   $01
              16ae fc0a  bra  fsm16:ST    7347  fsmAsm('ST', sysArgs+4)
              16af 0028  ld   $28
              16b0 fc0e  bra  fsm16:ADD   7348  fsmAsm('ADD', 0xf0)             # is 16 (15+1)?
              16b1 00f0  ld   $f0
              16b2 fc17  bra  fsm16:BNZ   7349  fsmAsm('BNZ', 'se:loadGt1z:offset')
              16b3 00b8  ld   $b8
              16b4 fc28  bra  fsm16:LUP   7350  fsmAsm('LUP')                   # extension byte for mcnt
              16b5 00b6  ld   $b6
              16b6 fc0a  bra  fsm16:ST    7351  fsmAsm('ST', sysArgs+4)
              16b7 0028  ld   $28
