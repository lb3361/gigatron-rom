                                          1494  label('.vBlankLast#32')
.vBlankLast#32:
              01a6 e028  jmp  y,$28       1495  jmp(Y,'vBlankLast#34')          #32 Jump out of page for space reasons
              01a7 1401  ld   $01,y       1496  ld(hi(pc()),Y)                  #33
                                          1497
                                          1498  label('vBlankLast#52')
                                          1499
                                          1500  # Respond to reset button (14 cycles)
                                          1501  # - ResetTimer decrements as long as just [Start] is pressed down
                                          1502  # - Reaching 0 (normal) or 128 (extended) triggers the soft reset sequence
                                          1503  # - Initial value is 128 (or 255 at boot), first decrement, then check
                                          1504  # - This starts vReset -> SYS_Reset_88 -> SYS_Exec_88 -> Reset.gcl -> Main.gcl
                                          1505  # - Main.gcl then recognizes extended presses if resetTimer is 0..127 ("paasei")
                                          1506  # - This requires a full cycle (4s) in the warm boot scenario
                                          1507  # - Or a half cycle (2s) when pressing [Select] down during hard reset
                                          1508  # - This furthermore requires >=1 frame (and <=128) to have passed between
                                          1509  #   reaching 128 and getting through Reset and the start of Main, while [Start]
                                          1510  #   was still pressed so the count reaches <128. Two reasonable expectations.
                                          1511  # - The unintended power-up scenarios of ROMv1 (pulling SER_DATA low, or
                                          1512  #   pressing [Select] together with another button) now don't trigger anymore.
                                          1513
vBlankLast#52:
              01a8 0111  ld   [$11]       1514  ld([buttonState])               #52 Check [Start] for soft reset
              01a9 60ef  xora $ef         1515  xora(~buttonStart)              #53
              01aa ecb3  bne  .restart#56 1516  bne('.restart#56')              #54
              01ab 0112  ld   [$12]       1517  ld([resetTimer])                #55 As long as button pressed
              01ac a001  suba $01         1518  suba(1)                         #56 ... count down the timer
              01ad c212  st   [$12]       1519  st([resetTimer])                #57
              01ae 207f  anda $7f         1520  anda(127)                       #58
              01af f0bb  beq  .restart#61 1521  beq('.restart#61')              #59 Reset at 0 (normal 2s) or 128 (extended 4s)
              01b0 00ee  ld   $ee         1522  ld((vReset&255)-2)              #60 Start force reset when hitting 0
              01b1 fcba  bra  .restart#63 1523  bra('.restart#63')              #61 ... otherwise do nothing yet
              01b2 fcb9  bra  .restart#64 1524  bra('.restart#64')              #62
                                          1525  label('.restart#56')
.restart#56:  01b3 0001  ld   $01         1526  wait(62-56)                     #56
              01b4 ecb4  bne  $01b4
              01b5 a001  suba $01
              01b6 0200  nop
              01b7 0080  ld   $80         1527  ld(128)                         #62 Not pressed, reset the timer
              01b8 c212  st   [$12]       1528  st([resetTimer])                #63
                                          1529  label('.restart#64')
.restart#64:  01b9 fcc0  bra  .restart#66 1530  bra('.restart#66')              #64
                                          1531  label('.restart#63')
.restart#63:  01ba 0200  nop              1532  nop()                           #63,65
                                          1533  label('.restart#61')
.restart#61:  01bb c216  st   [$16]       1534  st([vPC])                       #61 Point vPC at vReset
              01bc 0001  ld   $01         1535  ld(vReset>>8)                   #62
              01bd c217  st   [$17]       1536  st([vPC+1])                     #63
              01be 0002  ld   $02         1537  ld(hi('ENTER'))                 #64 Set active interpreter to vCPU
              01bf c205  st   [$05]       1538  st([vCpuSelect])                #65
                                          1539  label('.restart#66')
                                          1540
                                          1541  # Sets vReturn and nextVideo for visible lines
.restart#66:  01c0 00ff  ld   $ff         1542  ld(lo('vVisibEnter'))           #66
              01c1 c21e  st   [$1e]       1543  st([vReturn])                   #67
              01c2 1401  ld   $01,y       1544  ld(videoTop_v5>>8,Y)            #68
              01c3 09f9  ld   [y,$f9]     1545  ld([Y,videoTop_v5])             #69
              01c4 c209  st   [$09]       1546  st([videoY])                    #70
