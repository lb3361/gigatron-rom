                                          1628  #-----------------------------------------------------------------------
                                          1629  #
                                          1630  #  $0200 ROM page 2: Video loop visible scanlines
                                          1631  #
                                          1632  #-----------------------------------------------------------------------
                                          1633
                                          1634
                                          1635
                                          1636  if WITH_512K_BOARD:
                                          1637    assert pc() == 0x1ff            # Enables runVcpu() to re-enter into the next page
                                          1638    ld(syncBits,OUT)                #200,0 <New scan line start>
                                          1639    align(0x100, size=0x100)
                                          1640
                                          1641    # Front porch
                                          1642    anda([channelMask])             #1 AC is [channel] already!
                                          1643    adda(1)                         #2
                                          1644    st([channel],Y)                 #3
                                          1645    ld(syncBits^hSync,OUT)          #4 Start horizontal pulse (4)
                                          1646
                                          1647    # Horizontal sync and sound channel update for scanlines outside vBlank
                                          1648    label('sound2')
                                          1649    ld(0x7f)                        #5
                                          1650    anda([Y,oscL])                  #6
                                          1651    adda([Y,keyL])                  #7
                                          1652    st([Y,oscL])                    #8
                                          1653    anda(0x80,X)                    #9
                                          1654    ld([X])                         #10
                                          1655    adda([Y,oscH])                  #11
                                          1656    adda([Y,keyH])                  #12
                                          1657    st([Y,oscH] )                   #13
                                          1658    anda(0xfc)                      #14
                                          1659    xora([Y,wavX])                  #15
                                          1660    ld(AC,X)                        #16
                                          1661    ld([Y,wavA])                    #17
                                          1662    ld(soundTable>>8,Y)             #18
                                          1663    adda([Y,X])                     #19
                                          1664    bmi(pc()+3)                     #20
                                          1665    bra(pc()+3)                     #21
                                          1666    anda(63)                        #22
                                          1667    ld(63)                          #22(!)
                                          1668    adda([sample])                  #23
                                          1669    st([sample])                    #24
                                          1670    ld([xout])                      #25 Gets copied to XOUT
                                          1671    ld(videoTable>>8,Y)             #26 Make Y=1 for all videoABC routines!
                                          1672    bra([nextVideo])                #27
                                          1673    ld(syncBits,OUT)                #28 End horizontal pulse
                                          1674
                                          1675    # Back porch A: first of 4 repeated scan lines
                                          1676    # - Fetch next Yi and store it for retrieval in the next scan lines
                                          1677    # - Calculate Xi from dXi and store it as well thanks to a saved cycle.
                                          1678    label('videoA')
                                          1679    ld('videoB')                    #29 1st scanline of 4 (always visible)
                                          1680    st([nextVideo])                 #30
                                          1681    ld([videoY],X)                  #31
                                          1682    ld([Y,X])                       #32 Y is already 1
                                          1683    st([Y,Xpp])                     #33 Just X++
                                          1684    st([frameY])                    #34
                                          1685    ld([Y,X])                       #35
                                          1686    adda([frameX])                  #36
                                          1687    st([frameX],X)                  #37 I am sure Marcel sought to do this (LB)
                                          1688    ld([frameY],Y)                  #38
                                          1689    ld(syncBits)                    #39
                                          1690    ora([Y,Xpp],OUT)                #40 begin of pixel burst
                                          1691    runVcpu(200-41,                 #41
                                          1692            'A--- line 40-520',
                                          1693            returnTo=0x1ff )
                                          1694
                                          1695    # Back porch B: second of 4 repeated scan lines
                                          1696    # - Process double vres
                                          1697    label('videoB')
                                          1698    ld('videoC')                    #29
                                          1699    st([nextVideo])                 #30
                                          1700    ld([frameY],Y)                  #31
                                          1701    ld([videoModeC])                #32 New role for videoModeC
                                          1702    anda(1)                         #33
                                          1703    adda([frameY])                  #34
                                          1704    st([frameY])                    #35
                                          1705    ld([frameX],X)                  #36
                                          1706    ld(syncBits)                    #37
                                          1707    bra([videoModeB])               #38
                                          1708    bra(pc()+2)                     #39
                                          1709    nop()                           #40 'pixels' or 'nopixels'
                                          1710    runVcpu(200-41,                 #41
                                          1711            '-B-- line 40-520',
                                          1712            returnTo=0x1ff )
                                          1713
                                          1714    # Back porch C: third of 4 repeated scan lines
                                          1715    # - Nothing new to for video do as Yi and Xi are known,
                                          1716    # - This is the time to emit and reset the next sound sample
                                          1717    label('videoC')
                                          1718    ld('videoD')                    #29 3rd scanline of 4
                                          1719    st([nextVideo])                 #30
                                          1720    ld([sample])                    #31 New sound sample is ready (didn't fit in audio loop)
                                          1721    ora(0x0f)                       #32
                                          1722    anda([xoutMask])                #33
                                          1723    st([xout])                      #34 Update [xout] with new sample (4 channels just updated)
                                          1724    ld([frameX],X)                  #35
                                          1725    ld([xoutMask])                  #36
                                          1726    bmi('videoC#39')                #37
                                          1727    ld([frameY],Y)                  #38
                                          1728    ld(syncBits)                    #39
                                          1729    ora([Y,Xpp], OUT)               #40 Always outputs pixels on C lines
                                          1730    runVcpu(200-41,                 #41
                                          1731            '--C- line 40-520 no sound',
                                          1732            returnTo=0x1ff )
                                          1733    label('videoC#39')
                                          1734    ld(syncBits)                    #39
                                          1735    ora([Y,Xpp], OUT)               #40 Always outputs pixels on C lines
                                          1736    ld([sample],Y)                  #41
                                          1737    st(sample, [sample])            #42 Reset for next sample
                                          1738    ctrl(Y,0xD0);                   #43 Forward audio to PWM (only when audio is active)
                                          1739    runVcpu(200-44,                 #44
                                          1740            '--C- line 40-520 sound forwarding',
                                          1741          returnTo=0x1ff )
                                          1742
                                          1743    # Back porch D: last of 4 repeated scan lines
                                          1744    # - Calculate the next frame index
                                          1745    # - Decide if this is the last line or not
                                          1746    label('videoD')                 # Default video mode
                                          1747    ld([frameX], X)                 #29 4th scanline of 4
                                          1748    ld([videoY])                    #30
                                          1749    suba((120-1)*2)                 #31
                                          1750    beq('.lastpixels#34')           #32
                                          1751    adda(120*2)                     #33 More pixel lines to go
                                          1752    st([videoY])                    #34
                                          1753    nop()                           #35
                                          1754    ld([frameY],Y)                  #36
                                          1755    ld(syncBits)                    #37
                                          1756    bra([videoModeD])               #38
                                          1757    bra(pc()+2)                     #39
                                          1758    nop()                           #40 'pixels' or 'nopixels'
                                          1759    nop()                           #41
                                          1760    ld('videoA')                    #42
                                          1761    label('videoD#43')
                                          1762    st([nextVideo])                 #43
                                          1763    runVcpu(200-44,                 #44
                                          1764            '---D line 40-520',
                                          1765            returnTo=0x1ff )
                                          1766
                                          1767    label('.lastpixels#34')
                                          1768    if soundDiscontinuity == 1:
                                          1769      st(sample, [sample])          #34 Sound continuity
                                          1770    else:
                                          1771      nop()                         #34
                                          1772    ld([frameY],Y)                  #35
                                          1773    ld(syncBits)                    #36
                                          1774    nop()                           #37
                                          1775    bra([videoModeD])               #38
                                          1776    bra(pc()+2)                     #39
                                          1777    nop()                           #40 'pixels' or 'nopixels'
                                          1778    bra('videoD#43')                #41
                                          1779    ld('videoE')                    #42 no more scanlines
                                          1780
                                          1781    # Back porch "E": after the last line
                                          1782    # - Go back and and enter vertical blank (program page 2)
                                          1783    label('videoE') # Exit visible area
                                          1784    ld(hi('vBlankStart'),Y)         #29 Return to vertical blank interval
                                          1785    jmp(Y,'vBlankStart')            #30
                                          1786    ld(syncBits)                    #31
                                          1787
                                          1788    # Video mode that blacks out one or more pixel lines from the top of screen.
                                          1789    # This yields some speed, but also frees up screen memory for other purposes.
                                          1790    # Note: Sound output becomes choppier the more pixel lines are skipped
                                          1791    # Note: The vertical blank driver leaves 0x80 behind in [videoSync1]
                                          1792    label('videoF')
                                          1793    ld([videoSync1])                #29 Completely black pixel line
                                          1794    adda(0x80)                      #30
                                          1795    st([videoSync1],X)              #31
                                          1796    ld([frameX])                    #32
                                          1797    suba([X])                       #33 Decrements every two VGA scanlines
                                          1798    beq('.videoF#36')               #34
                                          1799    st([frameX])                    #35
                                          1800    bra('.videoF#38')               #36
                                          1801    label('.videoF#36')
                                          1802    ld('videoA')                    #36,37 Transfer to visible screen area
                                          1803    st([nextVideo])                 #37
                                          1804    label('.videoF#38')
                                          1805    runVcpu(200-38,
                                          1806            'F--- line 40-520',
                                          1807            returnTo=0x1ff )        #38
                                          1808
                                          1809    fillers(until=0xfc);
                                          1810    label('pixels')
                                          1811    ora([Y,Xpp],OUT)                #40
                                          1812    label('nopixels')
                                          1813    nop()                           #40
                                          1814
                                          1815  elif WITH_128K_BOARD:
                                          1816
                                          1817    assert pc() == 0x1fe
                                          1818    ld([ctrlVideo],X)               #199
                                          1819    bra('sound3')                   #200,0 <New scan line start>
                                          1820    align(0x100, size=0x100)
                                          1821    ctrl(X)                         #1 Reset banking to page1.
                                          1822
                                          1823    # Back porch A: first of 4 repeated scan lines
                                          1824    # - Fetch next Yi and store it for retrieval in the next scan lines
                                          1825    # - Calculate Xi from dXi, but there is no cycle time left to store it as well
                                          1826    label('videoA')
                                          1827    ld('videoB')                    #29 1st scanline of 4 (always visible)
                                          1828    st([nextVideo])                 #30
                                          1829    ld(videoTable>>8,Y)             #31
                                          1830    ld([videoY],X)                  #32
                                          1831    ld([Y,X])                       #33
                                          1832    st([Y,Xpp])                     #34 Just X++
                                          1833    st([frameY])                    #35
                                          1834    ld([Y,X])                       #36
                                          1835    adda([frameX],X)                #37
                                          1836    label('pixels')
                                          1837    ld([frameY],Y)                  #38
                                          1838    ld(syncBits)                    #39
                                          1839
                                          1840    # Stream 160 pixels from memory location <Yi,Xi> onwards
                                          1841    # Superimpose the sync signal bits to be robust against misprogramming
                                          1842    for i in range(qqVgaWidth):
