                                          1095  #-----------------------------------------------------------------------
                                          1096
                                          1097  # SYS function for copying 1..256 bytes
                                          1098  #
                                          1099  # sysArgs[0:1]    Destination address
                                          1100  # sysArgs[2:3]    Source address
                                          1101  # vAC[0]          Count (0 means 256)
                                          1102  #
                                          1103  # Doesn't cross page boundaries.
                                          1104  # Overwrites sysArgs[4:7] and vLR.
                                          1105
                                          1106  label('SYS_CopyMemory_v6_80')
SYS_CopyMemory_v6_80:
              00e9 1413  ld   $13,y       1107  ld(hi('sys_CopyMemory'),Y)       # 15 slot 0xe9
              00ea e000  jmp  y,$00       1108  jmp(Y, 'sys_CopyMemory')         # 16
              00eb 0118  ld   [$18]       1109  ld([vAC])                        # 17
