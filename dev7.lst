.restart#66:  01cc 0111  ld   [$11]       1536  ld([buttonState])               #66 Check [Select] to switch modes
              01cd 60df  xora $df         1537  xora(~buttonSelect)             #67 Only trigger when just [Select] is pressed
              01ce ece4  bne  .select#70  1538  bne('.select#70')               #68
                                          1539
                                          1540  if not WITH_512K_BOARD:
              01cf 010b  ld   [$0b]       1541    ld([videoModeC])              #69
              01d0 e8d6  blt  .select#72  1542    bmi('.select#72')             #70 Branch when line C is off
              01d1 010a  ld   [$0a]       1543    ld([videoModeB])              #71 Rotate: Off->D->B->C
              01d2 c20b  st   [$0b]       1544    st([videoModeC])              #72
              01d3 010c  ld   [$0c]       1545    ld([videoModeD])              #73
              01d4 c20a  st   [$0a]       1546    st([videoModeB])              #74
              01d5 fcdb  bra  .select#77  1547    bra('.select#77')             #75
                                          1548    label('.select#72')
.select#72:   01d6 00f6  ld   $f6         1549    ld('nopixels')                #72,76
              01d7 000a  ld   $0a         1550    ld('pixels')                  #73 Reset: On->D->B->C
              01d8 c20b  st   [$0b]       1551    st([videoModeC])              #74
              01d9 c20a  st   [$0a]       1552    st([videoModeB])              #75
              01da 0200  nop              1553    nop()                         #76
                                          1554    label('.select#77')
.select#77:   01db c20c  st   [$0c]       1555    st([videoModeD])              #77
                                          1556  else:
