                                          3014  #
                                          3015  #  $0500 ROM page 5-6: Shift table and code
                                          3016  #
                                          3017  #-----------------------------------------------------------------------
                                          3018
                                          3019  align(0x100, size=0x200)
                                          3020
                                          3021  # Lookup table for i>>n, with n in 1..6
                                          3022  # Indexing ix = i & ~b | (b-1), where b = 1<<(n-1)
                                          3023  #       ...
                                          3024  #       ld   <.ret
                                          3025  #       st   [vTmp]
                                          3026  #       ld   >shiftTable,y
                                          3027  #       <calculate ix>
                                          3028  #       jmp  y,ac
                                          3029  #       bra  $ff
                                          3030  # .ret: ...
                                          3031  #
                                          3032  # i >> 7 can be always be done with RAM: [i&128]
                                          3033  #       ...
                                          3034  #       anda $80,x
                                          3035  #       ld   [x]
                                          3036  #       ...
                                          3037
                                          3038  label('shiftTable')
                                          3039  shiftTable = pc()
                                          3040
                                          3041  for ix in range(255):
                                          3042    for n in range(1,7): # Find first zero
                                          3043      if ~ix & (1 << (n-1)):
                                          3044        break
                                          3045    pattern = ['x' if i<n else '1' if ix&(1<<i) else '0' for i in range(8)]
                                          3046    ld(ix>>n); C('0b%s >> %d' % (''.join(reversed(pattern)), n))
