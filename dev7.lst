                                          1491  label('vBlankLast#52')
                                          1492
                                          1493  # Respond to reset button (14 cycles)
                                          1494  # - ResetTimer decrements as long as just [Start] is pressed down
                                          1495  # - Reaching 0 (normal) or 128 (extended) triggers the soft reset sequence
                                          1496  # - Initial value is 128 (or 255 at boot), first decrement, then check
                                          1497  # - This starts vReset -> SYS_Reset_88 -> SYS_Exec_88 -> Reset.gcl -> Main.gcl
                                          1498  # - Main.gcl then recognizes extended presses if resetTimer is 0..127 ("paasei")
                                          1499  # - This requires a full cycle (4s) in the warm boot scenario
                                          1500  # - Or a half cycle (2s) when pressing [Select] down during hard reset
                                          1501  # - This furthermore requires >=1 frame (and <=128) to have passed between
                                          1502  #   reaching 128 and getting through Reset and the start of Main, while [Start]
                                          1503  #   was still pressed so the count reaches <128. Two reasonable expectations.
                                          1504  # - The unintended power-up scenarios of ROMv1 (pulling SER_DATA low, or
                                          1505  #   pressing [Select] together with another button) now don't trigger anymore.
                                          1506
vBlankLast#52:
              01b4 0111  ld   [$11]       1507  ld([buttonState])               #52 Check [Start] for soft reset
              01b5 60ef  xora $ef         1508  xora(~buttonStart)              #53
              01b6 ecbf  bne  .restart#56 1509  bne('.restart#56')              #54
              01b7 0112  ld   [$12]       1510  ld([resetTimer])                #55 As long as button pressed
              01b8 a001  suba $01         1511  suba(1)                         #56 ... count down the timer
              01b9 c212  st   [$12]       1512  st([resetTimer])                #57
              01ba 207f  anda $7f         1513  anda(127)                       #58
              01bb f0c7  beq  .restart#61 1514  beq('.restart#61')              #59 Reset at 0 (normal 2s) or 128 (extended 4s)
              01bc 00ee  ld   $ee         1515  ld((vReset&255)-2)              #60 Start force reset when hitting 0
              01bd fcc6  bra  .restart#63 1516  bra('.restart#63')              #61 ... otherwise do nothing yet
              01be fcc5  bra  .restart#64 1517  bra('.restart#64')              #62
                                          1518  label('.restart#56')
.restart#56:  01bf 0001  ld   $01         1519  wait(62-56)                     #56
              01c0 ecc0  bne  $01c0
              01c1 a001  suba $01
              01c2 0200  nop
              01c3 0080  ld   $80         1520  ld(128)                         #62 Not pressed, reset the timer
              01c4 c212  st   [$12]       1521  st([resetTimer])                #63
                                          1522  label('.restart#64')
.restart#64:  01c5 fccc  bra  .restart#66 1523  bra('.restart#66')              #64
                                          1524  label('.restart#63')
.restart#63:  01c6 0200  nop              1525  nop()                           #63,65
                                          1526  label('.restart#61')
.restart#61:  01c7 c216  st   [$16]       1527  st([vPC])                       #61 Point vPC at vReset
              01c8 0001  ld   $01         1528  ld(vReset>>8)                   #62
              01c9 c217  st   [$17]       1529  st([vPC+1])                     #63
              01ca 0002  ld   $02         1530  ld(hi('ENTER'))                 #64 Set active interpreter to vCPU
              01cb c205  st   [$05]       1531  st([vCpuSelect])                #65
                                          1532  label('.restart#66')
                                          1533
                                          1534  # Switch video mode when (only) select is pressed (16 cycles)
