              0c0d 0200  nop              4122  nop()                           #28
              0c0e 1403  ld   $03,y       4123  ld(hi('REENTER'),Y)             #29 Normal exit (no self-repeat)
              0c0f e0cb  jmp  y,$cb       4124  jmp(Y,'REENTER')                #30
              0c10 00ef  ld   $ef         4125  ld(-34/2)                       #31
