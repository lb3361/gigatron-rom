                                          2958  #-----------------------------------------------------------------------
                                          2959  #
                                          2960  #  vCPU extension functions (for acceleration and compaction) follow below.
                                          2961  #
                                          2962  #  The naming convention is: SYS_<CamelCase>[_v<V>]_<N>
                                          2963  #
                                          2964  #  With <N> the maximum number of cycles the function will run
                                          2965  #  (counted from NEXT to NEXT). This is the same number that must
                                          2966  #  be passed to the 'SYS' vCPU instruction as operand, and it will
                                          2967  #  appear in the GCL code upon use.
                                          2968  #
                                          2969  #  If a SYS extension got introduced after ROM v1, the version number of
                                          2970  #  introduction is included in the name. This helps the programmer to be
                                          2971  #  reminded to verify the acutal ROM version and fail gracefully on older
                                          2972  #  ROMs than required. See also Docs/GT1-files.txt on using [romType].
                                          2973  #
                                          2974  #-----------------------------------------------------------------------
                                          2975
              04a4 0200  nop              2976  fillers(until=0xa7)
              04a5 0200  nop
              04a6 0200  nop
