              121d 09f5  ld   [y,$f5]     6007  ld([Y, vIrqCtx_v7])             #84
              121e 1600  ld   ac,y        6008  ld(AC,Y)                        #85
              121f 09ff  ld   [y,$ff]     6009  ld([Y,0xff])                    #86 irqMask
                                          6010  beq('vBlankFirst#89')           #87
              1220 f024  beq  vBlankFirst#89
              1221 cafe  st   [y,$fe]     6011  st([Y,0xfe])                    #88 irqFlag
                                          6012  n,m = runVcpu_ticks(190-89-extra, 5, '---D line 0 timeout masked irq')
                                          6013  bra('vBlankFirst#vCPU%d' % m)   #89
              1222 fc00  bra  vBlankFirst#vCPU1
              1223 001c  ld   $1c         6014  ld(n)
