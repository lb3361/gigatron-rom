              14e1 f4f6  bge  rdivs#9c    6864  bge('rdivs#9c')                 #7
              14e2 0001  ld   $01         6865  ld(1)                           #8
                                          6866  label('rdivs#9b')
rdivs#9b:     14e3 612a  xora [$2a]       6867  xora([sysArgs+6])               #9
