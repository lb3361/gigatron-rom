mulw#7a:      14c2 c22f  st   [$2f]       6825  st([vTmp])                      #7
              14c3 0118  ld   [$18]       6826  ld([vAC])                       #8
              14c4 c226  st   [$26]       6827  st([sysArgs+2])                 #9
              14c5 0119  ld   [$19]       6828  ld([vAC+1])                     #10
              14c6 c227  st   [$27]       6829  st([sysArgs+3])                 #11
              14c7 012a  ld   [$2a]       6830  ld([sysArgs+6])                 #12
              14c8 9001  adda $01,x       6831  adda(1,X)                       #13
              14c9 0500  ld   [x]         6832  ld([X])                         #14
              14ca c225  st   [$25]       6833  st([sysArgs+1])                 #15
              14cb 112a  ld   [$2a],x     6834  ld([sysArgs+6],X)               #16
              14cc 0500  ld   [x]         6835  ld([X])                         #17
              14cd c224  st   [$24]       6836  st([sysArgs+0])                 #18
              14ce 0000  ld   $00         6837  ld(0)                           #19
              14cf c228  st   [$28]       6838  st([sysArgs+4])                 #20
              14d0 c229  st   [$29]       6839  st([sysArgs+5])                 #21
              14d1 012f  ld   [$2f]       6840  ld([vTmp])                      #22
