                                          2837  #-----------------------------------------------------------------------
                                          2838  #
                                          2839  #  vCPU extension functions (for acceleration and compaction) follow below.
                                          2840  #
                                          2841  #  The naming convention is: SYS_<CamelCase>[_v<V>]_<N>
                                          2842  #
                                          2843  #  With <N> the maximum number of cycles the function will run
                                          2844  #  (counted from NEXT to NEXT). This is the same number that must
                                          2845  #  be passed to the 'SYS' vCPU instruction as operand, and it will
                                          2846  #  appear in the GCL code upon use.
                                          2847  #
                                          2848  #  If a SYS extension got introduced after ROM v1, the version number of
                                          2849  #  introduction is included in the name. This helps the programmer to be
                                          2850  #  reminded to verify the acutal ROM version and fail gracefully on older
                                          2851  #  ROMs than required. See also Docs/GT1-files.txt on using [romType].
                                          2852  #
                                          2853  #-----------------------------------------------------------------------
                                          2854
              04a4 0200  nop              2855  fillers(until=0xa7)
              04a5 0200  nop
              04a6 0200  nop
