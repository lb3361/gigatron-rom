                                          7264  # Ensure labels defined here do not conflict
                                          7265  def fsmLab(n):
                                          7266      return f'fsm16:{n}'
                                          7267
                                          7268  # Assemble u-opcode
                                          7269  def fsmAsm(op,arg=None):
                                          7270      bra(fsmLab(op))
                                          7271      ld(pc()+1) if arg is None else ld(arg)
                                          7272
                                          7273  # Usage fsmAsm('ST', arg)
                                          7274  # - [arg] := vACL
                                          7275  label(fsmLab('ST'))
fsm16:ST:     160a 1415  ld   $15,y       7276  ld(hi('fsmST#8'),Y)             #5
              160b e0a8  jmp  y,$a8       7277  jmp(Y,'fsmST#8')                #6 + overlap
                                          7278
                                          7279  # Usage fsmAsm('LD', arg)
                                          7280  # - vACL = arg with arg=d or arg=[d]
                                          7281  label(fsmLab('LD'))
fsm16:LD:     160c 1415  ld   $15,y       7282  ld(hi('fsmOP#8'),Y)             #5
              160d e0b2  jmp  y,$b2       7283  jmp(Y,'fsmOP#8')                #6 + overlap
                                          7284
                                          7285  # Usage fsmAsm('ADD', arg)
                                          7286  # - vACL += arg with arg=d or arg=[d]
                                          7287  label(fsmLab('ADD'))
fsm16:ADD:    160e 1415  ld   $15,y       7288  ld(hi('fsmOP#8'),Y)             #5,7
              160f e0b2  jmp  y,$b2       7289  jmp(Y,'fsmOP#8')                #6
              1610 8118  adda [$18]       7290  adda([vAC])                     #7
                                          7291
                                          7292  # Usage fsmAsm('AND', arg)
                                          7293  # - vACL &= arg with arg=d or arg=[d]
                                          7294  label(fsmLab('AND'))
fsm16:AND:    1611 1415  ld   $15,y       7295  ld(hi('fsmOP#8'),Y)             #5,7
              1612 e0b2  jmp  y,$b2       7296  jmp(Y,'fsmOP#8')                #6
              1613 2118  anda [$18]       7297  anda([vAC])                     #7
                                          7298
                                          7299  # Usage fsmAsm('LSR4')
                                          7300  # - right shift vACL by 4 positions (high nibble)
                                          7301  label(fsmLab('LSR4'))
fsm16:LSR4:   1614 1415  ld   $15,y       7302  ld(hi('fsmLSR4#8'),Y)           #5
              1615 e0b5  jmp  y,$b5       7303  jmp(Y,'fsmLSR4#8')              #6
              1616 c22b  st   [$2b]       7304  st([fsmState])                  #7
                                          7305
                                          7306  # Usage fsmAsm('BNZ', arg)
                                          7307  # - branch if [vACL] is nonzero
                                          7308  label(fsmLab('BNZ'))
fsm16:BNZ:    1617 1415  ld   $15,y       7309  ld(hi('fsmBNZ#8'),Y)            #5,7
              1618 e0bd  jmp  y,$bd       7310  jmp(Y,'fsmBNZ#8')               #6
              1619 c22f  st   [$2f]       7311  st([vTmp])                      #7
                                          7312
                                          7313  # Usage fsmAsm('BZ', arg)
                                          7314  # - branch if [vACL] is zero
                                          7315  label(fsmLab('BZ'))
fsm16:BZ:     161a 1415  ld   $15,y       7316  ld(hi('fsmBZ#8'),Y)             #5
              161b e0c2  jmp  y,$c2       7317  jmp(Y,'fsmBZ#8')                #6
              161c c22f  st   [$2f]       7318  st([vTmp])                      #7
                                          7319
                                          7320  # Usage fsmAsm('B', arg)
                                          7321  # - unconditional branch
                                          7322  # - can be the same as BL if sysArgs+6 can be trashed
                                          7323  label(fsmLab('B'))
                                          7324  #st([fsmState])                  #5
                                          7325  #bra('NEXT')                     #6
                                          7326  #ld(-8/2)                        #7
                                          7327
                                          7328  # Usage fsmAsm('BL', arg)
                                          7329  # - branch and link using sysArgs+6 as link register
                                          7330  # - call subroutine with fsmAsm('BL', 'label')
                                          7331  # - return from subroutine with fsmAsm('BL',[sysArgs+6])
                                          7332  label(fsmLab('BL'))
fsm16:B:
fsm16:BL:     161d 1415  ld   $15,y       7333  ld(hi('fsmBL#8'),Y)             #5
              161e e0c7  jmp  y,$c7       7334  jmp(Y,'fsmBL#8')                #6
              161f c22f  st   [$2f]       7335  st([vTmp])                      #7
                                          7336
                                          7337  # Usage: fsmAsm('VRETNZ')
                                          7338  # - if vLR is nonzero, return to vCPU at address vLR.
                                          7339  label(fsmLab('VRETNZ'))
fsm16:VRETNZ: 1620 1415  ld   $15,y       7340  ld(hi('fsmVRETNZ#8'),Y)         #5
              1621 e0cc  jmp  y,$cc       7341  jmp(Y,'fsmVRETNZ#8')            #6
              1622 c22b  st   [$2b]       7342  st([fsmState])                  #7
                                          7343
                                          7344  # Usage: fsmAsm('CHANMASK')
                                          7345  # - clear channelMask if segment [sysArgs[23],sysArgs[23]+sysArgs[4]]
                                          7346  #   overlaps OSCL/OSCH for audio channel 1-3
                                          7347  label(fsmLab('CHANMASK'))
fsm16:CHANMASK:
              1623 1415  ld   $15,y       7348  ld(hi('fsmCHANMASK#8'),Y)       #5
              1624 e0db  jmp  y,$db       7349  jmp(Y,'fsmCHANMASK#8')          #6
              1625 c22b  st   [$2b]       7350  st([fsmState])                  #7
                                          7351
                                          7352  # Usage: fsmAsm('ST+')
                                          7353  # - store vACL into [sysArgs23]
                                          7354  # - increment low address byte sysArgs2
                                          7355  # - decrements count sysArgs+4 and return it in vACL
                                          7356  label(fsmLab('ST+'))
fsm16:ST+:    1626 1415  ld   $15,y       7357  ld(hi('fsmST+#8'),Y)            #5
              1627 e0ee  jmp  y,$ee       7358  jmp(Y,'fsmST+#8')               #6 + overlap
                                          7359
                                          7360  # Usage: fsmAsm('LUP')
                                          7361  # - copy rom byte at [sysArgs01] into vACL
                                          7362  # - increment [sysArgs01] skipping trampolines
                                          7363  label(fsmLab('LUP'))
fsm16:LUP:    1628 c22b  st   [$2b]       7364  st([fsmState])                  #5
              1629 0124  ld   [$24]       7365  ld([sysArgs+0])                 #6
              162a a0fa  suba $fa         7366  suba(250)                       #7
                                          7367  beq(fsmLab('LUP#10'))           #8
              162b f032  beq  fsm16:LUP#10
              162c 1525  ld   [$25],y     7368  ld([sysArgs+1],Y)               #9
              162d 80fb  adda $fb         7369  adda(251)                       #10
              162e c224  st   [$24]       7370  st([sysArgs+0])                 #11
              162f a001  suba $01         7371  suba(1)                         #12
                                          7372  bra(fsmLab('LUP#15'))           #13
              1630 fc37  bra  fsm16:LUP#15
              1631 0200  nop              7373  nop()                           #14
                                          7374  label(fsmLab('LUP#10'))
fsm16:LUP#10: 1632 c224  st   [$24]       7375  st([sysArgs+0])                 #10
              1633 0125  ld   [$25]       7376  ld([sysArgs+1])                 #11
              1634 8001  adda $01         7377  adda(1)                         #12
              1635 c225  st   [$25]       7378  st([sysArgs+1])                 #13
              1636 00fa  ld   $fa         7379  ld(250)                         #14
                                          7380  label(fsmLab('LUP#15'))
fsm16:LUP#15: 1637 e0fb  jmp  y,$fb       7381  jmp(Y,251)                      #15
              1638 0200  nop              7382  nop()                           #16
                                          7383
                                          7384  # Usage: fsmAsm('LDMATCH')
                                          7385  # - compute address sysArgs[23] minus offset sysFn[01] (no carry)
                                          7386  # - load byte at this address into vACL
                                          7387  label(fsmLab('LDMATCH'))
fsm16:LDMATCH:
              1639 c22b  st   [$2b]       7388  st([fsmState])                  #5,7
              163a 0127  ld   [$27]       7389  ld([sysArgs+3])                 #6
              163b b523  suba [$23],y     7390  suba([sysFn+1],Y)               #7
              163c 0126  ld   [$26]       7391  ld([sysArgs+2])                 #8
              163d b122  suba [$22],x     7392  suba([sysFn],X)                 #9
              163e 0d00  ld   [y,x]       7393  ld([Y,X])                       #10
              163f c218  st   [$18]       7394  st([vAC])                       #11
              1640 fc01  bra  FSM16_NEXT  7395  bra('NEXT')                     #12
              1641 00f9  ld   $f9         7396  ld(-14/2)                       #13
                                          7397
                                          7398  # Subroutine to copy [sysArgs+4] literals at [sysArgs+23]
                                          7399  label('se:copyLiteral')
se:copyLiteral:                           7400  fsmAsm('CHANMASK')
              1642 fc23  bra  fsm16:CHANMASK
              1643 0044  ld   $44
                                          7401  label('se:copyLiteral.1')
se:copyLiteral.1:
              1644 fc28  bra  fsm16:LUP   7402  fsmAsm('LUP')
              1645 0046  ld   $46
              1646 fc26  bra  fsm16:ST+   7403  fsmAsm('ST+')
              1647 0048  ld   $48
              1648 fc17  bra  fsm16:BNZ   7404  fsmAsm('BNZ', 'se:copyLiteral.1')
              1649 0044  ld   $44
              164a fc1d  bra  fsm16:BL    7405  fsmAsm('BL', [sysArgs+6])
              164b 012a  ld   [$2a]
                                          7406
                                          7407  # Load uncompressed GT1
                                          7408  label('se:loadGt1:al')
se:loadGt1:al:
              164c fc28  bra  fsm16:LUP   7409  fsmAsm('LUP')
              164d 004e  ld   $4e
              164e fc0a  bra  fsm16:ST    7410  fsmAsm('ST', sysArgs+2)
              164f 0026  ld   $26
                                          7411  label('se:loadGt1:len')
se:loadGt1:len:
              1650 fc28  bra  fsm16:LUP   7412  fsmAsm('LUP')
              1651 0052  ld   $52
              1652 fc0a  bra  fsm16:ST    7413  fsmAsm('ST', sysArgs+4)
              1653 0028  ld   $28
              1654 fc1d  bra  fsm16:BL    7414  fsmAsm('BL', 'se:copyLiteral')
              1655 0042  ld   $42
              1656 fc28  bra  fsm16:LUP   7415  fsmAsm('LUP')
              1657 0058  ld   $58
              1658 fc0a  bra  fsm16:ST    7416  fsmAsm('ST', sysArgs+3)
              1659 0027  ld   $27
              165a fc17  bra  fsm16:BNZ   7417  fsmAsm('BNZ','se:loadGt1:al')
              165b 004c  ld   $4c
                                          7418
                                          7419  label('se:fin')
se:fin:       165c fc0c  bra  fsm16:LD    7420  fsmAsm('LD', 'SYS_Exec_88')     # restore sysFn
              165d 00ad  ld   $ad
              165e fc0a  bra  fsm16:ST    7421  fsmAsm('ST', sysFn)
              165f 0022  ld   $22
              1660 fc0c  bra  fsm16:LD    7422  fsmAsm('LD', hi('SYS_Exec_88'))
              1661 0000  ld   $00
              1662 fc0a  bra  fsm16:ST    7423  fsmAsm('ST', sysFn+1)
              1663 0023  ld   $23
                                          7424  fsmAsm('VRETNZ')
              1664 fc20  bra  fsm16:VRETNZ
              1665 0066  ld   $66
              1666 fc28  bra  fsm16:LUP   7425  fsmAsm('LUP')
              1667 0068  ld   $68
              1668 fc0a  bra  fsm16:ST    7426  fsmAsm('ST', vLR+1)
              1669 001b  ld   $1b
              166a fc28  bra  fsm16:LUP   7427  fsmAsm('LUP')
              166b 006c  ld   $6c
              166c fc0a  bra  fsm16:ST    7428  fsmAsm('ST', vLR)
              166d 001a  ld   $1a
                                          7429  label('se:ret')
                                          7430  fsmAsm('VRETNZ')
se:ret:       166e fc20  bra  fsm16:VRETNZ
              166f 0070  ld   $70
              1670 fc1d  bra  fsm16:BL    7431  fsmAsm('B', 'se:ret')           # don't crash, loop.
              1671 006e  ld   $6e
