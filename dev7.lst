                                          10651  #----------------------------------------
                                          10652  # LUP implementation
                                          10653
                                          10654  # LUP on dev7rom runs 4 cycles behind earlier ROMS.
                                          10655  # Clearing [vAC+1] is now achieved before branching
                                          10656  # into the rom page instead of in the return suffix.
                                          10657  # This permits sys_Exec to consult the ROM tables
                                          10658  # without losing the contents of [vAC+1] and with
                                          10659  # enough time to increment the lup pointer.
                                          10660  label('lup#13')
lup#13:       2000 1519  ld   [$19],y     10661  ld([vAC+1],Y)                   #13
              2001 1019  ld   $19,x       10662  ld(vAC+1,X)                     #14
              2002 e0fb  jmp  y,$fb       10663  jmp(Y,251)                      #15
              2003 c400  st   $00,[x]     10664  st(0,[X])                       #16 clear [vAC+1]
                                          10665
