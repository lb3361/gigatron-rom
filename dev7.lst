                                          5897  label('.cmp21')
.cmp21:       11cb 6080  xora $80         5898  xora(0x80)                      #21
              11cc 3080  anda $80,x       5899  anda(0x80,X)                    #22 Move carry to bit 0
              11cd 0127  ld   [$27]       5900  ld([v6502_P])                   #23 C flag
              11ce 20fe  anda $fe         5901  anda(~1)                        #24
              11cf 4500  ora  [x]         5902  ora([X])                        #25
              11d0 c227  st   [$27]       5903  st([v6502_P])                   #26
              11d1 140e  ld   $0e,y       5904  ld(hi('v6502_next'),Y)          #27
              11d2 e020  jmp  y,$20       5905  jmp(Y,'v6502_next')             #28
              11d3 00f1  ld   $f1         5906  ld(-30/2)                       #29
