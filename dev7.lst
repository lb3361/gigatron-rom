                                          891   #-----------------------------------------------------------------------
                                          892   # Extension SYS_Exec_88: Load code from ROM into memory and execute it
                                          893   #-----------------------------------------------------------------------
                                          894   #
                                          895   # This loads the vCPU code with consideration of the current vSP
                                          896   # Used during reset, but also for switching between applications or for
                                          897   # loading data from ROM from within an application (overlays).
                                          898   #
                                          899   # ROM stream format is
                                          900   #  [<addrH> <addrL> <n&255> n*<byte>]* 0 [<execH> <execL>]
                                          901   # on top of lookup tables.
                                          902   #
                                          903   #       sysArgs[0:1]    ROM pointer (in)
                                          904   #       sysArgs[2:3]    RAM pointer (changed) Execution address (out)
                                          905   #       sysArgs[4]      Byte counter (changed)
                                          906   #       sysArgs[7]      FSM state (changed)
                                          907   #       vLR==0          vCPU continues at GT1 execution address (in)
                                          908   #       vLR!=0          vCPU continues at vLR (in)
                                          909
                                          910   label('SYS_Exec_88')
SYS_Exec_88:  00ad 1420  ld   $20,y       911   ld(hi('sys_Exec'),Y)            #15
              00ae e009  jmp  y,$09       912   jmp(Y,'sys_Exec')               #16
              00af 0200  nop              913   nop()                           #17
                                          914
                                          915   #-----------------------------------------------------------------------
                                          916   # Extension SYS_Loader_DEVROM_44: Load code from serial input and execute
                                          917   #-----------------------------------------------------------------------
                                          918   #
                                          919   # This loads vCPU code and data presented on the serial port according
                                          920   # to the loader protocol then jumps to the avertised execution
                                          921   # address. This call never returns.
                                          922   #
                                          923   # Set sysArgs[0] to 0xc to enable visual feedback in the pixel
                                          924   # row located in page sysArgs[1]. This is automatically
                                          925   # disabled if bytes are loaded in the feedback area.
                                          926   #
                                          927   #       sysArgs[0]      Zero to disable echo (0x00 or ox0c) (in)
                                          928   #       sysArgs[1]      Echo row (0x59) (in)
                                          929   #
                                          930   # Credits: The first native loader was written for ROMvX0 by at67.
                                          931   #
                                          932   # Loader protocol
                                          933   # ---------------
                                          934   # The data is divided into chunks of at most 60 bytes to be loaded at
                                          935   # contiguous addresses inside a same gigatron memory page. Each chunk
                                          936   # is transmitted over the serial port (IN) synchronously with the
                                          937   # video signal, one chunk per frame. Each byte of the chunk must be
                                          938   # read from the IN port when videoY takes specific values:
                                          939   #
                                          940   #  videoY    Data
                                          941   #   207      protocol signature: 'L'
                                          942   #   219      chunk length (low 6 bits) or zero to execute.
                                          943   #   235      chunk address (l) or execution address (l) if len=0
                                          944   #   251      chunk address (h) or execution address (h)  if len=0
                                          945   #   2        chunk byte 0
                                          946   #   6        chunk byte 1
                                          947   #  ....
                                          948   #   2+4*k    chunk byte k
                                          949
              00b0 1415  ld   $15,y       950   ld(hi('sys_Loader'),Y)          #15 slot 0xb0
              00b1 e09b  jmp  y,$9b       951   jmp(Y,'sys_Loader')             #16
              00b2 0124  ld   [$24]       952   ld([sysArgs+0])                 #17
                                          953
                                          954   #-----------------------------------------------------------------------
                                          955   # More placeholders for future SYS functions
                                          956   #-----------------------------------------------------------------------
                                          957
