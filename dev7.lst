              04b6 1403  ld   $03,y       2889  ld(hi('REENTER'),Y)             #29
              04b7 e0cb  jmp  y,$cb       2890  jmp(Y,'REENTER')                #30
              04b8 00ef  ld   $ef         2891  ld(-34/2)                       #31
