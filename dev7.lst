                                          4188
                                          4189  #-----------------------------------------------------------------------
                                          4190  # Extension SYS_Sprite6_v3_64
                                          4191  # Extension SYS_Sprite6x_v3_64
                                          4192  # Extension SYS_Sprite6y_v3_64
                                          4193  # Extension SYS_Sprite6xy_v3_64
                                          4194  #-----------------------------------------------------------------------
                                          4195
                                          4196  # Blit sprite in screen memory
                                          4197  #
                                          4198  # Variables
                                          4199  #       vAC             Destination address in screen
                                          4200  #       sysArgs[0:1]    Source address of 6xY pixels (colors 0..63) terminated
                                          4201  #                       by negative byte value N (typically N = -Y)
                                          4202  #       sysArgs[2:7]    Scratch (user as copy buffer)
                                          4203  #
                                          4204  # This SYS function draws a sprite of 6 pixels wide and Y pixels high.
                                          4205  # The pixel data is read sequentually from RAM, in horizontal chunks
                                          4206  # of 6 pixels at a time, and then written to the screen through the
                                          4207  # destination pointer (each chunk underneath the previous), thus
                                          4208  # drawing a 6xY stripe. Pixel values should be non-negative. The first
                                          4209  # negative byte N after a chunk signals the end of the sprite data.
                                          4210  # So the sprite's height Y is determined by the source data and is
                                          4211  # therefore flexible. This negative byte value, typically N == -Y,
                                          4212  # is then used to adjust the destination pointer's high byte, to make
                                          4213  # it easier to draw sprites wider than 6 pixels: just repeat the SYS
                                          4214  # call for as many 6-pixel wide stripes you need. All arguments are
                                          4215  # already left in place to facilitate this. After one call, the source
                                          4216  # pointer will point past that source data, effectively:
                                          4217  #       src += Y * 6 + 1
                                          4218  # The destination pointer will have been adjusted as:
                                          4219  #       dst += (Y + N) * 256 + 6
                                          4220  # (With arithmetic wrapping around on the same memory page)
                                          4221  #
                                          4222  # Y is only limited by source memory, not by CPU cycles. The
                                          4223  # implementation is such that the SYS function self-repeats, each
                                          4224  # time drawing the next 6-pixel chunk. It can typically draw 12
                                          4225  # pixels per scanline this way.
                                          4226
                                          4227  label('SYS_Sprite6_v3_64')
                                          4228
SYS_Sprite6_v3_64:
              0c00 1124  ld   [$24],x     4229  ld([sysArgs+0],X)               #15 Pixel data source address
              0c01 1525  ld   [$25],y     4230  ld([sysArgs+1],Y)               #16
              0c02 0d00  ld   [y,x]       4231  ld([Y,X])                       #17 Next pixel or stop
              0c03 f411  bge  .sysDpx0    4232  bpl('.sysDpx0')                 #18
              0c04 de00  st   [y,x++]     4233  st([Y,Xpp])                     #19 Just X++
                                          4234
              0c05 8119  adda [$19]       4235  adda([vAC+1])                   #20 Adjust dst for convenience
              0c06 c219  st   [$19]       4236  st([vAC+1])                     #21
              0c07 0118  ld   [$18]       4237  ld([vAC])                       #22
              0c08 8006  adda $06         4238  adda(6)                         #23
              0c09 c218  st   [$18]       4239  st([vAC])                       #24
              0c0a 0124  ld   [$24]       4240  ld([sysArgs+0])                 #25 Adjust src for convenience
              0c0b 8001  adda $01         4241  adda(1)                         #26
              0c0c c224  st   [$24]       4242  st([sysArgs+0])                 #27
              0c0d 0200  nop              4243  nop()                           #28
              0c0e 1403  ld   $03,y       4244  ld(hi('REENTER'),Y)             #29 Normal exit (no self-repeat)
              0c0f e0cb  jmp  y,$cb       4245  jmp(Y,'REENTER')                #30
              0c10 00ef  ld   $ef         4246  ld(-34/2)                       #31
                                          4247
