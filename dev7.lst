                                          1046  #-----------------------------------------------------------------------
                                          1047  # Extension SYS_DoubleDabble_v7_34
                                          1048  #-----------------------------------------------------------------------
                                          1049
                                          1050  # SYS function to help converting integers into ascii in any base.
                                          1051  # The string of bytes [sysArgs[2:3]...sysArgs[0:1]-1] represents
                                          1052  # a number in base sysArgs[4]. Calling the SYS function doubles
                                          1053  # this number and adds 1 if vAC<=0 (msb set). If necessary
                                          1054  # sysArgs[2:3] is decremented to make space for a new digit.
                                          1055  #
                                          1056  # sysArgs[0:1]       (in)    End address
                                          1057  # sysArgs[2:3]       (inout) Start address
                                          1058  # sysArgs[4]         (in)    Base
                                          1059  # vAC                (in)    Carry in high bit
                                          1060  # sysArgs[5]         (used)
                                          1061
                                          1062  label('SYS_DoubleDabble_v7_34')
SYS_DoubleDabble_v7_34:
