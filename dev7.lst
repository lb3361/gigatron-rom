                                          850   #-----------------------------------------------------------------------
                                          851   # Extension SYS_Multiply_s16_v6_66: 16 bit multiplication
                                          852   # Also known as SYS_Multiply_s16_v7_34.
                                          853   #-----------------------------------------------------------------------
                                          854   #
                                          855   # Computes C = C + A * B where A,B,C are 16 bits integers.
                                          856   # Returns product in vAC as well
                                          857   #
                                          858   #       sysArgs[0:1]    Multiplicand A (in)
                                          859   #       sysArgs[2:3]    Multiplicand B (in)
                                          860   #       sysArgs[4:5]    C (inout)
                                          861   #       sysArgs[6:7]    (changed)
                                          862   #
                                          863   # Original design: at67
                                          864   #
                                          865   # The improved dev7rom version is substantially faster.
                                          866   # Alternatively use the new opcode MULW.
                                          867
                                          868   label('SYS_Multiply_s16_v6_66')
                                          869   label('SYS_Multiply_s16_v7_34')
SYS_Multiply_s16_v6_66:
SYS_Multiply_s16_v7_34:
              009e 1413  ld   $13,y       870   ld(hi('sys_Multiply_s16'),Y)    #15 slot 0x9e
              009f e0e6  jmp  y,$e6       871   jmp(Y,'sys_Multiply_s16')       #16
              00a0 0200  nop              872   nop()
                                          873
                                          874   #-----------------------------------------------------------------------
                                          875   # Extension SYS_Divide_s16_v6_80: 15 bit division
                                          876   # Also known as SYS_Divide_u16_v7_34
                                          877   #-----------------------------------------------------------------------
                                          878   #
                                          879   # Computes the Euclidean division of 0<=A<65536 and 0<B<65536.
                                          880   # The s16 component of the name is a misnomer (should be u15).
                                          881   # For 16 bits signed division, additional code must handle the signs
                                          882   # Return the quotient in vAC as well as sysArgs[01]
                                          883   # Return the remainder in sysArgs[45]
                                          884   #
                                          885   #       sysArgs[0:1]    Dividend A (in) Quotient (out)
                                          886   #       sysArgs[2:3]    Divisor B (in)
                                          887   #       sysArgs[4:5]    Remainder (out)
                                          888   #       sysArgs[6:7]    (changed)
                                          889   #
                                          890   # Original design by at67.
                                          891   #
                                          892   # The improced dev7rom version handles unrestricted 16 bits unsigned division
                                          893   # that is 0 <= A,B <= 65535. An external wrapper is still needed for signed
                                          894   # division. Alternatively any of the new opcodes RDIVU or RDIVS.
                                          895
                                          896   label('SYS_Divide_s16_v6_80')
                                          897   label('SYS_Divide_u16_v7_34')
SYS_Divide_s16_v6_80:
SYS_Divide_u16_v7_34:
              00a1 1413  ld   $13,y       898   ld(hi('sys_Divide_u16'),Y)      #15 slot 0xa1
              00a2 e0f0  jmp  y,$f0       899   jmp(Y,'sys_Divide_u16')         #16
              00a3 0200  nop              900   nop()
                                          901
