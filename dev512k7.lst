v6502_jmp1:   0dd1 0200  nop              4607  nop()                           #12
              0dd2 0124  ld   [$24]       4608  ld([v6502_ADL])                 #13
              0dd3 c21a  st   [$1a]       4609  st([v6502_PCL])                 #14
