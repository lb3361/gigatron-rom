                                          6008  # SYS_ResetWaveforms_v4_50 implementation
                                          6009  label('sys_ResetWaveforms')
sys_ResetWaveforms:
              125f 0118  ld   [$18]       6010  ld([vAC+0])                     #18 X=4i
              1260 8200  adda ac          6011  adda(AC)                        #19
              1261 9200  adda ac,x        6012  adda(AC,X)                      #20
              1262 0118  ld   [$18]       6013  ld([vAC+0])                     #21
              1263 de00  st   [y,x++]     6014  st([Y,Xpp])                     #22 Sawtooth: T[4i+0] = i
              1264 2020  anda $20         6015  anda(0x20)                      #23 Triangle: T[4i+1] = 2i if i<32 else 127-2i
              1265 ec68  bne  $1268       6016  bne(pc()+3)                     #24
              1266 0118  ld   [$18]       6017  ld([vAC+0])                     #25
              1267 fc6a  bra  $126a       6018  bra(pc()+3)                     #26
              1268 8118  adda [$18]       6019  adda([vAC+0])                   #26,27
              1269 607f  xora $7f         6020  xora(127)                       #27
              126a de00  st   [y,x++]     6021  st([Y,Xpp])                     #28
              126b 0118  ld   [$18]       6022  ld([vAC+0])                     #29 Pulse: T[4i+2] = 0 if i<32 else 63
              126c 2020  anda $20         6023  anda(0x20)                      #30
              126d ec70  bne  $1270       6024  bne(pc()+3)                     #31
              126e fc71  bra  $1271       6025  bra(pc()+3)                     #32
              126f 0000  ld   $00         6026  ld(0)                           #33
              1270 003f  ld   $3f         6027  ld(63)                          #33(!)
              1271 de00  st   [y,x++]     6028  st([Y,Xpp])                     #34
              1272 0118  ld   [$18]       6029  ld([vAC+0])                     #35 Sawtooth: T[4i+3] = i
              1273 ce00  st   [y,x]       6030  st([Y,X])                       #36
              1274 8001  adda $01         6031  adda(1)                         #37 i += 1
              1275 c218  st   [$18]       6032  st([vAC+0])                     #38
              1276 6040  xora $40         6033  xora(64)                        #39 For 64 iterations
              1277 f07a  beq  $127a       6034  beq(pc()+3)                     #40
              1278 fc7b  bra  $127b       6035  bra(pc()+3)                     #41
              1279 00fe  ld   $fe         6036  ld(-2)                          #42
              127a 0000  ld   $00         6037  ld(0)                           #42(!)
              127b 8116  adda [$16]       6038  adda([vPC])                     #43
              127c c216  st   [$16]       6039  st([vPC])                       #44
              127d 1403  ld   $03,y       6040  ld(hi('REENTER'),Y)             #45
              127e e0cb  jmp  y,$cb       6041  jmp(Y,'REENTER')                #46
              127f 00e7  ld   $e7         6042  ld(-50/2)                       #47
