                                          3667  # Extension SYS_ResetWaveforms_v4_50
                                          3668  #-----------------------------------------------------------------------
                                          3669
                                          3670  # soundTable[4x+0] = sawtooth, to be modified into metallic/noise
                                          3671  # soundTable[4x+1] = pulse
