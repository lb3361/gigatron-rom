                                          1040
                                          1041  #-----------------------------------------------------------------------
                                          1042  # Extension SYS_ScanMemoryExt_v6_50
                                          1043  #-----------------------------------------------------------------------
                                          1044
                                          1045  # SYS function for searching bytes in a different memory bank.
                                          1046  # This function examines bytes starting from address sysArgs[01] with
                                          1047  # the selected bank mapped at addresses 0x8000-0xffff. It stops when
                                          1048  # encountering a byte equal to either sysArgs[2] or sysArgs[3], or
                                          1049  # when vACL bytes have been examined, whichever comes first. It does
                                          1050  # not cross page boudaries but wraps around in page sysArgs[1].
                                          1051  #
                                          1052  # Input:
                                          1053  #   sysArgs[01]        Start address of the string
                                          1054  #   sysArgs[23]        Bytes to search
                                          1055  #   vACL               Length of the string (0 means 256)
                                          1056  #   vACH               Bits 7 and 6 select the bank mapped in 0x8000-0xffff.
                                          1057  #
                                          1058  # If a matching byte is found, its address is returned in vAC and
                                          1059  # sysArgs[01].  Otherwise, zero is returned in vAC and sysArgs[0]
                                          1060  # point right after the string.
