              1218 c217  st   [$17]       5999  st([vPC+1])                     #97
              1219 0002  ld   $02         6000  ld(hi('ENTER'))                 #98 Set vCpuSelect to ENTER (=regular vCPU)
              121a c205  st   [$05]       6001  st([vCpuSelect])                #99
