                                          6106  label('.sysVdb0')
.sysVdb0:     1245 c22f  st   [$2f]       6107  st([vTmp])                      #19+i*12
              1246 9529  adda [$29],y     6108  adda([sysArgs+5],Y)             #20+i*12 Y=[sysPos+1]+[vTmp]
              1247 0126  ld   [$26]       6109  ld([sysArgs+2])                 #21+i*12 Select color
              1248 e854  blt  .sysVdb1    6110  bmi('.sysVdb1')                 #22+i*12
              1249 8200  adda ac          6111  adda(AC)                        #23+i*12
              124a c226  st   [$26]       6112  st([sysArgs+2])                 #24+i*12
              124b 0124  ld   [$24]       6113  ld([sysArgs+0])                 #25+i*12
              124c ce00  st   [y,x]       6114  st([Y,X])                       #26+i*12
              124d 012f  ld   [$2f]       6115  ld([vTmp])                      #27+i*12
              124e a007  suba $07         6116  suba(7)                         #28+i*12
              124f ec45  bne  .sysVdb0    6117  bne('.sysVdb0')                 #29+i*12
              1250 8008  adda $08         6118  adda(8)                         #30+i*12
              1251 1403  ld   $03,y       6119  ld(hi('REENTER'),Y)             #115
              1252 e0cb  jmp  y,$cb       6120  jmp(Y,'REENTER')                #116
              1253 00c4  ld   $c4         6121  ld(-120/2)                      #117
                                          6122  label('.sysVdb1')
.sysVdb1:     1254 c226  st   [$26]       6123  st([sysArgs+2])                 #24+i*12
              1255 0125  ld   [$25]       6124  ld([sysArgs+1])                 #25+i*12
              1256 ce00  st   [y,x]       6125  st([Y,X])                       #26+i*12
              1257 012f  ld   [$2f]       6126  ld([vTmp])                      #27+i*12
              1258 a007  suba $07         6127  suba(7)                         #28+i*12
              1259 ec45  bne  .sysVdb0    6128  bne('.sysVdb0')                 #29+i*12
              125a 8008  adda $08         6129  adda(8)                         #30+i*12
              125b 1403  ld   $03,y       6130  ld(hi('REENTER'),Y)             #115
              125c e0cb  jmp  y,$cb       6131  jmp(Y,'REENTER')                #116
              125d 00c4  ld   $c4         6132  ld(-120/2)                      #117
                                          6133
                                          6134  # SYS_ResetWaveforms_v4_50 implementation
                                          6135  label('sys_ResetWaveforms')
sys_ResetWaveforms:
              125e 0118  ld   [$18]       6136  ld([vAC+0])                     #18 X=4i
              125f 8200  adda ac          6137  adda(AC)                        #19
              1260 9200  adda ac,x        6138  adda(AC,X)                      #20
              1261 0118  ld   [$18]       6139  ld([vAC+0])                     #21
              1262 de00  st   [y,x++]     6140  st([Y,Xpp])                     #22 Sawtooth: T[4i+0] = i
              1263 2020  anda $20         6141  anda(0x20)                      #23 Triangle: T[4i+1] = 2i if i<32 else 127-2i
              1264 ec67  bne  $1267       6142  bne(pc()+3)                     #24
              1265 0118  ld   [$18]       6143  ld([vAC+0])                     #25
              1266 fc69  bra  $1269       6144  bra(pc()+3)                     #26
              1267 8118  adda [$18]       6145  adda([vAC+0])                   #26,27
              1268 607f  xora $7f         6146  xora(127)                       #27
              1269 de00  st   [y,x++]     6147  st([Y,Xpp])                     #28
              126a 0118  ld   [$18]       6148  ld([vAC+0])                     #29 Pulse: T[4i+2] = 0 if i<32 else 63
              126b 2020  anda $20         6149  anda(0x20)                      #30
              126c ec6f  bne  $126f       6150  bne(pc()+3)                     #31
              126d fc70  bra  $1270       6151  bra(pc()+3)                     #32
              126e 0000  ld   $00         6152  ld(0)                           #33
              126f 003f  ld   $3f         6153  ld(63)                          #33(!)
              1270 de00  st   [y,x++]     6154  st([Y,Xpp])                     #34
              1271 0118  ld   [$18]       6155  ld([vAC+0])                     #35 Sawtooth: T[4i+3] = i
              1272 ce00  st   [y,x]       6156  st([Y,X])                       #36
              1273 8001  adda $01         6157  adda(1)                         #37 i += 1
              1274 c218  st   [$18]       6158  st([vAC+0])                     #38
              1275 6040  xora $40         6159  xora(64)                        #39 For 64 iterations
              1276 f079  beq  $1279       6160  beq(pc()+3)                     #40
              1277 fc7a  bra  $127a       6161  bra(pc()+3)                     #41
              1278 00fe  ld   $fe         6162  ld(-2)                          #42
              1279 0000  ld   $00         6163  ld(0)                           #42(!)
              127a 8116  adda [$16]       6164  adda([vPC])                     #43
              127b c216  st   [$16]       6165  st([vPC])                       #44
              127c 1403  ld   $03,y       6166  ld(hi('REENTER'),Y)             #45
              127d e0cb  jmp  y,$cb       6167  jmp(Y,'REENTER')                #46
              127e 00e7  ld   $e7         6168  ld(-50/2)                       #47
