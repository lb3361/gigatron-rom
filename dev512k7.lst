                                          761
                                          762
                                          763   #-----------------------------------------------------------------------
                                          764   # Placeholders for future SYS functions. This works as a kind of jump
                                          765   # table. The indirection allows SYS implementations to be moved around
                                          766   # between ROM versions, at the expense of 2 clock cycles (or 1). When
                                          767   # the function is not present it just acts as a NOP. Of course, when a
                                          768   # SYS function must be patched or extended it needs to have budget for
                                          769   # that in its declared maximum cycle count.
                                          770   #
                                          771   # Technically the same goal can be achieved by starting each function
                                          772   # with 2 nop's, or by overdeclaring their duration in the first place
                                          773   # (a bit is still wise to do). But this can result in fragmentation
                                          774   # of future ROM images. The indirection avoids that.
                                          775   #
                                          776   # An added advantage of having these in ROM page 0 is that it saves one
                                          777   # byte when setting sysFn: LDI+STW (4 bytes) instead of LDWI+STW (5 bytes)
                                          778   #-----------------------------------------------------------------------
                                          779
              007e 0200  nop              780   align(0x80, size=0x80)
              007f 0200  nop
                                          781   assert pc() == 0x80
                                          782
              0080 1403  ld   $03,y       783   ld(hi('REENTER'),Y)             #15 slot 0x80
              0081 e0cb  jmp  y,$cb       784   jmp(Y,'REENTER')                #16
              0082 00f6  ld   $f6         785   ld(-20/2)                       #17
                                          786
              0083 1403  ld   $03,y       787   ld(hi('REENTER'),Y)             #15 slot 0x83
              0084 e0cb  jmp  y,$cb       788   jmp(Y,'REENTER')                #16
              0085 00f6  ld   $f6         789   ld(-20/2)                       #17
                                          790
              0086 1403  ld   $03,y       791   ld(hi('REENTER'),Y)             #15 slot 0x86
              0087 e0cb  jmp  y,$cb       792   jmp(Y,'REENTER')                #16
              0088 00f6  ld   $f6         793   ld(-20/2)                       #17
                                          794
              0089 1403  ld   $03,y       795   ld(hi('REENTER'),Y)             #15 slot 0x89
              008a e0cb  jmp  y,$cb       796   jmp(Y,'REENTER')                #16
              008b 00f6  ld   $f6         797   ld(-20/2)                       #17
                                          798
              008c 1403  ld   $03,y       799   ld(hi('REENTER'),Y)             #15 slot 0x8c
              008d e0cb  jmp  y,$cb       800   jmp(Y,'REENTER')                #16
              008e 00f6  ld   $f6         801   ld(-20/2)                       #17
                                          802
              008f 1403  ld   $03,y       803   ld(hi('REENTER'),Y)             #15 slot 0x8f
              0090 e0cb  jmp  y,$cb       804   jmp(Y,'REENTER')                #16
              0091 00f6  ld   $f6         805   ld(-20/2)                       #17
                                          806
              0092 1403  ld   $03,y       807   ld(hi('REENTER'),Y)             #15 slot 0x92
              0093 e0cb  jmp  y,$cb       808   jmp(Y,'REENTER')                #16
              0094 00f6  ld   $f6         809   ld(-20/2)                       #17
                                          810
              0095 1403  ld   $03,y       811   ld(hi('REENTER'),Y)             #15 slot 0x95
              0096 e0cb  jmp  y,$cb       812   jmp(Y,'REENTER')                #16
