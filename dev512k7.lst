fsmST+#8:     15ee c22b  st   [$2b]       7096  st([fsmState])                  #8
              15ef 1527  ld   [$27],y     7097  ld([sysArgs+3],Y)               #9
              15f0 1126  ld   [$26],x     7098  ld([sysArgs+2],X)               #10
              15f1 0118  ld   [$18]       7099  ld([vAC])                       #11
              15f2 ce00  st   [y,x]       7100  st([Y,X])                       #12
              15f3 0126  ld   [$26]       7101  ld([sysArgs+2])                 #13
              15f4 8001  adda $01         7102  adda(1)                         #14
              15f5 c226  st   [$26]       7103  st([sysArgs+2])                 #15
              15f6 0128  ld   [$28]       7104  ld([sysArgs+4])                 #16
              15f7 a001  suba $01         7105  suba(1)                         #17
              15f8 c228  st   [$28]       7106  st([sysArgs+4])                 #18
