se:loadGt1z:  1688 fc0a  bra  fsm16:ST    7325  fsmAsm('ST', sysArgs+3)
              1689 0027  ld   $27
              168a fc28  bra  fsm16:LUP   7326  fsmAsm('LUP')                   # lo segment address
              168b 008c  ld   $8c
              168c fc0a  bra  fsm16:ST    7327  fsmAsm('ST', sysArgs+2)
              168d 0026  ld   $26
              168e fc0a  bra  fsm16:ST    7328  fsmAsm('ST', sysArgs+5)
              168f 0029  ld   $29
                                          7329  label('se:loadGt1z:token')
se:loadGt1z:token:
              1690 fc28  bra  fsm16:LUP   7330  fsmAsm('LUP')                   # read token
              1691 0092  ld   $92
              1692 fc0a  bra  fsm16:ST    7331  fsmAsm('ST', vAC+1)             # stash
              1693 0019  ld   $19
              1694 fc11  bra  fsm16:AND   7332  fsmAsm('AND', 0x70)             # mask nLit
              1695 0070  ld   $70
              1696 fc1a  bra  fsm16:BZ    7333  fsmAsm('BZ', 'se:loadGt1z:mcnt')
              1697 00a6  ld   $a6
              1698 fc14  bra  fsm16:LSR4  7334  fsmAsm('LSR4')
              1699 009a  ld   $9a
              169a fc0a  bra  fsm16:ST    7335  fsmAsm('ST', sysArgs+4)
              169b 0028  ld   $28
              169c fc0e  bra  fsm16:ADD   7336  fsmAsm('ADD', 0xf9)             # is 7?
              169d 00f9  ld   $f9
              169e fc17  bra  fsm16:BNZ   7337  fsmAsm('BNZ', 'se:loadGt1z:lit')
              169f 00a4  ld   $a4
              16a0 fc28  bra  fsm16:LUP   7338  fsmAsm('LUP')                   # extension byte for nlit
              16a1 00a2  ld   $a2
              16a2 fc0a  bra  fsm16:ST    7339  fsmAsm('ST', sysArgs+4)
              16a3 0028  ld   $28
                                          7340  label('se:loadGt1z:lit')
se:loadGt1z:lit:
              16a4 fc1d  bra  fsm16:BL    7341  fsmAsm('BL', 'se:copyLiteral')
