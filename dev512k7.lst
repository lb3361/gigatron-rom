                                          3596  #-----------------------------------------------------------------------
                                          3597  # Extension SYS_SetMode_v2_80
                                          3598  #-----------------------------------------------------------------------
                                          3599
                                          3600  # Set video mode to 0 to 3 black scanlines per pixel line.
                                          3601  #
                                          3602  # Mainly for making the MODE command available in Tiny BASIC, so that
                                          3603  # the user can experiment. It's adviced to refrain from using
                                          3604  # SYS_SetMode_v2_80 in regular applications. Video mode is a deeply
                                          3605  # personal preference, and the programmer shouldn't overrule the user
                                          3606  # in that choice. The Gigatron philisophy is that the end user has
                                          3607  # the final say on what happens on the system, not the application,
                                          3608  # even if that implies a degraded performance. This doesn't mean that
                                          3609  # all applications must work well in all video modes: mode 1 is still
                                          3610  # the default. If an application really doesn't work at all in that
                                          3611  # mode, it's acceptable to change mode once after loading.
                                          3612  #
                                          3613  # There's no "SYS_GetMode" function.
                                          3614  #
                                          3615  # Variables:
                                          3616  #       vAC bit 0:1     Mode:
                                          3617  #                         0      "ABCD" -> Full mode (slowest)
                                          3618  #                         1      "ABC-" -> Default mode after reset
                                          3619  #                         2      "A-C-" -> at67's mode
                                          3620  #                         3      "A---" -> HGM's mode
                                          3621  #       vAC bit 2:15    Ignored bits and should be 0
                                          3622  #
                                          3623  # Special values (ROM v4):
                                          3624  #       vAC = 1975      Zombie mode (no video signals, no input,
                                          3625  #                        no blinkenlights).
                                          3626  #       vAC = -1        Leave zombie mode and restore previous mode.
                                          3627
                                          3628  # Actual duration is <80 cycles, but keep some room for future extensions
                                          3629  label('SYS_SetMode_v2_80')
SYS_SetMode_v2_80:
              0b00 140b  ld   $0b,y       3630  ld(hi('sys_SetMode'),Y)         #15
              0b01 e05d  jmp  y,$5d       3631  jmp(Y,'sys_SetMode')            #16
              0b02 011e  ld   [$1e]       3632  ld([vReturn])                   #17
                                          3633
                                          3634  #-----------------------------------------------------------------------
                                          3635  # Extension SYS_SetMemory_v2_54
                                          3636  #-----------------------------------------------------------------------
                                          3637
                                          3638  # SYS function for setting 1..256 bytes
                                          3639  #
                                          3640  # sysArgs[0]   Copy count (in, changed)
                                          3641  # sysArgs[1]   Copy value (in)
                                          3642  # sysArgs[2:3] Destination address (in, changed)
                                          3643  #
                                          3644  # Sets up to 8 bytes per invocation before restarting itself through vCPU.
                                          3645  # Doesn't wrap around page boundary. Can run 3 times per 148-cycle time slice.
                                          3646  # All combined that gives a 300% speedup over ROMv4 and before.
                                          3647
                                          3648  label('SYS_SetMemory_v2_54')
SYS_SetMemory_v2_54:
              0b03 0124  ld   [$24]       3649  ld([sysArgs+0])                 #15
                                          3650  bra('sys_SetMemory#18')         #16
              0b04 fc1a  bra  sys_SetMemory#18
              0b05 1126  ld   [$26],x     3651  ld([sysArgs+2],X)               #17
                                          3652
                                          3653  #-----------------------------------------------------------------------
                                          3654  # Extension SYS_SendSerial1_v3_80
                                          3655  #-----------------------------------------------------------------------
                                          3656
                                          3657  # SYS function for sending data over serial controller port using
                                          3658  # pulse width modulation of the vertical sync signal.
                                          3659  #
                                          3660  # Variables:
                                          3661  #       sysArgs[0:1]    Source address               (in, changed)
                                          3662  #       sysArgs[2]      Start bit mask (typically 1) (in, changed)
                                          3663  #       sysArgs[3]      Number of send frames X      (in, changed)
                                          3664  #
                                          3665  # The sending will abort if input data is detected on the serial port.
                                          3666  # Returns 0 in case of all bits sent, or <>0 in case of abort
                                          3667  #
                                          3668  # This modulates the next upcoming X vertical pulses with the supplied
                                          3669  # data. A zero becomes a 7 line vPulse, a one will be 9 lines.
                                          3670  # After that, the vPulse width falls back to 8 lines (idle).
                                          3671
                                          3672  label('SYS_SendSerial1_v3_80')
SYS_SendSerial1_v3_80:
              0b06 0109  ld   [$09]       3673  ld([videoY])                    #15
                                          3674  bra('sys_SendSerial1')          #16
              0b07 fc8c  bra  sys_SendSerial1
              0b08 60b3  xora $b3         3675  xora(videoYline0)               #17 First line of vertical blank
                                          3676
                                          3677  #-----------------------------------------------------------------------
                                          3678  # Extension SYS_ExpanderControl_v4_40
                                          3679  #-----------------------------------------------------------------------
                                          3680
                                          3681  # Sets the I/O and RAM expander's control register
                                          3682  #
                                          3683  # Variables:
                                          3684  #       vAC bit 2       Device enable /SS0
                                          3685  #           bit 3       Device enable /SS1
                                          3686  #           bit 4       Device enable /SS2
                                          3687  #           bit 5       Device enable /SS3
                                          3688  #           bit 6       Banking B0
                                          3689  #           bit 7       Banking B1
                                          3690  #           bit 15      Data out MOSI
                                          3691  #       sysArgs[7]      Cache for control state (written to)
                                          3692  #
                                          3693  # Intended for prototyping, and probably too low-level for most applications
                                          3694  # Still there's a safeguard: it's not possible to disable RAM using this
                                          3695
                                          3696  label('SYS_ExpanderControl_v4_40')
SYS_ExpanderControl_v4_40:
              0b09 140d  ld   $0d,y       3697  ld(hi('sys_ExpanderControl'),Y) #15
              0b0a e000  jmp  y,$00       3698  jmp(Y,'sys_ExpanderControl')    #16
              0b0b 000c  ld   $0c         3699  ld(0b00001100)                  #17
                                          3700  #    ^^^^^^^^
                                          3701  #    |||||||`-- SCLK
                                          3702  #    ||||||`--- Not connected
                                          3703  #    |||||`---- /SS0
                                          3704  #    ||||`----- /SS1
                                          3705  #    |||`------ /SS2 or /CPOL
                                          3706  #    ||`------- /SS3 or /ZPBANK
                                          3707  #    |`-------- B0
                                          3708  #    `--------- B1
                                          3709
                                          3710  #-----------------------------------------------------------------------
                                          3711  # Extension SYS_Run6502_v4_80
                                          3712  #-----------------------------------------------------------------------
                                          3713
                                          3714  # Transfer control to v6502
                                          3715  #
                                          3716  # Calling 6502 code from vCPU goes (only) through this SYS function.
                                          3717  # Directly modifying the vCpuSelect variable is unreliable. The
                                          3718  # control transfer is immediate, without waiting for the current
                                          3719  # time slice to end or first returning to vCPU.
                                          3720  #
                                          3721  # vCPU code and v6502 code can interoperate without much hassle:
                                          3722  # - The v6502 program counter is vLR, and v6502 doesn't touch vPC
                                          3723  # - Returning to vCPU is with the BRK instruction
                                          3724  # - BRK doesn't dump process state on the stack
                                          3725  # - vCPU can save/restore the vLR with PUSH/POP
                                          3726  # - Stacks are shared, vAC is shared
                                          3727  # - vAC can indicate what the v6502 code wants. vAC+1 will be cleared
                                          3728  # - Alternative is to leave a word in sysArgs[6:7] (v6502 X and Y registers)
                                          3729  # - Another way is to set vPC before BRK, and vCPU will continue there(+2)
                                          3730  #
                                          3731  # Calling v6502 code from vCPU looks like this:
                                          3732  #       LDWI  SYS_Run6502_v4_80
                                          3733  #       STW   sysFn
                                          3734  #       LDWI  $6502_start_address
                                          3735  #       STW   vLR
                                          3736  #       SYS   80
                                          3737  #
                                          3738  # Variables:
                                          3739  #       vAC             Accumulator
                                          3740  #       vLR             Program Counter
                                          3741  #       vSP             Stack Pointer (+1)
                                          3742  #       sysArgs[6]      Index Register X
                                          3743  #       sysArgs[7]      Index Register Y
                                          3744  # For info:
                                          3745  #       sysArgs[0:1]    Address Register, free to clobber
                                          3746  #       sysArgs[2]      Instruction Register, free to clobber
                                          3747  #       sysArgs[3:5]    Flags, don't touch
                                          3748  #
                                          3749  # Implementation details::
                                          3750  #
                                          3751  #  The time to reserve for this transition is the maximum time
                                          3752  #  between NEXT and v6502_check. This is
                                          3753  #       SYS call duration + 2*v6502_maxTicks + (v6502_overhead - vCPU_overhead)
                                          3754  #     = 22 + 28 + (11 - 9) = 62 cycles.
                                          3755  #  So reserving 80 cycles is future proof. This isn't overhead, as it includes
                                          3756  #  the fetching of the first 6502 opcode and its operands..
                                          3757  #
                                          3758  #                      0            10                 28=0         9
                                          3759  #    ---+----+---------+------------+------------------+-----------+---
                                          3760  # video | nop| runVcpu |   ENTER    | At least one ins |   EXIT    | video
                                          3761  #    ---+----+---------+------------+------------------+-----------+---
                                          3762  #        sync  prelude  ENTER-to-ins    ins-to-NEXT     NEXT-to-video
                                          3763  #       |<-->|
                                          3764  #        0/1 |<------->|
                                          3765  #                 5    |<----------------------------->|
                                          3766  #          runVCpu_overhead           28               |<--------->|
                                          3767  #                                 2*maxTicks                 9
                                          3768  #                                                      vCPU_overhead
                                          3769  #
                                          3770  #                      0                21                    38=0       11
                                          3771  #    ---+----+---------+----------------+--------------------+-----------+---
                                          3772  # video | nop| runVcpu |   v6502_ENTER  | At least one fetch |v6502_exitB| video
                                          3773  #    ---+----+---------+----------------+--------------------+-----------+---
                                          3774  #        sync  prelude   enter-to-fetch     fetch-to-check    check-to-video
                                          3775  #       |<-->|
                                          3776  #        0/1 |<------->|
                                          3777  #                 5    |<----------------------------------->|
                                          3778  #          runVcpu_overhead           38                     |<--------->|
                                          3779  #                              2*v6520_maxTicks                    11
                                          3780  #                                                            v6502_overhead
                                          3781
                                          3782  label('SYS_Run6502_v4_80')
SYS_Run6502_v4_80:
              0b0c 140d  ld   $0d,y       3783  ld(hi('sys_v6502'),Y)           #15
              0b0d e08f  jmp  y,$8f       3784  jmp(Y,'sys_v6502')              #16
              0b0e 000d  ld   $0d         3785  ld(hi('v6502_ENTER'))           #17 Activate v6502
                                          3786
