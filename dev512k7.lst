                                          1019  #-----------------------------------------------------------------------
                                          1020  # Extension SYS_DoubleDabble_v7_34
                                          1021  #-----------------------------------------------------------------------
                                          1022
                                          1023  # SYS function to help converting integers into ascii in any base.
                                          1024  # The string of bytes [sysArgs[2:3]...sysArgs[0:1]-1] represents
                                          1025  # a number in base sysArgs[4]. Calling the SYS function doubles
                                          1026  # this number and adds 1 if vAC<=0 (msb set). If necessary
                                          1027  # sysArgs[2:3] is decremented to make space for a new digit.
                                          1028  #
                                          1029  # sysArgs[0:1]       (in)    End address
                                          1030  # sysArgs[2:3]       (inout) Start address
                                          1031  # sysArgs[4]         (in)    Base
                                          1032  # vAC                (in)    Carry in high bit
                                          1033  # sysArgs[5]         (used)
                                          1034
                                          1035  label('SYS_DoubleDabble_v7_34')
SYS_DoubleDabble_v7_34:
              00e0 1420  ld   $20,y       1036  ld(hi('sys_DoubleDabble'),Y)    #15 slot 0xe0
              00e1 e044  jmp  y,$44       1037  jmp(Y,'sys_DoubleDabble')       #16
              00e2 0119  ld   [$19]       1038  ld([vAC+1])                     #17
