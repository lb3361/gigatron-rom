                                          6836  label(fsmLab('B'))
fsm15:B:      1517 c22b  st   [$2b]       6837  st([fsmState])                  #5
              1518 fc01  bra  FSM15_NEXT  6838  bra('NEXT')                     #6
              1519 00fc  ld   $fc         6839  ld(-8/2)                        #7
