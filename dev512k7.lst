                                          2560  # Instruction MOVW (bb dd ss), 36 cycles
                                          2561  # * Move word [ss..ss+1] to [dd..dd+1].
                                          2562  # * Trashes sysArgs7
                                          2563  label('MOVW_v7')
MOVW_v7:      03bb c22b  st   [$2b]       2564  st([sysArgs+7])                 #10 destination operand
              03bc de00  st   [y,x++]     2565  st([Y,Xpp])                     #11
              03bd 0d00  ld   [y,x]       2566  ld([Y,X])                       #12 source operand
              03be 1420  ld   $20,y       2567  ld(hi('movw#16'),Y)             #13
              03bf e06c  jmp  y,$6c       2568  jmp(Y,'movw#16')                #14
              03c0 9001  adda $01,x       2569  adda(1,X)                       #15
                                          2570
                                          2571  # Continue LD/ANDI/INC
                                          2572  label('ld#13')
ld#13:        03c1 c218  st   [$18]       2573  st([vAC])                       #13 LD,ANDI
              03c2 0000  ld   $00         2574  ld(0)                           #14
              03c3 c219  st   [$19]       2575  st([vAC+1])                     #15
                                          2576  label('ld#16')
ld#16:        03c4 fc01  bra  NEXT        2577  bra('NEXT')                     #16 INC
              03c5 00f7  ld   $f7         2578  ld(-18/2)                       #17
