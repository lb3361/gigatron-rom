                                          2836
                                          2837  #-----------------------------------------------------------------------
                                          2838  #
                                          2839  #  vCPU extension functions (for acceleration and compaction) follow below.
                                          2840  #
                                          2841  #  The naming convention is: SYS_<CamelCase>[_v<V>]_<N>
                                          2842  #
                                          2843  #  With <N> the maximum number of cycles the function will run
                                          2844  #  (counted from NEXT to NEXT). This is the same number that must
                                          2845  #  be passed to the 'SYS' vCPU instruction as operand, and it will
                                          2846  #  appear in the GCL code upon use.
                                          2847  #
                                          2848  #  If a SYS extension got introduced after ROM v1, the version number of
                                          2849  #  introduction is included in the name. This helps the programmer to be
                                          2850  #  reminded to verify the acutal ROM version and fail gracefully on older
                                          2851  #  ROMs than required. See also Docs/GT1-files.txt on using [romType].
                                          2852  #
                                          2853  #-----------------------------------------------------------------------
                                          2854
              04a4 0200  nop              2855  fillers(until=0xa7)
              04a5 0200  nop
              04a6 0200  nop
                                          2856
                                          2857  #-----------------------------------------------------------------------
                                          2858  # Extension SYS_Random_34: Update entropy and copy to vAC
                                          2859  #-----------------------------------------------------------------------
                                          2860
                                          2861  # This same algorithm runs automatically once per vertical blank.
                                          2862  # Use this function to get numbers at a higher rate.
                                          2863  #
                                          2864  # Variables:
                                          2865  #       vAC
                                          2866
                                          2867  label('SYS_Random_34')
SYS_Random_34:
              04a7 0115  ld   [$15]       2868  ld([vTicks])                    #15
              04a8 6107  xora [$07]       2869  xora([entropy+1])               #16
              04a9 1401  ld   $01,y       2870  ld(1,Y)                         #17
              04aa 8106  adda [$06]       2871  adda([entropy+0])               #18
              04ab c206  st   [$06]       2872  st([entropy+0])                 #19
              04ac c218  st   [$18]       2873  st([vAC+0])                     #20
                                          2874  if WITH_128K_BOARD:
                                          2875    adda([Y,entropy2])            #21
                                          2876    st([Y,entropy2])              #22
                                          2877  else:
              04ad 8108  adda [$08]       2878    adda([entropy+2])             #21
              04ae c208  st   [$08]       2879    st([entropy+2])               #22
              04af e8b2  blt  .sysRnd0    2880  bmi('.sysRnd0')                 #23
              04b0 fcb3  bra  .sysRnd1    2881  bra('.sysRnd1')                 #24
              04b1 6053  xora $53         2882  xora(64+16+2+1)                 #25
                                          2883  label('.sysRnd0')
.sysRnd0:     04b2 606c  xora $6c         2884  xora(64+32+8+4)                 #25
                                          2885  label('.sysRnd1')
.sysRnd1:     04b3 8107  adda [$07]       2886  adda([entropy+1])               #26
              04b4 c207  st   [$07]       2887  st([entropy+1])                 #27
              04b5 c219  st   [$19]       2888  st([vAC+1])                     #28
              04b6 1403  ld   $03,y       2889  ld(hi('REENTER'),Y)             #29
              04b7 e0cb  jmp  y,$cb       2890  jmp(Y,'REENTER')                #30
              04b8 00ef  ld   $ef         2891  ld(-34/2)                       #31
