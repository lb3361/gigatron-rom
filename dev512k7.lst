                                          3561  for i in range(0, 250, 2):
                                          3562    j = i//2-1
                                          3563    freq = 440.0*2.0**((j-57)/12.0)
                                          3564    if j>=0 and freq <= sampleRate/2.0:
                                          3565      key = int(round(32768 * freq / sampleRate))
                                          3566      octave, note = j//12, notes[j%12]
                                          3567      sharp = '-' if notes[j%12-1] != note else '#'
                                          3568      comment = '%s%s%s (%0.1f Hz)' % (note, sharp, octave, freq)
                                          3569      ld(key&127); C(comment); ld(key>>7)
