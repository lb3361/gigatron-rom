                                          2554  # * Subtract [vv] from vAC (AC-=[vv]+256*[vv+1])
                                          2555  label('SUBW')
SUBW:         03b8 1420  ld   $20,y       2556  ld(hi('subw#13'),Y)             #10,14
              03b9 e052  jmp  y,$52       2557  jmp(Y,'subw#13')                #11
              03ba 1403  ld   $03,y       2558  ld(hi('NEXTY'),Y)               #12
