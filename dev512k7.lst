                                          918   #-----------------------------------------------------------------------
                                          919   # Extension SYS_Exec_88: Load code from ROM into memory and execute it
                                          920   #-----------------------------------------------------------------------
                                          921   #
                                          922   # This loads the vCPU code with consideration of the current vSP
                                          923   # Used during reset, but also for switching between applications or for
                                          924   # loading data from ROM from within an application (overlays).
                                          925   #
                                          926   # ROM stream format is
                                          927   #  [<addrH> <addrL> <n&255> n*<byte>]* 0 [<execH> <execL>]
                                          928   # on top of lookup tables.
                                          929   #
                                          930   #       sysArgs[0:1]    ROM pointer (in)
                                          931   #       sysArgs[2:3]    RAM pointer (changed) Execution address (out)
                                          932   #       sysArgs[4]      Byte counter (changed)
                                          933   #       sysArgs[7]      FSM state (changed)
                                          934   #       vLR==0          vCPU continues at GT1 execution address (in)
                                          935   #       vLR!=0          vCPU continues at vLR (in)
                                          936
                                          937   label('SYS_Exec_88')
SYS_Exec_88:  00ad 1420  ld   $20,y       938   ld(hi('sys_Exec'),Y)            #15
              00ae e009  jmp  y,$09       939   jmp(Y,'sys_Exec')               #16
              00af 0200  nop              940   nop()                           #17
                                          941
                                          942   #-----------------------------------------------------------------------
                                          943   # Extension SYS_Loader_DEVROM_44: Load code from serial input and execute
                                          944   #-----------------------------------------------------------------------
                                          945   #
                                          946   # This loads vCPU code and data presented on the serial port according
                                          947   # to the loader protocol then jumps to the avertised execution
                                          948   # address. This call never returns.
                                          949   #
                                          950   # Set sysArgs[0] to 0xc to enable visual feedback in the pixel
                                          951   # row located in page sysArgs[1]. This is automatically
                                          952   # disabled if bytes are loaded in the feedback area.
                                          953   #
                                          954   #       sysArgs[0]      Zero to disable echo (0x00 or ox0c) (in)
                                          955   #       sysArgs[1]      Echo row (0x59) (in)
                                          956   #
                                          957   # Credits: The first native loader was written for ROMvX0 by at67.
                                          958   #
                                          959   # Loader protocol
                                          960   # ---------------
                                          961   # The data is divided into chunks of at most 60 bytes to be loaded at
                                          962   # contiguous addresses inside a same gigatron memory page. Each chunk
                                          963   # is transmitted over the serial port (IN) synchronously with the
                                          964   # video signal, one chunk per frame. Each byte of the chunk must be
                                          965   # read from the IN port when videoY takes specific values:
                                          966   #
                                          967   #  videoY    Data
                                          968   #   207      protocol signature: 'L'
                                          969   #   219      chunk length (low 6 bits) or zero to execute.
                                          970   #   235      chunk address (l) or execution address (l) if len=0
                                          971   #   251      chunk address (h) or execution address (h)  if len=0
                                          972   #   2        chunk byte 0
                                          973   #   6        chunk byte 1
                                          974   #  ....
                                          975   #   2+4*k    chunk byte k
                                          976
              00b0 1415  ld   $15,y       977   ld(hi('sys_Loader'),Y)          #15 slot 0xb0
              00b1 e09b  jmp  y,$9b       978   jmp(Y,'sys_Loader')             #16
              00b2 0124  ld   [$24]       979   ld([sysArgs+0])                 #17
                                          980
                                          981   #-----------------------------------------------------------------------
                                          982   # More placeholders for future SYS functions
                                          983   #-----------------------------------------------------------------------
                                          984
              00b3 1403  ld   $03,y       985   ld(hi('REENTER'),Y)             #15 slot 0xb3
              00b4 e0cb  jmp  y,$cb       986   jmp(Y,'REENTER')                #16
              00b5 00f6  ld   $f6         987   ld(-20/2)                       #17
                                          988
              00b6 1403  ld   $03,y       989   ld(hi('REENTER'),Y)             #15 slot 0xb6
              00b7 e0cb  jmp  y,$cb       990   jmp(Y,'REENTER')                #16
              00b8 00f6  ld   $f6         991   ld(-20/2)                       #17
                                          992
              00b9 1403  ld   $03,y       993   ld(hi('REENTER'),Y)             #15 slot 0xb9
              00ba e0cb  jmp  y,$cb       994   jmp(Y,'REENTER')                #16
              00bb 00f6  ld   $f6         995   ld(-20/2)                       #17
