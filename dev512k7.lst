              15e4 f0e7  beq  $15e7       7084  beq(pc()+3)                     #17
              15e5 fce8  bra  $15e8       7085  bra(pc()+3)                     #18
              15e6 00ff  ld   $ff         7086  ld(0xff)                        #19
              15e7 00fc  ld   $fc         7087  ld(0xfc)                        #19!
              15e8 2121  anda [$21]       7088  anda([channelMask])             #20
              15e9 c221  st   [$21]       7089  st([channelMask])               #21
              15ea 0105  ld   [$05]       7090  ld([vCpuSelect])                #22
              15eb 9401  adda $01,y       7091  adda(1,Y)                       #23
              15ec e001  jmp  y,$01       7092  jmp(Y,'NEXT')                   #24
              15ed 00f3  ld   $f3         7093  ld(-26/2)                       #25
