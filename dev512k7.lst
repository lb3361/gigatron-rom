                                          1585    # with the video loop entry point at 0x1ff
              01ef 0200  nop              1586    fillers(until=0xf3)
              01f0 0200  nop
              01f1 0200  nop
              01f2 0200  nop
                                          1587    label('vBlankEnd#189')
vBlankEnd#189:
              01f3 1401  ld   $01,y       1588    ld(videoTop_v5>>8,Y)          #189
              01f4 09f9  ld   [y,$f9]     1589    ld([Y,videoTop_v5])           #190
              01f5 c209  st   [$09]       1590    st([videoY])                  #191
              01f6 c21f  st   [$1f]       1591    st([frameX])                  #192
              01f7 ecfa  bne  $01fa       1592    bne(pc()+3)                   #193
              01f8 fcfb  bra  $01fb       1593    bra(pc()+3)                   #194
              01f9 001d  ld   $1d         1594    ld('videoA')                  #195
              01fa 007d  ld   $7d         1595    ld('videoF')                  #195(!)
              01fb c20d  st   [$0d]       1596    st([nextVideo])               #196
              01fc 0102  ld   [$02]       1597    ld([channel])                 #197 Normalize channel for robustness
              01fd 2003  anda $03         1598    anda(0b00000011)              #198
              01fe c202  st   [$02]       1599    st([channel])                 #199
                                          1600
                                          1601  else: # WITH_128K_BOARD
                                          1602
                                          1603    runVcpu(188-80,               #80
                                          1604            '---D line 40 select',
                                          1605            returnTo='vBlankEnd#188')
