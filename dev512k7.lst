                                          7114  #-----------------------------------------------------------------------
                                          7115  #
                                          7116  #   $1600 ROM page 22: SYS_Exec FSM with compressed GT1 support
                                          7117  #
                                          7118  #-----------------------------------------------------------------------
                                          7119
                                          7120
              15fe 0200  nop              7121  fillers(until=0xff)
                                          7122  label('FSM16_ENTER')
FSM16_ENTER:  15ff fc03  bra  $1603       7123  bra(pc()+4)                     #0
                                          7124  align(0x100, size=0x100)
              1600 fd2b  bra  [$2b]       7125  bra([fsmState])                 #1
                                          7126  assert (pc() & 255) == (symbol('NEXT') & 255)
                                          7127  label('FSM16_NEXT')
FSM16_NEXT:   1601 8115  adda [$15]       7128  adda([vTicks])                  #0
              1602 f52b  bge  [$2b]       7129  bge([fsmState],warn=False)      #1
              1603 c215  st   [$15]       7130  st([vTicks])                    #2
              1604 800f  adda $0f         7131  adda(maxTicks)                  #3
              1605 e405  bgt  $1605       7132  bgt(pc()&255)                   #4
              1606 a001  suba $01         7133  suba(1)                         #5
              1607 1401  ld   $01,y       7134  ld(hi('vBlankStart'),Y)         #6
              1608 e11e  jmp  y,[$1e]     7135  jmp(Y,[vReturn])                #7
              1609 0102  ld   [$02]       7136  ld([channel])                   #8
                                          7137
                                          7138  # Ensure labels defined here do not conflict
                                          7139  def fsmLab(n):
                                          7140      return f'fsm16:{n}'
                                          7141
                                          7142  # Assemble u-opcode
                                          7143  def fsmAsm(op,arg=None):
                                          7144      bra(fsmLab(op))
                                          7145      ld(pc()+1) if arg is None else ld(arg)
                                          7146
                                          7147  # Usage fsmAsm('ST', arg)
                                          7148  # - [arg] := vACL
                                          7149  label(fsmLab('ST'))
fsm16:ST:     160a 1415  ld   $15,y       7150  ld(hi('fsmST#8'),Y)             #5
              160b e0a8  jmp  y,$a8       7151  jmp(Y,'fsmST#8')                #6 + overlap
                                          7152
                                          7153  # Usage fsmAsm('LD', arg)
                                          7154  # - vACL = arg with arg=d or arg=[d]
                                          7155  label(fsmLab('LD'))
fsm16:LD:     160c 1415  ld   $15,y       7156  ld(hi('fsmOP#8'),Y)             #5
              160d e0b2  jmp  y,$b2       7157  jmp(Y,'fsmOP#8')                #6 + overlap
                                          7158
                                          7159  # Usage fsmAsm('ADD', arg)
                                          7160  # - vACL += arg with arg=d or arg=[d]
                                          7161  label(fsmLab('ADD'))
fsm16:ADD:    160e 1415  ld   $15,y       7162  ld(hi('fsmOP#8'),Y)             #5,7
              160f e0b2  jmp  y,$b2       7163  jmp(Y,'fsmOP#8')                #6
              1610 8118  adda [$18]       7164  adda([vAC])                     #7
                                          7165
                                          7166  # Usage fsmAsm('AND', arg)
                                          7167  # - vACL &= arg with arg=d or arg=[d]
                                          7168  label(fsmLab('AND'))
fsm16:AND:    1611 1415  ld   $15,y       7169  ld(hi('fsmOP#8'),Y)             #5,7
              1612 e0b2  jmp  y,$b2       7170  jmp(Y,'fsmOP#8')                #6
              1613 2118  anda [$18]       7171  anda([vAC])                     #7
                                          7172
                                          7173  # Usage fsmAsm('LSR4')
                                          7174  # - right shift vACL by 4 positions (high nibble)
                                          7175  label(fsmLab('LSR4'))
fsm16:LSR4:   1614 1415  ld   $15,y       7176  ld(hi('fsmLSR4#8'),Y)           #5
              1615 e0b5  jmp  y,$b5       7177  jmp(Y,'fsmLSR4#8')              #6
              1616 c22b  st   [$2b]       7178  st([fsmState])                  #7
                                          7179
                                          7180  # Usage fsmAsm('BNZ', arg)
                                          7181  # - branch if [vACL] is nonzero
                                          7182  label(fsmLab('BNZ'))
fsm16:BNZ:    1617 1415  ld   $15,y       7183  ld(hi('fsmBNZ#8'),Y)            #5,7
              1618 e0bd  jmp  y,$bd       7184  jmp(Y,'fsmBNZ#8')               #6
              1619 c22f  st   [$2f]       7185  st([vTmp])                      #7
                                          7186
                                          7187  # Usage fsmAsm('BZ', arg)
                                          7188  # - branch if [vACL] is zero
                                          7189  label(fsmLab('BZ'))
fsm16:BZ:     161a 1415  ld   $15,y       7190  ld(hi('fsmBZ#8'),Y)             #5
              161b e0c2  jmp  y,$c2       7191  jmp(Y,'fsmBZ#8')                #6
              161c c22f  st   [$2f]       7192  st([vTmp])                      #7
                                          7193
                                          7194  # Usage fsmAsm('B', arg)
                                          7195  # - unconditional branch
                                          7196  # - can be the same as BL if sysArgs+6 can be trashed
                                          7197  label(fsmLab('B'))
                                          7198  #st([fsmState])                  #5
                                          7199  #bra('NEXT')                     #6
                                          7200  #ld(-8/2)                        #7
                                          7201
                                          7202  # Usage fsmAsm('BL', arg)
                                          7203  # - branch and link using sysArgs+6 as link register
                                          7204  # - call subroutine with fsmAsm('BL', 'label')
                                          7205  # - return from subroutine with fsmAsm('BL',[sysArgs+6])
                                          7206  label(fsmLab('BL'))
fsm16:B:
fsm16:BL:     161d 1415  ld   $15,y       7207  ld(hi('fsmBL#8'),Y)             #5
              161e e0c7  jmp  y,$c7       7208  jmp(Y,'fsmBL#8')                #6
              161f c22f  st   [$2f]       7209  st([vTmp])                      #7
                                          7210
                                          7211  # Usage: fsmAsm('VRETNZ')
                                          7212  # - if vLR is nonzero, return to vCPU at address vLR.
                                          7213  label(fsmLab('VRETNZ'))
fsm16:VRETNZ: 1620 1415  ld   $15,y       7214  ld(hi('fsmVRETNZ#8'),Y)         #5
              1621 e0cc  jmp  y,$cc       7215  jmp(Y,'fsmVRETNZ#8')            #6
              1622 c22b  st   [$2b]       7216  st([fsmState])                  #7
                                          7217
                                          7218  # Usage: fsmAsm('CHANMASK')
                                          7219  # - clear channelMask if segment [sysArgs[23],sysArgs[23]+sysArgs[4]]
                                          7220  #   overlaps OSCL/OSCH for audio channel 1-3
                                          7221  label(fsmLab('CHANMASK'))
fsm16:CHANMASK:
              1623 1415  ld   $15,y       7222  ld(hi('fsmCHANMASK#8'),Y)       #5
              1624 e0db  jmp  y,$db       7223  jmp(Y,'fsmCHANMASK#8')          #6
              1625 c22b  st   [$2b]       7224  st([fsmState])                  #7
                                          7225
                                          7226  # Usage: fsmAsm('ST+')
                                          7227  # - store vACL into [sysArgs23]
                                          7228  # - increment low address byte sysArgs2
                                          7229  # - decrements count sysArgs+4 and return it in vACL
                                          7230  label(fsmLab('ST+'))
fsm16:ST+:    1626 1415  ld   $15,y       7231  ld(hi('fsmST+#8'),Y)            #5
              1627 e0ee  jmp  y,$ee       7232  jmp(Y,'fsmST+#8')               #6 + overlap
                                          7233
                                          7234  # Usage: fsmAsm('LUP')
                                          7235  # - copy rom byte at [sysArgs01] into vACL
                                          7236  # - increment [sysArgs01] skipping trampolines
                                          7237  label(fsmLab('LUP'))
fsm16:LUP:    1628 c22b  st   [$2b]       7238  st([fsmState])                  #5
              1629 0124  ld   [$24]       7239  ld([sysArgs+0])                 #6
              162a a0fa  suba $fa         7240  suba(250)                       #7
                                          7241  beq(fsmLab('LUP#10'))           #8
              162b f032  beq  fsm16:LUP#10
              162c 1525  ld   [$25],y     7242  ld([sysArgs+1],Y)               #9
              162d 80fb  adda $fb         7243  adda(251)                       #10
              162e c224  st   [$24]       7244  st([sysArgs+0])                 #11
              162f a001  suba $01         7245  suba(1)                         #12
                                          7246  bra(fsmLab('LUP#15'))           #13
              1630 fc37  bra  fsm16:LUP#15
              1631 0200  nop              7247  nop()                           #14
                                          7248  label(fsmLab('LUP#10'))
fsm16:LUP#10: 1632 c224  st   [$24]       7249  st([sysArgs+0])                 #10
              1633 0125  ld   [$25]       7250  ld([sysArgs+1])                 #11
              1634 8001  adda $01         7251  adda(1)                         #12
              1635 c225  st   [$25]       7252  st([sysArgs+1])                 #13
              1636 00fa  ld   $fa         7253  ld(250)                         #14
                                          7254  label(fsmLab('LUP#15'))
fsm16:LUP#15: 1637 e0fb  jmp  y,$fb       7255  jmp(Y,251)                      #15
              1638 0200  nop              7256  nop()                           #16
                                          7257
                                          7258  # Usage: fsmAsm('LDMATCH')
                                          7259  # - compute address sysArgs[23] minus offset sysFn[01] (no carry)
                                          7260  # - load byte at this address into vACL
                                          7261  label(fsmLab('LDMATCH'))
fsm16:LDMATCH:
              1639 c22b  st   [$2b]       7262  st([fsmState])                  #5,7
              163a 0127  ld   [$27]       7263  ld([sysArgs+3])                 #6
              163b b523  suba [$23],y     7264  suba([sysFn+1],Y)               #7
              163c 0126  ld   [$26]       7265  ld([sysArgs+2])                 #8
              163d b122  suba [$22],x     7266  suba([sysFn],X)                 #9
              163e 0d00  ld   [y,x]       7267  ld([Y,X])                       #10
              163f c218  st   [$18]       7268  st([vAC])                       #11
              1640 fc01  bra  FSM16_NEXT  7269  bra('NEXT')                     #12
              1641 00f9  ld   $f9         7270  ld(-14/2)                       #13
                                          7271
                                          7272  # Subroutine to copy [sysArgs+4] literals at [sysArgs+23]
                                          7273  label('se:copyLiteral')
se:copyLiteral:                           7274  fsmAsm('CHANMASK')
              1642 fc23  bra  fsm16:CHANMASK
              1643 0044  ld   $44
                                          7275  label('se:copyLiteral.1')
se:copyLiteral.1:
              1644 fc28  bra  fsm16:LUP   7276  fsmAsm('LUP')
              1645 0046  ld   $46
              1646 fc26  bra  fsm16:ST+   7277  fsmAsm('ST+')
              1647 0048  ld   $48
              1648 fc17  bra  fsm16:BNZ   7278  fsmAsm('BNZ', 'se:copyLiteral.1')
              1649 0044  ld   $44
              164a fc1d  bra  fsm16:BL    7279  fsmAsm('BL', [sysArgs+6])
              164b 012a  ld   [$2a]
                                          7280
                                          7281  # Load uncompressed GT1
                                          7282  label('se:loadGt1:al')
se:loadGt1:al:
              164c fc28  bra  fsm16:LUP   7283  fsmAsm('LUP')
              164d 004e  ld   $4e
              164e fc0a  bra  fsm16:ST    7284  fsmAsm('ST', sysArgs+2)
              164f 0026  ld   $26
                                          7285  label('se:loadGt1:len')
se:loadGt1:len:
              1650 fc28  bra  fsm16:LUP   7286  fsmAsm('LUP')
              1651 0052  ld   $52
              1652 fc0a  bra  fsm16:ST    7287  fsmAsm('ST', sysArgs+4)
              1653 0028  ld   $28
              1654 fc1d  bra  fsm16:BL    7288  fsmAsm('BL', 'se:copyLiteral')
              1655 0042  ld   $42
              1656 fc28  bra  fsm16:LUP   7289  fsmAsm('LUP')
              1657 0058  ld   $58
              1658 fc0a  bra  fsm16:ST    7290  fsmAsm('ST', sysArgs+3)
              1659 0027  ld   $27
              165a fc17  bra  fsm16:BNZ   7291  fsmAsm('BNZ','se:loadGt1:al')
              165b 004c  ld   $4c
