              0e3b e43b  bgt  $0e3b       4744  bgt(pc()&255)                   #4 Resync
              0e3c a001  suba $01         4745  suba(1)                         #5
              0e3d 000d  ld   $0d         4746  ld(hi('v6502_ENTER'))           #6 Set entry point to before 'fetch'
              0e3e c205  st   [$05]       4747  st([vCpuSelect])                #7
              0e3f 1401  ld   $01,y       4748  ld(hi('vBlankStart'),Y)         #8
              0e40 e11e  jmp  y,[$1e]     4749  jmp(Y,[vReturn])                #9 To video driver
              0e41 0102  ld   [$02]       4750  ld([channel])                   #10
                                          4751  assert v6502_overhead ==         11
