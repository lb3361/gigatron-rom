              128f 8004  adda $04         6061  adda(4)                         #33
              1290 c219  st   [$19]       6062  st([vAC+1])                     #34
              1291 f094  beq  $1294       6063  beq(pc()+3)                     #35 For 64 iterations
              1292 fc95  bra  $1295       6064  bra(pc()+3)                     #36
              1293 00fe  ld   $fe         6065  ld(-2)                          #37
