                                          6170  # SYS_ShuffleNoise_v4_46 implementation
                                          6171  label('sys_ShuffleNoise')
sys_ShuffleNoise:
              127f 1118  ld   [$18],x     6172  ld([vAC+0],X)                   #18 tmp = T[4j]
              1280 0d00  ld   [y,x]       6173  ld([Y,X])                       #19
              1281 c22f  st   [$2f]       6174  st([vTmp])                      #20
              1282 1119  ld   [$19],x     6175  ld([vAC+1],X)                   #21 T[4j] = T[4i]
              1283 0d00  ld   [y,x]       6176  ld([Y,X])                       #22
              1284 1118  ld   [$18],x     6177  ld([vAC+0],X)                   #23
              1285 ce00  st   [y,x]       6178  st([Y,X])                       #24
              1286 8200  adda ac          6179  adda(AC)                        #25 j += T[4i]
              1287 8200  adda ac          6180  adda(AC,)                       #26
              1288 8118  adda [$18]       6181  adda([vAC+0])                   #27
              1289 c218  st   [$18]       6182  st([vAC+0])                     #28
