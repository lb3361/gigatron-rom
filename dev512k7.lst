                                          4558  label('v6502_lsr')
                                          4559  assert v6502_Cflag == 1
v6502_lsr:    0dab 1525  ld   [$25],y     4560  ld([v6502_ADH],Y)               #12
              0dac 0d00  ld   [y,x]       4561  ld([Y,X])                       #13 Transfer bit 0 to C
              0dad 6127  xora [$27]       4562  xora([v6502_P])                 #14
              0dae 2001  anda $01         4563  anda(1)                         #15
              0daf 6127  xora [$27]       4564  xora([v6502_P])                 #16
              0db0 c227  st   [$27]       4565  st([v6502_P])                   #17
              0db1 00c3  ld   $c3         4566  ld('v6502_lsr#28')              #18 Shift table lookup
              0db2 c22f  st   [$2f]       4567  st([vTmp])                      #19
              0db3 0d00  ld   [y,x]       4568  ld([Y,X])                       #20
              0db4 20fe  anda $fe         4569  anda(~1)                        #21
              0db5 1405  ld   $05,y       4570  ld(hi('shiftTable'),Y)          #22
              0db6 e200  jmp  y,ac        4571  jmp(Y,AC)                       #23
              0db7 fcff  bra  $ff         4572  bra(255)                        #24 bra shiftTable+255
                                          4573
