                                          1439  #
                                          1440  videoYInput = 1-2*(vBack-1-1)   # videoY when the 74HC595 has all 8 controller bits
              0193 0109  ld   [$09]       1441  ld([videoY])                    #42
              0194 60cf  xora $cf         1442  xora(videoYInput)               #43 Check for serial input capture
              0195 f09c  beq  vbInput#46  1443  beq('vbInput#46')               #44
              0196 60cf  xora $cf         1444  xora(videoYInput)               #45
              0197 2006  anda $06         1445  anda(6)                         #46 Check for sound sample
              0198 f09e  beq  vbSample#49 1446  beq('vbSample#49')              #47
                                          1447  label('vbNormal#48')
vbNormal#48:  0199 1505  ld   [$05],y     1448  runVcpu_new(vBlankEnterCyc-48,
              019a e0ff  jmp  y,$ff
              019b 0037  ld   $37
                                          1449              'AB-D line 1-36')   #48 Application cycles (vBlank scan lines without sound sample update)
                                          1450
                                          1451  # Capture serial input
                                          1452  label('vbInput#46')
                                          1453  if videoYInput ^ 6 != 0:
vbInput#46:   019c fc99  bra  vbNormal#48 1454    bra('vbNormal#48')            #46
              019d c30f  st   in,[$0f]    1455    st(IN, [serialRaw])           #47
                                          1456  else:
                                          1457    st(IN, [serialRaw])           #46
                                          1458    bra('vbSample#49')            #47
                                          1459
                                          1460  # Update [xout] with the next sound sample every 4 scan lines.
                                          1461  # Keep doing this on 'videoC equivalent' scan lines in vertical blank.
                                          1462  label('vbSample#49')
                                          1463  if not WITH_512K_BOARD:
                                          1464      ld([sample])                #49
                                          1465      ora(0x0f)                   #50 New sound sample is ready
                                          1466      anda([xoutMask])            #51
                                          1467      st([xout])                  #52
                                          1468      st(sample, [sample])        #53 Reset for next sample
                                          1469      runVcpu_new(vBlankEnterCyc-54,
                                          1470              '--C- line 3-39')   #54 Application cycles (vBlank scan lines with sound sample update)
                                          1471  else:
vbSample#49:  019e 1503  ld   [$03],y     1472      ld([sample],Y)              #49
              019f 0114  ld   [$14]       1473      ld([xoutMask])              #50
                                          1474      bmi('.vbSample#53')         #51
              01a0 e8a4  blt  .vbSample#53
              01a1 0103  ld   [$03]       1475      ld([sample])                #52
                                          1476      bra('.vbSample#55')         #53
              01a2 fca6  bra  .vbSample#55
              01a3 400f  ora  $0f         1477      ora(0x0f)                   #54
                                          1478      label('.vbSample#53')
.vbSample#53: 01a4 c9d0  ctrl y,$d0       1479      ctrl(Y,0xD0)                #53 instead of #43 (wrong by ~2us)
              01a5 400f  ora  $0f         1480      ora(0x0f)                   #54
                                          1481      label('.vbSample#55')
.vbSample#55: 01a6 2114  anda [$14]       1482      anda([xoutMask])            #55
              01a7 c213  st   [$13]       1483      st([xout])                  #56
              01a8 c003  st   $03,[$03]   1484      st(sample, [sample])        #57 Reset for next sample
              01a9 1505  ld   [$05],y     1485      runVcpu_new(vBlankEnterCyc-58,
              01aa e0ff  jmp  y,$ff
              01ab 0032  ld   $32
                                          1486              '--C- line 3-39')   #58 Application cycles (vBlank scan lines with sound sample update)
                                          1487
                                          1488
                                          1489  # ------- last vblank line
                                          1490  #
                                          1491  # This is executed during the last video blanking line.
                                          1492  # It sets up things for the visible lines that follow
                                          1493
                                          1494  label('.vBlankLast#32')
.vBlankLast#32:
              01ac e028  jmp  y,$28       1495  jmp(Y,'vBlankLast#34')          #32 Jump out of page for space reasons
              01ad 1401  ld   $01,y       1496  ld(hi(pc()),Y)                  #33
                                          1497
                                          1498  label('vBlankLast#52')
                                          1499
                                          1500  # Respond to reset button (14 cycles)
                                          1501  # - ResetTimer decrements as long as just [Start] is pressed down
                                          1502  # - Reaching 0 (normal) or 128 (extended) triggers the soft reset sequence
                                          1503  # - Initial value is 128 (or 255 at boot), first decrement, then check
                                          1504  # - This starts vReset -> SYS_Reset_88 -> SYS_Exec_88 -> Reset.gcl -> Main.gcl
                                          1505  # - Main.gcl then recognizes extended presses if resetTimer is 0..127 ("paasei")
                                          1506  # - This requires a full cycle (4s) in the warm boot scenario
                                          1507  # - Or a half cycle (2s) when pressing [Select] down during hard reset
                                          1508  # - This furthermore requires >=1 frame (and <=128) to have passed between
                                          1509  #   reaching 128 and getting through Reset and the start of Main, while [Start]
                                          1510  #   was still pressed so the count reaches <128. Two reasonable expectations.
                                          1511  # - The unintended power-up scenarios of ROMv1 (pulling SER_DATA low, or
                                          1512  #   pressing [Select] together with another button) now don't trigger anymore.
                                          1513
vBlankLast#52:
              01ae 0111  ld   [$11]       1514  ld([buttonState])               #52 Check [Start] for soft reset
              01af 60ef  xora $ef         1515  xora(~buttonStart)              #53
              01b0 ecb9  bne  .restart#56 1516  bne('.restart#56')              #54
              01b1 0112  ld   [$12]       1517  ld([resetTimer])                #55 As long as button pressed
              01b2 a001  suba $01         1518  suba(1)                         #56 ... count down the timer
              01b3 c212  st   [$12]       1519  st([resetTimer])                #57
              01b4 207f  anda $7f         1520  anda(127)                       #58
              01b5 f0c1  beq  .restart#61 1521  beq('.restart#61')              #59 Reset at 0 (normal 2s) or 128 (extended 4s)
              01b6 00ee  ld   $ee         1522  ld((vReset&255)-2)              #60 Start force reset when hitting 0
              01b7 fcc0  bra  .restart#63 1523  bra('.restart#63')              #61 ... otherwise do nothing yet
              01b8 fcbf  bra  .restart#64 1524  bra('.restart#64')              #62
                                          1525  label('.restart#56')
.restart#56:  01b9 0001  ld   $01         1526  wait(62-56)                     #56
              01ba ecba  bne  $01ba
              01bb a001  suba $01
              01bc 0200  nop
              01bd 0080  ld   $80         1527  ld(128)                         #62 Not pressed, reset the timer
              01be c212  st   [$12]       1528  st([resetTimer])                #63
                                          1529  label('.restart#64')
.restart#64:  01bf fcc6  bra  .restart#66 1530  bra('.restart#66')              #64
                                          1531  label('.restart#63')
.restart#63:  01c0 0200  nop              1532  nop()                           #63,65
                                          1533  label('.restart#61')
.restart#61:  01c1 c216  st   [$16]       1534  st([vPC])                       #61 Point vPC at vReset
              01c2 0001  ld   $01         1535  ld(vReset>>8)                   #62
              01c3 c217  st   [$17]       1536  st([vPC+1])                     #63
              01c4 0002  ld   $02         1537  ld(hi('ENTER'))                 #64 Set active interpreter to vCPU
              01c5 c205  st   [$05]       1538  st([vCpuSelect])                #65
                                          1539  label('.restart#66')
                                          1540
                                          1541  # Sets vReturn and nextVideo for visible lines
.restart#66:  01c6 00ff  ld   $ff         1542  ld(lo('vVisibEnter'))           #66
              01c7 c21e  st   [$1e]       1543  st([vReturn])                   #67
              01c8 1401  ld   $01,y       1544  ld(videoTop_v5>>8,Y)            #68
              01c9 09f9  ld   [y,$f9]     1545  ld([Y,videoTop_v5])             #69
              01ca c209  st   [$09]       1546  st([videoY])                    #70
              01cb c21f  st   [$1f]       1547  st([frameX])                    #71
              01cc eccf  bne  $01cf       1548  bne(pc()+3)                     #72
              01cd fcd0  bra  $01d0       1549  bra(pc()+3)                     #73
              01ce 001d  ld   $1d         1550  ld('videoA')                    #74
              01cf 0073  ld   $73         1551  ld('videoF')                    #74(!)
              01d0 c20d  st   [$0d]       1552  st([nextVideo])                 #75
              01d1 0102  ld   [$02]       1553  ld([channel])                   #76 Normalize channel for robustness
              01d2 2003  anda $03         1554  anda(0b00000011)                #77
              01d3 c202  st   [$02]       1555  st([channel])                   #78
                                          1556
                                          1557
                                          1558  # Switch video mode when (only) select is pressed (16 cycles)
                                          1559  # XXX We could make this a vCPU interrupt
              01d4 0111  ld   [$11]       1560  ld([buttonState])               #79 Check [Select] to switch modes
              01d5 60df  xora $df         1561  xora(~buttonSelect)             #80 Only trigger when just [Select] is pressed
              01d6 f0da  beq  .select#83  1562  beq('.select#83')               #81
              01d7 1505  ld   [$05],y     1563  runVcpu_new(vVisibEnterCyc-82,  #82 vCPU
              01d8 e0ff  jmp  y,$ff
              01d9 0026  ld   $26
                                          1564            '---D line 40 no select')
                                          1565
                                          1566  label('.select#83')
                                          1567  if not WITH_512K_BOARD:
                                          1568    ld([videoModeC])              #83
                                          1569    bmi('.select#86')             #84 Branch when line C is off
                                          1570    ld([videoModeB])              #85 Rotate: Off->D->B->C
                                          1571    st([videoModeC])              #86
                                          1572    ld([videoModeD])              #87
                                          1573    st([videoModeB])              #88
                                          1574    bra('.select#91')             #89
                                          1575    label('.select#86')
                                          1576    ld('nopixels')                #86,90
                                          1577    ld('pixels')                  #87 Reset: On->D->B->C
                                          1578    st([videoModeC])              #88
                                          1579    st([videoModeB])              #89
                                          1580    nop()                         #90
                                          1581    label('.select#91')
                                          1582    st([videoModeD])              #91
                                          1583  else:
.select#83:   01da 010a  ld   [$0a]       1584    ld([videoModeB])              #83
              01db 60fd  xora $fd         1585    xora('nopixels')              #84
              01dc f0e1  beq  .select#87  1586    beq('.select#87')             #85
              01dd 010c  ld   [$0c]       1587    ld([videoModeD])              #86
              01de c20a  st   [$0a]       1588    st([videoModeB])              #87
              01df fce4  bra  .select#90  1589    bra('.select#90')             #88
              01e0 00fd  ld   $fd         1590    ld('nopixels')                #89
                                          1591    label('.select#87')
.select#87:   01e1 00fc  ld   $fc         1592    ld('pixels')                  #87
              01e2 c20a  st   [$0a]       1593    st([videoModeB])              #88
              01e3 0200  nop              1594    nop()                         #89
                                          1595    label('.select#90')
.select#90:   01e4 c20c  st   [$0c]       1596    st([videoModeD])              #90
              01e5 0200  nop              1597    nop()                         #91
                                          1598
              01e6 00ff  ld   $ff         1599  ld(255)                         #92
              01e7 c211  st   [$11]       1600  st([buttonState])               #93
              01e8 1505  ld   [$05],y     1601  runVcpu_new(vVisibEnterCyc-94,  #94
              01e9 e0ff  jmp  y,$ff
              01ea 0020  ld   $20
                                          1602            '---D line 40 select')
                                          1603
                                          1604
                                          1605
                                          1606
                                          1607  #-----------------------------------------------------------------------
                                          1608  #
                                          1609  #  $0200 ROM page 2: Video loop visible scanlines
                                          1610  #
                                          1611  #-----------------------------------------------------------------------
                                          1612
                                          1613
                                          1614
                                          1615  if WITH_512K_BOARD:
                                          1616
                                          1617    # Code for the Gigatron 512K
                                          1618
              01eb 0200  nop              1619    fillers(until=0xff)
              01ec 0200  nop
              01ed 0200  nop
              * 20 times
                                          1620    label('vVisibEnter')
                                          1621    assert(vVisibEnterCyc == 200)
vVisibEnter:  01ff 18c0  ld   $c0,out     1622    ld(syncBits,OUT)                #200,0 <New scan line start>
                                          1623    align(0x100, size=0x100)
                                          1624
                                          1625    # Front porch
              0200 2121  anda [$21]       1626    anda([channelMask])             #1 AC is [channel] already!
              0201 8001  adda $01         1627    adda(1)                         #2
              0202 d602  st   [$02],y     1628    st([channel],Y)                 #3
              0203 1880  ld   $80,out     1629    ld(syncBits^hSync,OUT)          #4 Start horizontal pulse (4)
                                          1630
                                          1631    # Horizontal sync and sound channel update for scanlines outside vBlank
                                          1632    label('sound2')
sound2:       0204 007f  ld   $7f         1633    ld(0x7f)                        #5
              0205 29fe  anda [y,$fe]     1634    anda([Y,oscL])                  #6
              0206 89fc  adda [y,$fc]     1635    adda([Y,keyL])                  #7
              0207 cafe  st   [y,$fe]     1636    st([Y,oscL])                    #8
              0208 3080  anda $80,x       1637    anda(0x80,X)                    #9
              0209 0500  ld   [x]         1638    ld([X])                         #10
              020a 89ff  adda [y,$ff]     1639    adda([Y,oscH])                  #11
              020b 89fd  adda [y,$fd]     1640    adda([Y,keyH])                  #12
              020c caff  st   [y,$ff]     1641    st([Y,oscH] )                   #13
              020d 20fc  anda $fc         1642    anda(0xfc)                      #14
              020e 69fb  xora [y,$fb]     1643    xora([Y,wavX])                  #15
              020f 1200  ld   ac,x        1644    ld(AC,X)                        #16
              0210 09fa  ld   [y,$fa]     1645    ld([Y,wavA])                    #17
              0211 1407  ld   $07,y       1646    ld(soundTable>>8,Y)             #18
              0212 8d00  adda [y,x]       1647    adda([Y,X])                     #19
              0213 e816  blt  $0216       1648    bmi(pc()+3)                     #20
              0214 fc17  bra  $0217       1649    bra(pc()+3)                     #21
              0215 203f  anda $3f         1650    anda(63)                        #22
              0216 003f  ld   $3f         1651    ld(63)                          #22(!)
              0217 8103  adda [$03]       1652    adda([sample])                  #23
              0218 c203  st   [$03]       1653    st([sample])                    #24
              0219 0113  ld   [$13]       1654    ld([xout])                      #25 Gets copied to XOUT
              021a 1401  ld   $01,y       1655    ld(videoTable>>8,Y)             #26 Make Y=1 for all videoABC routines!
              021b fd0d  bra  [$0d]       1656    bra([nextVideo])                #27
              021c 18c0  ld   $c0,out     1657    ld(syncBits,OUT)                #28 End horizontal pulse
                                          1658
                                          1659    # Back porch A: first of 4 repeated scan lines
                                          1660    # - Fetch next Yi and store it for retrieval in the next scan lines
                                          1661    # - Calculate Xi from dXi and store it as well thanks to a saved cycle.
                                          1662    label('videoA')
videoA:       021d 002d  ld   $2d         1663    ld('videoB')                    #29 1st scanline of 4 (always visible)
              021e c20d  st   [$0d]       1664    st([nextVideo])                 #30
              021f 1109  ld   [$09],x     1665    ld([videoY],X)                  #31
              0220 0d00  ld   [y,x]       1666    ld([Y,X])                       #32 Y is already 1
              0221 de00  st   [y,x++]     1667    st([Y,Xpp])                     #33 Just X++
              0222 c220  st   [$20]       1668    st([frameY])                    #34
              0223 0d00  ld   [y,x]       1669    ld([Y,X])                       #35
              0224 811f  adda [$1f]       1670    adda([frameX])                  #36
              0225 d21f  st   [$1f],x     1671    st([frameX],X)                  #37 I am sure Marcel sought to do this (LB)
              0226 1520  ld   [$20],y     1672    ld([frameY],Y)                  #38
              0227 00c0  ld   $c0         1673    ld(syncBits)                    #39
              0228 5d00  ora  [y,x++],out 1674    ora([Y,Xpp],OUT)                #40 begin of pixel burst
              0229 1505  ld   [$05],y     1675    runVcpu_new(vVisibEnterCyc-41,  #41
              022a c000  st   $00,[$00]
              022b e0ff  jmp  y,$ff
              022c 003a  ld   $3a
                                          1676            'A--- line 40-520' )
                                          1677
                                          1678    # Back porch B: second of 4 repeated scan lines
                                          1679    # - Process double vres
                                          1680    label('videoB')
videoB:       022d 003d  ld   $3d         1681    ld('videoC')                    #29
              022e c20d  st   [$0d]       1682    st([nextVideo])                 #30
              022f 1520  ld   [$20],y     1683    ld([frameY],Y)                  #31
              0230 010b  ld   [$0b]       1684    ld([videoModeC])                #32 New role for videoModeC
              0231 2001  anda $01         1685    anda(1)                         #33
              0232 8120  adda [$20]       1686    adda([frameY])                  #34
              0233 c220  st   [$20]       1687    st([frameY])                    #35
              0234 111f  ld   [$1f],x     1688    ld([frameX],X)                  #36
              0235 00c0  ld   $c0         1689    ld(syncBits)                    #37
              0236 fd0a  bra  [$0a]       1690    bra([videoModeB])               #38
              0237 fc39  bra  $0239       1691    bra(pc()+2)                     #39
              0238 0200  nop              1692    nop()                           #40 'pixels' or 'nopixels'
              0239 1505  ld   [$05],y     1693    runVcpu_new(vVisibEnterCyc-41,  #41
              023a c000  st   $00,[$00]
              023b e0ff  jmp  y,$ff
              023c 003a  ld   $3a
                                          1694            '-B-- line 40-520' )
                                          1695
                                          1696    # Back porch C: third of 4 repeated scan lines
                                          1697    # - Nothing new to for video do as Yi and Xi are known,
                                          1698    # - This is the time to emit and reset the next sound sample
                                          1699    label('videoC')
videoC:       023d 0055  ld   $55         1700    ld('videoD')                    #29 3rd scanline of 4
              023e c20d  st   [$0d]       1701    st([nextVideo])                 #30
              023f 0103  ld   [$03]       1702    ld([sample])                    #31 New sound sample is ready (didn't fit in audio loop)
              0240 400f  ora  $0f         1703    ora(0x0f)                       #32
              0241 2114  anda [$14]       1704    anda([xoutMask])                #33
              0242 c213  st   [$13]       1705    st([xout])                      #34 Update [xout] with new sample (4 channels just updated)
              0243 111f  ld   [$1f],x     1706    ld([frameX],X)                  #35
              0244 0114  ld   [$14]       1707    ld([xoutMask])                  #36
              0245 e84d  blt  videoC#39   1708    bmi('videoC#39')                #37
              0246 1520  ld   [$20],y     1709    ld([frameY],Y)                  #38
              0247 00c0  ld   $c0         1710    ld(syncBits)                    #39
              0248 5d00  ora  [y,x++],out 1711    ora([Y,Xpp], OUT)               #40 Always outputs pixels on C lines
              0249 1505  ld   [$05],y     1712    runVcpu_new(vVisibEnterCyc-41,  #41
              024a c000  st   $00,[$00]
              024b e0ff  jmp  y,$ff
              024c 003a  ld   $3a
                                          1713            '--C- line 40-520 no sound')
                                          1714
                                          1715    label('videoC#39')
videoC#39:    024d 00c0  ld   $c0         1716    ld(syncBits)                    #39
              024e 5d00  ora  [y,x++],out 1717    ora([Y,Xpp], OUT)               #40 Always outputs pixels on C lines
              024f 1503  ld   [$03],y     1718    ld([sample],Y)                  #41
              0250 c003  st   $03,[$03]   1719    st(sample, [sample])            #42 Reset for next sample
              0251 c9d0  ctrl y,$d0       1720    ctrl(Y,0xD0);                   #43 Forward audio to PWM (only when audio is active)
              0252 1505  ld   [$05],y     1721    runVcpu_new(vVisibEnterCyc-44,  #44
              0253 e0ff  jmp  y,$ff
              0254 0039  ld   $39
                                          1722            '--C- line 40-520 sound forwarding')
                                          1723
                                          1724    # Back porch D: last of 4 repeated scan lines
                                          1725    # - Calculate the next frame index
                                          1726    # - Decide if this is the last line or not
                                          1727    label('videoD')                 # Default video mode
videoD:       0255 111f  ld   [$1f],x     1728    ld([frameX], X)                 #29 4th scanline of 4
              0256 0109  ld   [$09]       1729    ld([videoY])                    #30
              0257 a0ee  suba $ee         1730    suba((120-1)*2)                 #31
                                          1731    beq('.lastpixels#34')           #32
              0258 f067  beq  .lastpixels#34
              0259 80f0  adda $f0         1732    adda(120*2)                     #33 More pixel lines to go
              025a c209  st   [$09]       1733    st([videoY])                    #34
              025b 0200  nop              1734    nop()                           #35
              025c 1520  ld   [$20],y     1735    ld([frameY],Y)                  #36
              025d 00c0  ld   $c0         1736    ld(syncBits)                    #37
              025e fd0c  bra  [$0c]       1737    bra([videoModeD])               #38
              025f fc61  bra  $0261       1738    bra(pc()+2)                     #39
              0260 0200  nop              1739    nop()                           #40 'pixels' or 'nopixels'
              0261 0200  nop              1740    nop()                           #41
              0262 001d  ld   $1d         1741    ld('videoA')                    #42
                                          1742    label('videoD#43')
videoD#43:    0263 c20d  st   [$0d]       1743    st([nextVideo])                 #43
              0264 1505  ld   [$05],y     1744    runVcpu_new(vVisibEnterCyc-44,  #44
              0265 e0ff  jmp  y,$ff
              0266 0039  ld   $39
                                          1745            '---D line 40-520')
                                          1746
                                          1747    label('.lastpixels#34')
                                          1748    if soundDiscontinuity == 1:
.lastpixels#34:
              0267 c003  st   $03,[$03]   1749      st(sample, [sample])          #34 Sound continuity
                                          1750    else:
                                          1751      nop()                         #34
              0268 1520  ld   [$20],y     1752    ld([frameY],Y)                  #35
              0269 00c0  ld   $c0         1753    ld(syncBits)                    #36
              026a 0200  nop              1754    nop()                           #37
              026b fd0c  bra  [$0c]       1755    bra([videoModeD])               #38
              026c fc6e  bra  $026e       1756    bra(pc()+2)                     #39
              026d 0200  nop              1757    nop()                           #40 'pixels' or 'nopixels'
              026e fc63  bra  videoD#43   1758    bra('videoD#43')                #41
              026f 0070  ld   $70         1759    ld('videoE')                    #42 no more scanlines
                                          1760
                                          1761    # Back porch "E": after the last line
                                          1762    # - Go back and and enter vertical blank (program page 2)
                                          1763    label('videoE') # Exit visible area
videoE:       0270 1401  ld   $01,y       1764    ld(hi('vBlankStart'),Y)         #29 Return to vertical blank interval
              0271 e004  jmp  y,$04       1765    jmp(Y,'vBlankStart')            #30
              0272 00c0  ld   $c0         1766    ld(syncBits)                    #31
                                          1767
                                          1768    # Video mode that blacks out one or more pixel lines from the top of screen.
                                          1769    # This yields some speed, but also frees up screen memory for other purposes.
                                          1770    # Note: Sound output becomes choppier the more pixel lines are skipped
                                          1771    # Note: The vertical blank driver leaves 0x80 behind in [videoSync1]
                                          1772    label('videoF')
videoF:       0273 0120  ld   [$20]       1773    ld([videoSync1])                #29 Completely black pixel line
              0274 8080  adda $80         1774    adda(0x80)                      #30
              0275 d220  st   [$20],x     1775    st([videoSync1],X)              #31
              0276 011f  ld   [$1f]       1776    ld([frameX])                    #32
              0277 a500  suba [x]         1777    suba([X])                       #33 Decrements every two VGA scanlines
              0278 f07b  beq  .videoF#36  1778    beq('.videoF#36')               #34
              0279 c21f  st   [$1f]       1779    st([frameX])                    #35
              027a fc7d  bra  .videoF#38  1780    bra('.videoF#38')               #36
                                          1781    label('.videoF#36')
.videoF#36:   027b 001d  ld   $1d         1782    ld('videoA')                    #36,37 Transfer to visible screen area
              027c c20d  st   [$0d]       1783    st([nextVideo])                 #37
                                          1784    label('.videoF#38')
.videoF#38:   027d 1505  ld   [$05],y     1785    runVcpu_new(200-38,             #38
              027e e0ff  jmp  y,$ff
              027f 003c  ld   $3c
                                          1786            'F--- line 40-520')
                                          1787
              0280 0200  nop              1788    fillers(until=0xfc);
              0281 0200  nop
              0282 0200  nop
              * 124 times
                                          1789    label('pixels')
pixels:       02fc 5d00  ora  [y,x++],out 1790    ora([Y,Xpp],OUT)                #40
                                          1791    label('nopixels')
nopixels:     02fd 0200  nop              1792    nop()                           #40
                                          1793
                                          1794  else:
                                          1795
                                          1796    # Code for the Gigatron / Gigatron 128K
                                          1797
                                          1798    if WITH_128K_BOARD:
                                          1799      fillers(until=0xe3)
                                          1800      label('vVisibEnter')
                                          1801      assert(vVisibEnterCyc == 200)
                                          1802      ld([ctrlVideo],X)             #200,0 <New scan line start>
                                          1803      ctrl(X)                       #1 Reset banking to page1.
                                          1804      anda([channelMask])           #2
                                          1805      adda(1)                       #3
                                          1806      ld(syncBits^hSync,OUT)        #4 Start horizontal pulse
                                          1807      st([channel],Y)               #5
                                          1808      ld(0x7f)                      #6  Copying the sound code
                                          1809      anda([Y,oscL])                #7  prevents losing one precious
                                          1810      adda([Y,keyL])                #8  cycle in a branch to sound3
                                          1811      st([Y,oscL])                  #9
                                          1812      anda(0x80,X)                  #10
                                          1813      ld([X])                       #11
                                          1814      adda([Y,oscH])                #12
                                          1815      adda([Y,keyH])                #13
                                          1816      st([Y,oscH] )                 #14
                                          1817      anda(0xfc)                    #15
                                          1818      xora([Y,wavX])                #16
                                          1819      ld(AC,X)                      #17
                                          1820      ld([Y,wavA])                  #18
                                          1821      ld(soundTable>>8,Y)           #19
                                          1822      adda([Y,X])                   #20
                                          1823      bmi(pc()+3)                   #21
                                          1824      bra(pc()+3)                   #22
                                          1825      anda(63)                      #23
                                          1826      ld(63)                        #23
                                          1827      adda([sample])                #24
                                          1828      st([sample])                  #25
                                          1829      ld([xout])                    #26
                                          1830      assert(pc()&0xff == 0xff)
                                          1831      bra([nextVideo])              #27
                                          1832      align(0x100, size=0x100)
                                          1833      ld(syncBits,OUT)              #28 End horizontal pulse
                                          1834
                                          1835
                                          1836    else:
                                          1837      fillers(until=0xff)
                                          1838      label('vVisibEnter')
                                          1839      assert(vVisibEnterCyc == 200)
                                          1840      bra('sound3')                 #200,0 <New scan line start>
                                          1841      align(0x100, size=0x100)
                                          1842      ld([channel])                 #1 AC already contains [channel]
                                          1843
                                          1844    # Back porch A: first of 4 repeated scan lines
                                          1845    # - Fetch next Yi and store it for retrieval in the next scan lines
                                          1846    # - Calculate Xi from dXi, but there is no cycle time left to store it as well
                                          1847    label('videoA')
                                          1848    ld('videoB')                    #29 1st scanline of 4 (always visible)
                                          1849    st([nextVideo])                 #30
                                          1850    ld(videoTable>>8,Y)             #31
                                          1851    ld([videoY],X)                  #32
                                          1852    ld([Y,X])                       #33
                                          1853    st([Y,Xpp])                     #34 Just X++
                                          1854    st([frameY])                    #35
                                          1855    ld([Y,X])                       #36
                                          1856    adda([frameX],X)                #37
                                          1857    label('pixels')
                                          1858    ld([frameY],Y)                  #38
                                          1859    ld(syncBits)                    #39
                                          1860
                                          1861    # Stream 160 pixels from memory location <Yi,Xi> onwards
                                          1862    # Superimpose the sync signal bits to be robust against misprogramming
                                          1863    for i in range(qqVgaWidth):
                                          1864      ora([Y,Xpp],OUT)              #40-199 Pixel burst
                                          1865    ld(syncBits,OUT)                #0 <New scan line start> Back to black
                                          1866
                                          1867    # Front porch
                                          1868    ld([channel])                   #1 Advance to next sound channel
                                          1869    label('sound3')                 # Return from vCPU interpreter
                                          1870    anda([channelMask])             #2
                                          1871    adda(1)                         #3
                                          1872    ld(syncBits^hSync,OUT)          #4 Start horizontal pulse
                                          1873
                                          1874    # Horizontal sync and sound channel update for scanlines outside vBlank
                                          1875    label('sound2')
                                          1876    st([channel],Y)                 #5
                                          1877    ld(0x7f)                        #6
                                          1878    anda([Y,oscL])                  #7
                                          1879    adda([Y,keyL])                  #8
                                          1880    st([Y,oscL])                    #9
                                          1881    anda(0x80,X)                    #10
                                          1882    ld([X])                         #11
                                          1883    adda([Y,oscH])                  #12
                                          1884    adda([Y,keyH])                  #13
                                          1885    st([Y,oscH] )                   #14
                                          1886    anda(0xfc)                      #15
                                          1887    xora([Y,wavX])                  #16
                                          1888    ld(AC,X)                        #17
                                          1889    ld([Y,wavA])                    #18
                                          1890    ld(soundTable>>8,Y)             #19
                                          1891    adda([Y,X])                     #20
                                          1892    bmi(pc()+3)                     #21
                                          1893    bra(pc()+3)                     #22
                                          1894    anda(63)                        #23
                                          1895    ld(63)                          #23
                                          1896    adda([sample])                  #24
                                          1897    st([sample])                    #25
                                          1898
                                          1899    ld([xout])                      #26 Gets copied to XOUT
                                          1900    bra([nextVideo])                #27
                                          1901    ld(syncBits,OUT)                #28 End horizontal pulse
                                          1902
                                          1903    # Back porch B: second of 4 repeated scan lines
                                          1904    # - Recompute Xi from dXi and store for retrieval in the next scan lines
                                          1905    label('videoB')
                                          1906    ld('videoC')                    #29 2nd scanline of 4
                                          1907    st([nextVideo])                 #30
                                          1908    ld(videoTable>>8,Y)             #31
                                          1909    ld([videoY])                    #32
                                          1910    adda(1,X)                       #33
                                          1911    ld([frameX])                    #34
                                          1912    adda([Y,X])                     #35
                                          1913    bra([videoModeB])               #36
                                          1914    st([frameX],X)                  #37 Store in RAM and X
                                          1915
                                          1916    # Back porch C: third of 4 repeated scan lines
                                          1917    # - Nothing new to for video do as Yi and Xi are known,
                                          1918    # - This is the time to emit and reset the next sound sample
                                          1919    label('videoC')
                                          1920    ld('videoD')                    #29 3rd scanline of 4
                                          1921    st([nextVideo])                 #30
                                          1922    ld([sample])                    #31 New sound sample is ready (didn't fit in audio loop)
                                          1923    ora(0x0f)                       #32
                                          1924    anda([xoutMask])                #33
                                          1925    st([xout])                      #34 Update [xout] with new sample (4 channels just updated)
                                          1926    st(sample, [sample])            #35 Reset for next sample
                                          1927    bra([videoModeC])               #36
                                          1928    ld([frameX],X)                  #37
                                          1929
                                          1930    # Back porch D: last of 4 repeated scan lines
                                          1931    # - Calculate the next frame index
                                          1932    # - Decide if this is the last line or not
                                          1933    label('videoD')                 # Default video mode
                                          1934    ld([frameX], X)                 #29 4th scanline of 4
                                          1935    ld([videoY])                    #30
                                          1936    suba((120-1)*2)                 #31
                                          1937    beq('.lastpixels#34')           #32
                                          1938    adda(120*2)                     #33 More pixel lines to go
                                          1939    st([videoY])                    #34
                                          1940    ld('videoA')                    #35
                                          1941    bra([videoModeD])               #36
                                          1942    st([nextVideo])                 #37
                                          1943
                                          1944    label('.lastpixels#34')
                                          1945    if soundDiscontinuity == 1:
                                          1946      st(sample, [sample])          #34 Sound continuity
                                          1947    else:
                                          1948      nop()                         #34
                                          1949    ld('videoE')                    #35 No more pixel lines to go
                                          1950    bra([videoModeD])               #36
                                          1951    st([nextVideo])                 #37
                                          1952
                                          1953    # Back porch "E": after the last line
                                          1954    # - Go back and and enter vertical blank (program page 2)
                                          1955    label('videoE') # Exit visible area
                                          1956    ld(hi('vBlankStart'),Y)         #29 Return to vertical blank interval
                                          1957    jmp(Y,'vBlankStart')            #30
                                          1958    ld(syncBits)                    #31
                                          1959
                                          1960    # Video mode that blacks out one or more pixel lines from the top of screen.
                                          1961    # This yields some speed, but also frees up screen memory for other purposes.
                                          1962    # Note: Sound output becomes choppier the more pixel lines are skipped
                                          1963    # Note: The vertical blank driver leaves 0x80 behind in [videoSync1]
                                          1964    label('videoF')
                                          1965    ld([videoSync1])                #29 Completely black pixel line
                                          1966    adda(0x80)                      #30
                                          1967    st([videoSync1],X)              #31
                                          1968    ld([frameX])                    #32
                                          1969    suba([X])                       #33 Decrements every two VGA scanlines
                                          1970    beq('.videoF#36')               #34
                                          1971    st([frameX])                    #35
                                          1972    bra('nopixels')                 #36
                                          1973    label('.videoF#36')
                                          1974    ld('videoA')                    #36,37 Transfer to visible screen area
                                          1975    st([nextVideo])                 #37
                                          1976    #
                                          1977    # Alternative for pixel burst: faster application mode
                                          1978    label('nopixels')
                                          1979    if WITH_128K_BOARD:
                                          1980      ld([ctrlCopy],X)                #38
                                          1981      ctrl(X)                         #39
                                          1982      runVcpu_new(vVisibEnterCyc-40,  #40
                                          1983              'FBCD line 40-520')     # Application interpreter (black scanlines)
                                          1984    else:
                                          1985      runVcpu_new(vVisibEnterCyc-38,  #38
                                          1986              'FBCD line 40-520')     # Application interpreter (black scanlines)
                                          1987
                                          1988
                                          1989
                                          1990  #-----------------------------------------------------------------------
                                          1991  #
                                          1992  #  $0300 ROM page 3: Application interpreter primary page
                                          1993  #
                                          1994  #-----------------------------------------------------------------------
                                          1995
                                          1996  # Enter the timing-aware application interpreter (aka virtual CPU, vCPU)
                                          1997  #
                                          1998  # This routine will execute as many as possible instructions in the
                                          1999  # allotted time. When time runs out, it synchronizes such that the total
                                          2000  # duration matches the caller's request. Durations are counted in `ticks',
                                          2001  # which are multiples of 2 clock cycles.
                                          2002  #
                                          2003  # Synopsis: Use the runVcpu() macro as entry point
                                          2004
                                          2005  # We let 'ENTER' begin one word before the page boundary, for a bit extra
                                          2006  # precious space in the packed interpreter code page. Although ENTER's
                                          2007  # first instruction is bra() which normally doesn't cross page boundaries,
                                          2008  # in this case it will still jump into the right space, because branches
                                          2009  # from $xxFF land in the next page anyway.
                                          2010
              02fe 0200  nop              2011  fillers(until=0xff)
                                          2012  label('ENTER')
ENTER:        02ff fc03  bra  .next2      2013  bra('.next2')                   #0 Enter at '.next2' (so no startup overhead)
                                          2014  # --- Page boundary ---
                                          2015  align(0x100,size=0x100)
                                          2016  label('NEXTY')                  # Alternative for REENTER
NEXTY:        0300 1517  ld   [$17],y     2017  ld([vPC+1],Y)                   #1
                                          2018
                                          2019  # Fetch next instruction and execute it, but only if there are sufficient
                                          2020  # ticks left for the slowest instruction.
                                          2021  label('NEXT')
NEXT:         0301 8115  adda [$15]       2022  adda([vTicks])                  #0 Track elapsed ticks (actually counting down: AC<0)
              0302 e80b  blt  EXIT        2023  blt('EXIT')                     #1 Escape near time out
                                          2024  label('.next2')
.next2:       0303 c215  st   [$15]       2025  st([vTicks])                    #2
              0304 0116  ld   [$16]       2026  ld([vPC])                       #3 Advance vPC
              0305 8002  adda $02         2027  adda(2)                         #4
              0306 d216  st   [$16],x     2028  st([vPC],X)                     #5
              0307 0d00  ld   [y,x]       2029  ld([Y,X])                       #6 Fetch opcode (actually a branch target)
              0308 de00  st   [y,x++]     2030  st([Y,Xpp])                     #7 Just X++
              0309 fe00  bra  ac          2031  bra(AC)                         #8 Dispatch
              030a 0d00  ld   [y,x]       2032  ld([Y,X])                       #9 Prefetch operand
                                          2033
                                          2034  # Resync with video driver and transfer control
                                          2035  label('EXIT')
EXIT:         030b 800f  adda $0f         2036  adda(maxTicks)                  #3
                                          2037  label('RESYNC')
RESYNC:       030c e40c  bgt  RESYNC      2038  bgt(pc()&255)                   #4 Resync
              030d a001  suba $01         2039  suba(1)                         #5
              030e 1401  ld   $01,y       2040  ld(hi('vBlankStart'),Y)         #6
              030f e11e  jmp  y,[$1e]     2041  jmp(Y,[vReturn])                #7 To video driver
              0310 0102  ld   [$02]       2042  ld([channel])                   #8 with channel in AC
                                          2043  assert vCPU_overhead ==          9
                                          2044
                                          2045  # Instruction LDWI: Load immediate word constant (vAC=D), 20 cycles
                                          2046  label('LDWI')
LDWI:         0311 c218  st   [$18]       2047  st([vAC])                       #10
              0312 de00  st   [y,x++]     2048  st([Y,Xpp])                     #11 Just X++
              0313 0116  ld   [$16]       2049  ld([vPC])                       #12 Advance vPC one more
              0314 8001  adda $01         2050  adda(1)                         #13
              0315 c216  st   [$16]       2051  st([vPC])                       #14
              0316 fc28  bra  ldw#17      2052  bra('ldw#17')                   #15
              0317 0d00  ld   [y,x]       2053  ld([Y,X])                       #16 Fetch second operand
                                          2054
                                          2055  # Instruction NEGV (18 vv) [26 cycles]
                                          2056  # * Negates word [vv]:=-[vv]
                                          2057  label('NEGV_v7')
NEGV_v7:      0318 141f  ld   $1f,y       2058  ld(hi('negv#13'),Y)             #10
              0319 e0e3  jmp  y,$e3       2059  jmp(Y,'negv#13')                #11+overlap
                                          2060
                                          2061  # Instruction LD: Load byte from zero page (vAC=[D]), 18 cycles
                                          2062  label('LD')
LD:           031a 1200  ld   ac,x        2063  ld(AC,X)                        #10
              031b fcc1  bra  ld#13       2064  bra('ld#13')                    #11
              031c 0500  ld   [x]         2065  ld([X])                         #13
                                          2066
                                          2067  # Helper for INC.
                                          2068  label('inc#14')
inc#14:       031d fcc4  bra  ld#16       2069  bra('ld#16')                    #14
              031e c600  st   [x]         2070  st([X])                         #15
                                          2071
                                          2072  # Instruction CMPHS: Adjust high byte for signed compare (vACH=XXX), 20-26 cycles
                                          2073  label('CMPHS_v5')
CMPHS_v5:     031f 140b  ld   $0b,y       2074  ld(hi('cmphs#13'),Y)            #10
              0320 e0d8  jmp  y,$d8       2075  jmp(Y,'cmphs#13')               #11
                                          2076  #ld(AC,X)                       #12 Overlap
                                          2077  #
                                          2078  # Instruction LDW: Load word from zero page (vAC=[D]+256*[D+1]), 20 cycles
                                          2079  label('LDW')
LDW:          0321 1200  ld   ac,x        2080  ld(AC,X)                        #10,12
              0322 8001  adda $01         2081  adda(1)                         #11
              0323 c22f  st   [$2f]       2082  st([vTmp])                      #12 Address of high byte
              0324 0500  ld   [x]         2083  ld([X])                         #13
              0325 112f  ld   [$2f],x     2084  ld([vTmp],X)                    #14
              0326 c218  st   [$18]       2085  st([vAC])                       #15
              0327 0500  ld   [x]         2086  ld([X])                         #16
                                          2087  label('ldw#17')
ldw#17:       0328 c219  st   [$19]       2088  st([vAC+1])                     #17
              0329 fc01  bra  NEXT        2089  bra('NEXT')                     #18
              032a 00f6  ld   $f6         2090  ld(-20/2)                       #19
                                          2091
                                          2092  # Instruction STW: Store word in zero page ([D],[D+1]=vAC&255,vAC>>8), 20 cycles
                                          2093  label('STW')
STW:          032b 1200  ld   ac,x        2094  ld(AC,X)                        #10
              032c 1400  ld   $00,y       2095  ld(0,Y)                         #11
              032d 0118  ld   [$18]       2096  ld([vAC])                       #12
              032e de00  st   [y,x++]     2097  st([Y,Xpp])                     #13
              032f 0119  ld   [$19]       2098  ld([vAC+1])                     #14
              0330 ce00  st   [y,x]       2099  st([Y,X])                       #15
              0331 fccb  bra  REENTER     2100  bra('REENTER')                  #16
              0332 00f6  ld   $f6         2101  ld(-20/2)                       #17
                                          2102
                                          2103  # Instruction ADDHI (33 xx), 16 cycles
                                          2104  # * Add constant xx to vACH.
                                          2105  # * To be used in conjunction with ADDI add a 16 bits constant
                                          2106  label('ADDHI_v7')
ADDHI_v7:     0333 fc5b  bra  ldi#12      2107  bra('ldi#12')
              0334 8119  adda [$19]       2108  adda([vAC+1])
                                          2109
                                          2110  # Instruction PREFIX35: (used to be BCC)
                                          2111  label('BCC')
                                          2112  label('PREFIX35')
BCC:
PREFIX35:     0335 de00  st   [y,x++]     2113  st([Y,Xpp])                     #10
              0336 1417  ld   $17,y       2114  ld(hi('PREFIX35_PAGE'),Y)       #11
              0337 e200  jmp  y,ac        2115  jmp(Y,AC)                       #12
              0338 1517  ld   [$17],y     2116  ld([vPC+1],Y)                   #13
                                          2117
                                          2118  # Instruction POKEA (39 xx), 22 cycles
                                          2119  # * Store word [xx] at location [vAC]
                                          2120  # * Origin: https://forum.gigatron.io/viewtopic.php?p=2053#p2053
                                          2121  #   Section 2. "POKE and DOKE work backwards"
                                          2122  label('POKEA_v7')
POKEA_v7:     0339 1419  ld   $19,y       2123  ld(hi('pokea#13'),Y)            #10,12
              033a e000  jmp  y,$00       2124  jmp(Y,'pokea#13')               #11
                                          2125
                                          2126  # Instruction DOKEA (3b xx), 28 cycles
                                          2127  # * Store word [xx] at location [vAC]
                                          2128  # * Origin: https://forum.gigatron.io/viewtopic.php?p=2053#p2053
                                          2129  #   Section 2. "POKE and DOKE work backwards"
                                          2130  label('DOKEA_v7')
DOKEA_v7:     033b 1419  ld   $19,y       2131  ld(hi('dokea#13'),Y)            #10
              033c e008  jmp  y,$08       2132  jmp(Y,'dokea#13')               #11+overlap
                                          2133
                                          2134  # Instruction DEEKA (3d xx), 30 cycles
                                          2135  # * Load word at location [vAC] and store into [xx]
                                          2136  # * Trashes sysArgs7 but can DEEK(sysArgs6or7)
                                          2137  # * Origin: https://forum.gigatron.io/viewtopic.php?p=2053#p2053
                                          2138  #   Section 2. "POKE and DOKE work backwards"
                                          2139  label('DEEKA_v7')
DEEKA_v7:     033d 1419  ld   $19,y       2140  ld(hi('deeka#13'),Y)            #10,12
              033e e016  jmp  y,$16       2141  jmp(Y,'deeka#13')               #11
                                          2142
                                          2143  # Instruction JEQ (3f ll hh), 24/26 cycles (was EQ)
                                          2144  # * Branch if zero (if(vACL==0)vPC=hhll[+2])
                                          2145  # * Original idea from at67
                                          2146  label('EQ')
                                          2147  label('JEQ_v7')
EQ:
JEQ_v7:       033f 1419  ld   $19,y       2148  ld(hi('jeq#13'),Y)              #10,12
              0340 e0cd  jmp  y,$cd       2149  jmp(Y,'jeq#13')                 #11
                                          2150
                                          2151  # Instruction DEEKV (41 vv), 28 cycles
                                          2152  # * shortcut for LDW(vv);DEEK()
                                          2153  # * Original idea from at67
                                          2154  label('DEEKV_v7')
DEEKV_v7:     0341 1419  ld   $19,y       2155  ld(hi('deekv#13'),Y)            #10,12
              0342 e042  jmp  y,$42       2156  jmp(Y,'deekv#13')               #11
              0343 c22f  st   [$2f]       2157  st([vTmp])                      #12
                                          2158
                                          2159  # Instruction DOKEQ (44 ii), 22 cycles
                                          2160  # * Store immediate ii into word pointed by vAC
                                          2161  label('DOKEQ_v7')
DOKEQ_v7:     0344 1419  ld   $19,y       2162  ld(hi('dokeq#13'),Y)            #10,12
              0345 e02c  jmp  y,$2c       2163  jmp(Y,'dokeq#13')               #11
                                          2164
                                          2165  # Instruction POKEQ (46 ii), 20 cycles
                                          2166  # * Store immediate ii into byte pointed by vAC
                                          2167  label('POKEQ_v7')
POKEQ_v7:     0346 1419  ld   $19,y       2168  ld(hi('pokeq#13'),Y)            #10,12
              0347 e026  jmp  y,$26       2169  jmp(Y,'pokeq#13')               #11
                                          2170
                                          2171  # Instruction MOVQB (48 vv ii), 26 cycles
                                          2172  # * Store immediate ii into byte [vv]:=ii
                                          2173  label('MOVQB_v7')
MOVQB_v7:     0348 1420  ld   $20,y       2174  ld(hi('movqb#13'),Y)            #10
              0349 e083  jmp  y,$83       2175  jmp(Y,'movqb#13')               #11
                                          2176
                                          2177  # Instruction MOVQW (4a vv ii), 28 cycles
                                          2178  # * Store immediate ii into word [vv]:=ii [vv+1]:=0
                                          2179  label('MOVQW_v7')
MOVQW_v7:     034a 1420  ld   $20,y       2180  ld(hi('movqw#13'),Y)            #10
              034b e08f  jmp  y,$8f       2181  jmp(Y,'movqw#13')               #11
              034c 1517  ld   [$17],y     2182  ld([vPC+1],Y)                   #12
                                          2183
                                          2184  # Instruction JGT (4d ll hh), 22-24/26 cycles (was GT)
                                          2185  # * Branch if positive (if(vACL>0)vPC=hhll[+2])
                                          2186  # * Original idea from at67
                                          2187  label('GT')
