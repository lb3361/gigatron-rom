                                          2779  # ORW implementation
                                          2780  label('orw')
orw:          047b c22f  st   [$2f]       2781  st([vTmp])                      #13
              047c 9001  adda $01,x       2782  adda(1,X)                       #14
              047d 0500  ld   [x]         2783  ld([X])                         #15
              047e 4119  ora  [$19]       2784  ora([vAC+1])                    #16
              047f c219  st   [$19]       2785  st([vAC+1])                     #17
              0480 112f  ld   [$2f],x     2786  ld([vTmp],X)                    #18
              0481 0500  ld   [x]         2787  ld([X])                         #19
              0482 4118  ora  [$18]       2788  ora([vAC])                      #20
