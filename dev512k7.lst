                                          7307  # Entry point
                                          7308  # - Note that sysFn must be set to 0x0001 before this
                                          7309  label('se:exec')
se:exec:      1672 fc28  bra  fsm16:LUP   7310  fsmAsm('LUP')
              1673 0074  ld   $74
              1674 fc0a  bra  fsm16:ST    7311  fsmAsm('ST', sysArgs+3)
              1675 0027  ld   $27
              1676 fc17  bra  fsm16:BNZ   7312  fsmAsm('BNZ', 'se:loadGt1:al')
              1677 004c  ld   $4c
              1678 fc28  bra  fsm16:LUP   7313  fsmAsm('LUP')
              1679 007a  ld   $7a
              167a fc0a  bra  fsm16:ST    7314  fsmAsm('ST', sysArgs+2)
              167b 0026  ld   $26
              167c fc0e  bra  fsm16:ADD   7315  fsmAsm('ADD', 1)
              167d 0001  ld   $01
              167e fc17  bra  fsm16:BNZ   7316  fsmAsm('BNZ', 'se:loadGt1:len')
              167f 0050  ld   $50
              1680 fc28  bra  fsm16:LUP   7317  fsmAsm('LUP')                   # hi segment address
              1681 0082  ld   $82
              1682 fc1d  bra  fsm16:BL    7318  fsmAsm('B','se:loadGt1z')
              1683 0088  ld   $88
