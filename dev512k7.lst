vBlankFirst#92:
              1213 1401  ld   $01,y       5873  ld(1,Y)                         #92
              1214 0116  ld   [$16]       5874  ld([vPC])                       #93
              1215 c230  st   [$30]       5875  st([vIrqSave+0])                #94 Save vPC
              1216 0117  ld   [$17]       5876  ld([vPC+1])                     #95
              1217 c231  st   [$31]       5877  st([vIrqSave+1])                #96
              1218 0118  ld   [$18]       5878  ld([vAC])                       #97 Save vAC
              1219 c232  st   [$32]       5879  st([vIrqSave+2])                #98
              121a 0119  ld   [$19]       5880  ld([vAC+1])                     #99
              121b c233  st   [$33]       5881  st([vIrqSave+3])                #100
              121c 0105  ld   [$05]       5882  ld([vCpuSelect])                #101 Save vCpuSelect
              121d c234  st   [$34]       5883  st([vIrqSave+4])                #102
              121e 09f6  ld   [y,$f6]     5884  ld([Y,vIRQ_v5])                 #103 Set vPC to vIRQ
              121f a002  suba $02         5885  suba(2)                         #104
              1220 c216  st   [$16]       5886  st([vPC])                       #105
              1221 09f7  ld   [y,$f7]     5887  ld([Y,vIRQ_v5+1])               #106
              1222 c217  st   [$17]       5888  st([vPC+1])                     #107
              1223 0002  ld   $02         5889  ld(hi('ENTER'))                 #108 Set vCpuSelect to ENTER (=regular vCPU)
              1224 c205  st   [$05]       5890  st([vCpuSelect])                #109
              1225 1505  ld   [$05],y     5891  runVcpu_new(vBlankEnterCyc-vBlankFirstExtra-110,
