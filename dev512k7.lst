                                          2613  label('CMPWS_v7')
CMPWS_v7:     03d3 1419  ld   $19,y       2614  ld(hi('cmpws#13'),Y)            #10
              03d4 e06f  jmp  y,$6f       2615  jmp(Y,'cmpws#13')               #11
