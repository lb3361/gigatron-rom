                                          4706  # Fetch opcode
              0e23 111a  ld   [$1a],x     4707  ld([v6502_PCL],X)               #3
              0e24 151b  ld   [$1b],y     4708  ld([v6502_PCH],Y)               #4
              0e25 0d00  ld   [y,x]       4709  ld([Y,X])                       #5 Fetch IR
              0e26 c226  st   [$26]       4710  st([v6502_IR])                  #6
              0e27 011a  ld   [$1a]       4711  ld([v6502_PCL])                 #7 PC++
              0e28 8001  adda $01         4712  adda(1)                         #8
              0e29 d21a  st   [$1a],x     4713  st([v6502_PCL],X)               #9
              0e2a f02d  beq  $0e2d       4714  beq(pc()+3)                     #10
              0e2b fc2e  bra  $0e2e       4715  bra(pc()+3)                     #11
              0e2c 0000  ld   $00         4716  ld(0)                           #12
              0e2d 0001  ld   $01         4717  ld(1)                           #12(!)
              0e2e 811b  adda [$1b]       4718  adda([v6502_PCH])               #13
              0e2f d61b  st   [$1b],y     4719  st([v6502_PCH],Y)               #14
                                          4720  #
                                          4721  # Get addressing mode and fetch operands
              0e30 0126  ld   [$26]       4722  ld([v6502_IR])                  #15 Get addressing mode
              0e31 201f  anda $1f         4723  anda(31)                        #16
              0e32 fe00  bra  ac          4724  bra(AC)                         #17
              0e33 fc34  bra  .next20     4725  bra('.next20')                  #18
                                          4726  # (jump table)                  #19
                                          4727  label('.next20')
.next20:      0e34 0d00  ld   [y,x]       4728  ld([Y,X])                       #20 Fetch L
                                          4729  # Most opcodes branch away at this point, but IR & 31 == 0 falls through
                                          4730  #
                                          4731  # Implicit Mode for  BRK JSR RTI RTS (<  0x80) -- 26 cycles
                                          4732  # Immediate Mode for LDY CPY CPX     (>= 0x80) -- 36 cycles
                                          4733  label('v6502_mode0')
v6502_mode0:  0e35 0126  ld   [$26]       4734  ld([v6502_IR])                  #21 'xxx0000'
              0e36 e845  blt  .imm24      4735  bmi('.imm24')                   #22
              0e37 011b  ld   [$1b]       4736  ld([v6502_PCH])                 #23
              0e38 fcf2  bra  v6502_check 4737  bra('v6502_check')              #24
              0e39 00f3  ld   $f3         4738  ld(-26/2)                       #25
                                          4739
                                          4740  # Resync with video driver. At this point we're returning BEFORE
                                          4741  # fetching and executing the next instruction.
