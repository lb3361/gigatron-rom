                                          2764  # ANDW implementation
                                          2765  label('andw')
andw:         046f c22f  st   [$2f]       2766  st([vTmp])                      #13
              0470 9001  adda $01,x       2767  adda(1,X)                       #14
              0471 0500  ld   [x]         2768  ld([X])                         #15
              0472 2119  anda [$19]       2769  anda([vAC+1])                   #16
              0473 c219  st   [$19]       2770  st([vAC+1])                     #17
              0474 112f  ld   [$2f],x     2771  ld([vTmp],X)                    #18
              0475 0500  ld   [x]         2772  ld([X])                         #19
              0476 2118  anda [$18]       2773  anda([vAC])                     #20
              0477 c218  st   [$18]       2774  st([vAC])                       #21
              0478 1403  ld   $03,y       2775  ld(hi('NEXTY'),Y)               #22
              0479 e000  jmp  y,$00       2776  jmp(Y,'NEXTY')                  #23
              047a 00f3  ld   $f3         2777  ld(-26/2)                       #24
