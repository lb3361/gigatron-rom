                                          5895  #-----------------------------------------------------------------------
                                          5896  #       Extended vertical blank logic: game controller decoding
                                          5897  #-----------------------------------------------------------------------
                                          5898
                                          5899  # Entered last line of vertical blank (line 40)
                                          5900  label('vBlankLast#34')
                                          5901
                                          5902  # Game controller types
                                          5903  # TypeA: Based on 74LS165 shift register (not supported)
                                          5904  # TypeB: Based on CD4021B shift register (standard)
                                          5905  # TypeC: Based on priority encoder
                                          5906  #
                                          5907  # Notes:
                                          5908  # - TypeA was only used during development and first beta test, before ROM v1
                                          5909  # - TypeB appears as type A with negative logic levels
                                          5910  # - TypeB is the game controller type that comes with the original kit and ROM v1
                                          5911  # - TypeB is mimicked by BabelFish / Pluggy McPlugface
                                          5912  # - TypeB requires a prolonged /SER_LATCH, therefore vPulse is 8 scanlines, not 2
                                          5913  # - TypeB and TypeC can be sampled in the same scanline
                                          5914  # - TypeA is 1 scanline shifted as it looks at a different edge (XXX up or down?)
                                          5915  # - TypeC gives incomplete information: lower buttons overshadow higher ones
                                          5916  #
                                          5917  #       TypeC    Alias    Button TypeB
                                          5918  #       00000000  ^@   -> Right  11111110
                                          5919  #       00000001  ^A   -> Left   11111101
                                          5920  #       00000011  ^C   -> Down   11111011
                                          5921  #       00000111  ^G   -> Up     11110111
                                          5922  #       00001111  ^O   -> Start  11101111
                                          5923  #       00011111  ^_   -> Select 11011111
                                          5924  #       00111111  ?    -> B      10111111
                                          5925  #       01111111  DEL  -> A      01111111
                                          5926  #       11111111       -> (None) 11111111
                                          5927  #
                                          5928  #       Conversion formula:
                                          5929  #               f(x) := 254 - x
                                          5930
                                          5931  # Detect controller TypeC codes
vBlankLast#34:
              1228 010f  ld   [$0f]       5932  ld([serialRaw])                 #34 if serialRaw in [0,1,3,7,15,31,63,127,255]
              1229 8001  adda $01         5933  adda(1)                         #35
              122a 210f  anda [$0f]       5934  anda([serialRaw])               #36
              122b ec3c  bne  .buttons#39 5935  bne('.buttons#39')              #37
                                          5936
                                          5937  # TypeC
              122c 010f  ld   [$0f]       5938  ld([serialRaw])                 #38 [TypeC] if serialRaw < serialLast
              122d 8001  adda $01         5939  adda(1)                         #39
              122e 2110  anda [$10]       5940  anda([serialLast])              #40
              122f ec33  bne  .buttons#43 5941  bne('.buttons#43')              #41
              1230 00fe  ld   $fe         5942  ld(254)                         #42 then clear the selected bit
              1231 0200  nop              5943  nop()                           #43
              1232 fc36  bra  .buttons#46 5944  bra('.buttons#46')              #44
                                          5945  label('.buttons#43')
.buttons#43:  1233 a10f  suba [$0f]       5946  suba([serialRaw])               #43,45
              1234 2111  anda [$11]       5947  anda([buttonState])             #44
              1235 c211  st   [$11]       5948  st([buttonState])               #45
                                          5949  label('.buttons#46')
.buttons#46:  1236 010f  ld   [$0f]       5950  ld([serialRaw])                 #46 Set the lower bits
              1237 4111  ora  [$11]       5951  ora([buttonState])              #47
                                          5952  label('.buttons#48')
.buttons#48:  1238 c211  st   [$11]       5953  st([buttonState])               #48
              1239 010f  ld   [$0f]       5954  ld([serialRaw])                 #49 Update serialLast for next pass
              123a e0ae  jmp  y,$ae       5955  jmp(Y,'vBlankLast#52')          #50
              123b c210  st   [$10]       5956  st([serialLast])                #51
                                          5957
                                          5958  # TypeB
                                          5959  # pChange = pNew & ~pOld
                                          5960  # nChange = nNew | ~nOld {DeMorgan}
                                          5961  label('.buttons#39')
.buttons#39:  123c 00ff  ld   $ff         5962  ld(255)                         #39 [TypeB] Bitwise edge-filter to detect button presses
              123d 6110  xora [$10]       5963  xora([serialLast])              #40
              123e 410f  ora  [$0f]       5964  ora([serialRaw])                #41 Catch button-press events
              123f 2111  anda [$11]       5965  anda([buttonState])             #42 Keep active button presses
              1240 410f  ora  [$0f]       5966  ora([serialRaw])                #43
              1241 0200  nop              5967  nop()                           #44
              1242 0200  nop              5968  nop()                           #45
              1243 fc38  bra  .buttons#48 5969  bra('.buttons#48')              #46
              1244 0200  nop              5970  nop()                           #47
