                                          2535  # The instructions below are all implemented in the second code page. Jumping
                                          2536  # back and forth makes each 6 cycles slower, but it also saves space in the
                                          2537  # primary page for the instructions above. Most of them are in fact not very
                                          2538  # critical, as evidenced by the fact that they weren't needed for the first
                                          2539  # Gigatron applications (Snake, Racer, Mandelbrot, Loader). By providing them
                                          2540  # in this way, at least they don't need to be implemented as a SYS extension.
                                          2541
                                          2542  # Instruction ADDI: Add small positive constant (vAC+=D), 24-26 cycles
                                          2543  label('ADDI')
ADDI:         03e3 1404  ld   $04,y       2544  ld(hi('addi#13'),Y)             #10,12
              03e4 e01c  jmp  y,$1c       2545  jmp(Y,'addi#13')                #11
              03e5 c22f  st   [$2f]       2546  st([vTmp])                      #12
                                          2547
                                          2548  # Instruction SUBI: Subtract small positive constant (vAC+=D), 24-26 cycles
                                          2549  label('SUBI')
SUBI:         03e6 1420  ld   $20,y       2550  ld(hi('subi#13'),Y)             #10
              03e7 e09d  jmp  y,$9d       2551  jmp(Y,'subi#13')                #11
              03e8 c22f  st   [$2f]       2552  st([vTmp])                      #12
                                          2553
                                          2554  # Instruction LSLW: Logical shift left (vAC<<=1), 26-28 cycles
                                          2555  # Useful, because ADDW can't add vAC to itself. Also more compact.
                                          2556  label('LSLW')
LSLW:         03e9 1404  ld   $04,y       2557  ld(hi('lslw#13'),Y)             #10
              03ea e02d  jmp  y,$2d       2558  jmp(Y,'lslw#13')                #11
              03eb 0116  ld   [$16]       2559  ld([vPC])                       #12
                                          2560
                                          2561  # Instruction STLW: (ec xx) 26 cycles (36 when vSPH!=0)
                                          2562  # * Store word in stack frame: *(vSP + xx) := vAC
                                          2563  label('STLW')
STLW:         03ec 141f  ld   $1f,y       2564  ld(hi('stlw#13'),Y)             #10
              03ed e068  jmp  y,$68       2565  jmp(Y,'stlw#13')                #11
                                          2566  #dummy()                        #12 Overlap
                                          2567  #
                                          2568  # Instruction LDLW: (ee xx) 26 cycles (36/38 when vSPH!=0)
                                          2569  # * Load word from stack frame: vAC := *(vSP + xx)
                                          2570  label('LDLW')
LDLW:         03ee 141f  ld   $1f,y       2571  ld(hi('ldlw#13'),Y)             #10,12
              03ef e08a  jmp  y,$8a       2572  jmp(Y,'ldlw#13')                #11
                                          2573  #st([vTmp])                     #12 Overlap
                                          2574  #
                                          2575  # Instruction POKE: Write byte in memory ([[D+1],[D]]=vAC&255), 28 cycles
                                          2576  label('POKE')
POKE:         03f0 c22f  st   [$2f]       2577  st([vTmp])                      #10,12
              03f1 1404  ld   $04,y       2578  ld(hi('poke#14'),Y)             #11
              03f2 e03f  jmp  y,$3f       2579  jmp(Y,'poke#14')                #12 Overlap
                                          2580
                                          2581  # Instruction DOKE: Write word in memory ([[D+1],[D]],[[D+1],[D]+1]=vAC&255,vAC>>8), 28 cycles
                                          2582  label('DOKE')
DOKE:         03f3 1404  ld   $04,y       2583  ld(hi('doke'),Y)                #10,13
              03f4 e056  jmp  y,$56       2584  jmp(Y,'doke')                   #11
              03f5 c22f  st   [$2f]       2585  st([vTmp])                      #12
                                          2586
                                          2587  # Instruction DEEK: Read word from memory (vAC=[vAC]+256*[vAC+1]), 28 cycles
                                          2588  label('DEEK')
DEEK:         03f6 1404  ld   $04,y       2589  ld(hi('deek'),Y)                #10
              03f7 e063  jmp  y,$63       2590  jmp(Y,'deek')                   #11
                                          2591  #dummy()                        #12 Overlap
                                          2592  #
                                          2593  # Instruction ANDW: Word logical-AND with zero page (vAC&=[D]+256*[D+1]), 28 cycles
                                          2594  label('ANDW')
ANDW:         03f8 1404  ld   $04,y       2595  ld(hi('andw'),Y)                #10,12
              03f9 e06f  jmp  y,$6f       2596  jmp(Y,'andw')                   #11
                                          2597  #dummy()                        #12 Overlap
                                          2598  #
                                          2599  # Instruction ORW: Word logical-OR with zero page (vAC|=[D]+256*[D+1]), 28 cycles
                                          2600  label('ORW')
ORW:          03fa 1404  ld   $04,y       2601  ld(hi('orw'),Y)                 #10,12
              03fb e07b  jmp  y,$7b       2602  jmp(Y,'orw')                    #11
                                          2603  #dummy()                        #12 Overlap
                                          2604  #
                                          2605  # Instruction XORW: Word logical-XOR with zero page (vAC^=[D]+256*[D+1]), 26 cycles
                                          2606  label('XORW')
XORW:         03fc 1404  ld   $04,y       2607  ld(hi('xorw'),Y)                #10,12
              03fd e087  jmp  y,$87       2608  jmp(Y,'xorw')                   #11
              03fe c22f  st   [$2f]       2609  st([vTmp])                      #12
                                          2610
                                          2611  # Instruction RET: Function return (vPC=vLR-2), 20 cycles
                                          2612  label('RET')
RET:          03ff 011a  ld   [$1a]       2613  ld([vLR])                       #10
                                          2614  assert pc()&255 == 0
                                          2615
                                          2616  #-----------------------------------------------------------------------
                                          2617  #
                                          2618  #  $0400 ROM page 4: Application interpreter extension
                                          2619  #
                                          2620  #-----------------------------------------------------------------------
                                          2621  align(0x100, size=0x100)
                                          2622
                                          2623  # (Continue RET)
              0400 a002  suba $02         2624  suba(2)                         #11
              0401 c216  st   [$16]       2625  st([vPC])                       #12
              0402 011b  ld   [$1b]       2626  ld([vLR+1])                     #13
              0403 c217  st   [$17]       2627  st([vPC+1])                     #14
              0404 1403  ld   $03,y       2628  ld(hi('REENTER'),Y)             #15
              0405 e0cb  jmp  y,$cb       2629  jmp(Y,'REENTER')                #16
              0406 00f6  ld   $f6         2630  ld(-20/2)                       #17
                                          2631
                                          2632  # DEF implementation
                                          2633  label('def#13')
def#13:       0407 0116  ld   [$16]       2634  ld([vPC])                       #13
              0408 8002  adda $02         2635  adda(2)                         #14
              0409 c218  st   [$18]       2636  st([vAC])                       #15
              040a 0117  ld   [$17]       2637  ld([vPC+1])                     #16
              040b c219  st   [$19]       2638  st([vAC+1])                     #17
              040c 012f  ld   [$2f]       2639  ld([vTmp])                      #18
              040d c216  st   [$16]       2640  st([vPC])                       #19
              040e 1403  ld   $03,y       2641  ld(hi('NEXTY'),Y)               #20
              040f e000  jmp  y,$00       2642  jmp(Y,'NEXTY')                  #21
              0410 00f4  ld   $f4         2643  ld(-24/2)                       #22
                                          2644
                                          2645  # LDSB implementation
                                          2646  label('ldsb#13')
ldsb#13:      0411 1200  ld   ac,x        2647  ld(AC,X)                        #13
              0412 0500  ld   [x]         2648  ld([X])                         #14
              0413 c218  st   [$18]       2649  st([vAC])                       #15
              0414 e817  blt  $0417       2650  bmi(pc()+3)                     #16
              0415 fc18  bra  $0418       2651  bra(pc()+3)                     #17
              0416 0000  ld   $00         2652  ld(0)                           #18
              0417 00ff  ld   $ff         2653  ld(0xff)                        #18
              0418 c219  st   [$19]       2654  st([vAC+1])                     #19
              0419 1403  ld   $03,y       2655  ld(hi('NEXTY'),Y)               #20
              041a e000  jmp  y,$00       2656  jmp(Y,'NEXTY')                  #21
              041b 00f4  ld   $f4         2657  ld(-24/2)                       #22
                                          2658
                                          2659  # ADDI implementation
                                          2660  label('addi#13')
addi#13:      041c 1403  ld   $03,y       2661  ld(hi('NEXTY'),Y)               #13
              041d 8118  adda [$18]       2662  adda([vAC])                     #14
              041e c218  st   [$18]       2663  st([vAC])                       #15 Store low result
              041f e826  blt  .addi#18    2664  bmi('.addi#18')                 #16 Now figure out if there was a carry
              0420 a12f  suba [$2f]       2665  suba([vTmp])                    #17 Gets back the initial value of vAC
              0421 412f  ora  [$2f]       2666  ora([vTmp])                     #18 Carry in bit 7
              0422 e829  blt  .addi#21c   2667  bmi('.addi#21c')                #19
              0423 0001  ld   $01         2668  ld(1)                           #20
                                          2669  label('.addi#21n')
.addi#21n:    0424 e000  jmp  y,$00       2670  jmp(Y,'NEXTY')                  #21
              0425 00f4  ld   $f4         2671  ld(-24/2)                       #22
                                          2672  label('.addi#18')
.addi#18:     0426 212f  anda [$2f]       2673  anda([vTmp])                    #18 Carry in bit 7
              0427 f424  bge  .addi#21n   2674  bpl('.addi#21n')                #19
              0428 0001  ld   $01         2675  ld(1)                           #20
                                          2676  label('.addi#21c')
.addi#21c:    0429 8119  adda [$19]       2677  adda([vAC+1])                   #21 Add the high bytes with carry
              042a c219  st   [$19]       2678  st([vAC+1])                     #22 Store high result
              042b e000  jmp  y,$00       2679  jmp(Y,'NEXTY')                  #24
              042c 00f3  ld   $f3         2680  ld(-26/2)                       #25
                                          2681
                                          2682  # LSLW implementation
                                          2683  label('lslw#13')
lslw#13:      042d a001  suba $01         2684  suba(1)                         #13
              042e c216  st   [$16]       2685  st([vPC])                       #14
              042f 0118  ld   [$18]       2686  ld([vAC])                       #15
              0430 1403  ld   $03,y       2687  ld(hi('NEXTY'),Y)               #16
              0431 e839  blt  lslw#19     2688  bmi('lslw#19')                  #17
              0432 8200  adda ac          2689  adda(AC)                        #18
              0433 c218  st   [$18]       2690  st([vAC])                       #19
              0434 0119  ld   [$19]       2691  ld([vAC+1])                     #20
              0435 8200  adda ac          2692  adda(AC)                        #21
              0436 c219  st   [$19]       2693  st([vAC+1])                     #22
              0437 e000  jmp  y,$00       2694  jmp(Y,'NEXTY')                  #23
              0438 00f3  ld   $f3         2695  ld(-26/2)                       #24
                                          2696  label('lslw#19')
lslw#19:      0439 c218  st   [$18]       2697  st([vAC])                       #19
              043a 0119  ld   [$19]       2698  ld([vAC+1])                     #20
              043b 8200  adda ac          2699  adda(AC)                        #21
              043c 8001  adda $01         2700  adda(1)                         #22
              043d e0ca  jmp  y,$ca       2701  jmp(Y,'REENTER_28')             #23
              043e c219  st   [$19]       2702  st([vAC+1])                     #24
                                          2703
                                          2704  # POKE implementation
                                          2705  label('poke#14')
poke#14:      043f 9001  adda $01,x       2706  adda(1,X)                       #14
              0440 0500  ld   [x]         2707  ld([X])                         #15
              0441 1600  ld   ac,y        2708  ld(AC,Y)                        #16
              0442 112f  ld   [$2f],x     2709  ld([vTmp],X)                    #17
              0443 0500  ld   [x]         2710  ld([X])                         #18
              0444 1200  ld   ac,x        2711  ld(AC,X)                        #19
              0445 0118  ld   [$18]       2712  ld([vAC])                       #20
              0446 ce00  st   [y,x]       2713  st([Y,X])                       #21
              0447 1403  ld   $03,y       2714  ld(hi('NEXTY'),Y)               #22
              0448 e000  jmp  y,$00       2715  jmp(Y,'NEXTY')                  #23
              0449 00f3  ld   $f3         2716  ld(-26/2)                       #24
                                          2717
                                          2718  # PEEK implementation
                                          2719  label('peek')
peek:         044a 0116  ld   [$16]       2720  ld([vPC])                       #13
              044b a001  suba $01         2721  suba(1)                         #14
              044c c216  st   [$16]       2722  st([vPC])                       #15
              044d 1118  ld   [$18],x     2723  ld([vAC],X)                     #16
              044e 1519  ld   [$19],y     2724  ld([vAC+1],Y)                   #17
              044f 0d00  ld   [y,x]       2725  ld([Y,X])                       #18
              0450 c218  st   [$18]       2726  st([vAC])                       #19
              0451 0000  ld   $00         2727  ld(0)                           #20
              0452 c219  st   [$19]       2728  st([vAC+1])                     #21
              0453 1403  ld   $03,y       2729  ld(hi('NEXTY'),Y)               #22
              0454 e000  jmp  y,$00       2730  jmp(Y,'NEXTY')                  #23
              0455 00f3  ld   $f3         2731  ld(-26/2)                       #24
                                          2732
                                          2733  # DOKE implementation
                                          2734  label('doke')
doke:         0456 9001  adda $01,x       2735  adda(1,X)                       #13
              0457 0500  ld   [x]         2736  ld([X])                         #14
              0458 1600  ld   ac,y        2737  ld(AC,Y)                        #15
              0459 112f  ld   [$2f],x     2738  ld([vTmp],X)                    #16
              045a 0500  ld   [x]         2739  ld([X])                         #17
              045b 1200  ld   ac,x        2740  ld(AC,X)                        #18
              045c 0118  ld   [$18]       2741  ld([vAC])                       #19
              045d de00  st   [y,x++]     2742  st([Y,Xpp])                     #20
              045e 0119  ld   [$19]       2743  ld([vAC+1])                     #21
              045f ce00  st   [y,x]       2744  st([Y,X])                       #22 Incompatible with REENTER_28
              0460 1403  ld   $03,y       2745  ld(hi('REENTER'),Y)             #23
              0461 e0cb  jmp  y,$cb       2746  jmp(Y,'REENTER')                #24
              0462 00f2  ld   $f2         2747  ld(-28/2)                       #25
                                          2748
                                          2749  # DEEK implementation
                                          2750  label('deek')
deek:         0463 0116  ld   [$16]       2751  ld([vPC])                       #13
              0464 a001  suba $01         2752  suba(1)                         #14
              0465 c216  st   [$16]       2753  st([vPC])                       #15
              0466 1118  ld   [$18],x     2754  ld([vAC],X)                     #16
              0467 1519  ld   [$19],y     2755  ld([vAC+1],Y)                   #17
              0468 0d00  ld   [y,x]       2756  ld([Y,X])                       #18
              0469 de00  st   [y,x++]     2757  st([Y,Xpp])                     #19 Just X++
              046a c218  st   [$18]       2758  st([vAC])                       #20
              046b 0d00  ld   [y,x]       2759  ld([Y,X])                       #21
              046c 1403  ld   $03,y       2760  ld(hi('REENTER_28'),Y)          #22
              046d e0ca  jmp  y,$ca       2761  jmp(Y,'REENTER_28')             #23
              046e c219  st   [$19]       2762  st([vAC+1])                     #24
