REENTER_28:   03ca 00f2  ld   $f2         2593  ld(-28/2)                       #25
                                          2594  label('REENTER')
REENTER:      03cb fc01  bra  NEXT        2595  bra('NEXT')                     #26 Return from SYS calls
              03cc 1517  ld   [$17],y     2596  ld([vPC+1],Y)                   #27
