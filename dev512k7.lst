                                          2648  # Instruction PEEKA (e1 xx), 24 cycles
                                          2649  # * Load byte at location [vAC] and store into byte [xx]
                                          2650  # * Origin: https://forum.gigatron.io/viewtopic.php?p=2053#p2053
                                          2651  #   Section 2. "POKE and DOKE work backwards"
                                          2652  label('PEEKA_v7')
PEEKA_v7:     03e1 140b  ld   $0b,y       2653  ld(hi('peeka#13'),Y)            #10,12
              03e2 e0f2  jmp  y,$f2       2654  jmp(Y,'peeka#13')               #11
                                          2655
                                          2656  # The instructions below are all implemented in the second code page. Jumping
                                          2657  # back and forth makes each 6 cycles slower, but it also saves space in the
                                          2658  # primary page for the instructions above. Most of them are in fact not very
                                          2659  # critical, as evidenced by the fact that they weren't needed for the first
                                          2660  # Gigatron applications (Snake, Racer, Mandelbrot, Loader). By providing them
                                          2661  # in this way, at least they don't need to be implemented as a SYS extension.
                                          2662
                                          2663  # Instruction ADDI: Add small positive constant (vAC+=D), 24-26 cycles
                                          2664  label('ADDI')
ADDI:         03e3 1404  ld   $04,y       2665  ld(hi('addi#13'),Y)             #10,12
              03e4 e01c  jmp  y,$1c       2666  jmp(Y,'addi#13')                #11
              03e5 c22f  st   [$2f]       2667  st([vTmp])                      #12
                                          2668
                                          2669  # Instruction SUBI: Subtract small positive constant (vAC+=D), 24-26 cycles
                                          2670  label('SUBI')
SUBI:         03e6 1420  ld   $20,y       2671  ld(hi('subi#13'),Y)             #10
              03e7 e09d  jmp  y,$9d       2672  jmp(Y,'subi#13')                #11
              03e8 c22f  st   [$2f]       2673  st([vTmp])                      #12
                                          2674
                                          2675  # Instruction LSLW: Logical shift left (vAC<<=1), 26-28 cycles
                                          2676  # Useful, because ADDW can't add vAC to itself. Also more compact.
                                          2677  label('LSLW')
LSLW:         03e9 1404  ld   $04,y       2678  ld(hi('lslw#13'),Y)             #10
              03ea e02d  jmp  y,$2d       2679  jmp(Y,'lslw#13')                #11
              03eb 0116  ld   [$16]       2680  ld([vPC])                       #12
                                          2681
                                          2682  # Instruction STLW: (ec xx) 26 cycles (36 when vSPH!=0)
                                          2683  # * Store word in stack frame: *(vSP + xx) := vAC
                                          2684  label('STLW')
STLW:         03ec 141f  ld   $1f,y       2685  ld(hi('stlw#13'),Y)             #10
              03ed e068  jmp  y,$68       2686  jmp(Y,'stlw#13')                #11
                                          2687  #dummy()                        #12 Overlap
                                          2688  #
                                          2689  # Instruction LDLW: (ee xx) 26 cycles (36/38 when vSPH!=0)
                                          2690  # * Load word from stack frame: vAC := *(vSP + xx)
                                          2691  label('LDLW')
LDLW:         03ee 141f  ld   $1f,y       2692  ld(hi('ldlw#13'),Y)             #10,12
              03ef e08a  jmp  y,$8a       2693  jmp(Y,'ldlw#13')                #11
                                          2694  #st([vTmp])                     #12 Overlap
                                          2695  #
                                          2696  # Instruction POKE: Write byte in memory ([[D+1],[D]]=vAC&255), 28 cycles
                                          2697  label('POKE')
POKE:         03f0 c22f  st   [$2f]       2698  st([vTmp])                      #10,12
              03f1 1404  ld   $04,y       2699  ld(hi('poke#14'),Y)             #11
              03f2 e03f  jmp  y,$3f       2700  jmp(Y,'poke#14')                #12 Overlap
                                          2701
                                          2702  # Instruction DOKE: Write word in memory ([[D+1],[D]],[[D+1],[D]+1]=vAC&255,vAC>>8), 28 cycles
                                          2703  label('DOKE')
DOKE:         03f3 1404  ld   $04,y       2704  ld(hi('doke'),Y)                #10,13
              03f4 e056  jmp  y,$56       2705  jmp(Y,'doke')                   #11
