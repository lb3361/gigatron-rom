                                          6791  # Ensure labels defined here do not conflict
                                          6792  def fsmLab(n):
                                          6793      return f'fsm15:{n}'
                                          6794
                                          6795  # Assemble u-opcode
                                          6796  def fsmAsm(op,arg=None):
                                          6797      bra(fsmLab(op))
                                          6798      ld(pc()+1) if arg is None else ld(arg)
                                          6799
                                          6800  # Usage fsmAsm('ST', arg)
                                          6801  # - [arg] := vACL
                                          6802  label(fsmLab('ST'))
fsm15:ST:     150a 1415  ld   $15,y       6803  ld(hi('fsmST#8'),Y)             #5
              150b e0a8  jmp  y,$a8       6804  jmp(Y,'fsmST#8')                #6 + overlap
                                          6805
                                          6806  # Usage fsmAsm('LD', arg)
                                          6807  # - vACL = arg with arg=d or arg=[d]
                                          6808  label(fsmLab('LD'))
fsm15:LD:     150c 1415  ld   $15,y       6809  ld(hi('fsmOP#8'),Y)             #5,7
              150d e0b2  jmp  y,$b2       6810  jmp(Y,'fsmOP#8')                #6 + overlap
                                          6811
                                          6812  # Usage fsmAsm('XOR', arg)
                                          6813  # - vACL += arg with arg=d or arg=[d]
                                          6814  label(fsmLab('XOR'))
fsm15:XOR:    150e 1415  ld   $15,y       6815  ld(hi('fsmOP#8'),Y)             #5,7
              150f e0b2  jmp  y,$b2       6816  jmp(Y,'fsmOP#8')                #6
              1510 6118  xora [$18]       6817  xora([vAC])                     #7
                                          6818
                                          6819  # Usage fsmAsm('AND', arg)
                                          6820  # - vACL &= arg with arg=d or arg=[d]
                                          6821  label(fsmLab('AND'))
fsm15:AND:    1511 1415  ld   $15,y       6822  ld(hi('fsmOP#8'),Y)             #5
              1512 e0b2  jmp  y,$b2       6823  jmp(Y,'fsmOP#8')                #6
              1513 2118  anda [$18]       6824  anda([vAC])                     #7
                                          6825
                                          6826  # Usage fsmAsm('BNZ', arg)
                                          6827  # - branch if [vACL] is nonzero
                                          6828  label(fsmLab('BNZ'))
fsm15:BNZ:    1514 1415  ld   $15,y       6829  ld(hi('fsmBNZ#8'),Y)            #5
              1515 e0bd  jmp  y,$bd       6830  jmp(Y,'fsmBNZ#8')               #6
              1516 c22f  st   [$2f]       6831  st([vTmp])                      #7
