                                          4515  #-----------------------------------------------------------------------
                                          4516  #       MOS 6502 emulator
                                          4517  #-----------------------------------------------------------------------
                                          4518
                                          4519  # Some quirks:
                                          4520  # - Stack in zero page instead of page 1
                                          4521  # - No interrupts
                                          4522  # - No decimal mode (may never be added). D flag is emulated but ignored.
                                          4523  # - BRK switches back to running 16-bits vCPU
                                          4524  # - Illegal opcodes map to BRK, but can read ghost operands before trapping
                                          4525  # - Illegal opcode $ff won't be trapped and cause havoc instead
                                          4526
                                          4527  # Big things TODO:
                                          4528  # XXX Tuning, put most frequent instructions in the primary page
                                          4529
                                          4530  label('v6502_ror')
                                          4531  assert v6502_Cflag == 1
v6502_ror:    0d93 1525  ld   [$25],y     4532  ld([v6502_ADH],Y)               #12
              0d94 00fc  ld   $fc         4533  ld(-46//2+v6502_maxTicks)       #13 Is there enough time for the excess ticks?
              0d95 8115  adda [$15]       4534  adda([vTicks])                  #14
              0d96 e8a8  blt  .recheck17  4535  blt('.recheck17')               #15
              0d97 0127  ld   [$27]       4536  ld([v6502_P])                   #16 Transfer C to "bit 8"
              0d98 2001  anda $01         4537  anda(1)                         #17
              0d99 807f  adda $7f         4538  adda(127)                       #18
              0d9a 2080  anda $80         4539  anda(128)                       #19
              0d9b c219  st   [$19]       4540  st([v6502_BI])                  #20 The real 6502 wouldn't use BI for this
              0d9c 0d00  ld   [y,x]       4541  ld([Y,X])                       #21 Transfer bit 0 to C
              0d9d 6127  xora [$27]       4542  xora([v6502_P])                 #22
              0d9e 2001  anda $01         4543  anda(1)                         #23
              0d9f 6127  xora [$27]       4544  xora([v6502_P])                 #24
              0da0 c227  st   [$27]       4545  st([v6502_P])                   #25
              0da1 00ca  ld   $ca         4546  ld('v6502_ror#36')              #26 Shift table lookup
              0da2 c22f  st   [$2f]       4547  st([vTmp])                      #27
              0da3 0d00  ld   [y,x]       4548  ld([Y,X])                       #28
              0da4 20fe  anda $fe         4549  anda(~1)                        #29
              0da5 1405  ld   $05,y       4550  ld(hi('shiftTable'),Y)          #30
              0da6 e200  jmp  y,ac        4551  jmp(Y,AC)                       #31
              0da7 fcff  bra  $ff         4552  bra(255)                        #32 bra shiftTable+255
                                          4553  label('.recheck17')
.recheck17:   0da8 140e  ld   $0e,y       4554  ld(hi('v6502_check'),Y)         #17 Go back to time check before dispatch
              0da9 e0f2  jmp  y,$f2       4555  jmp(Y,'v6502_check')            #18
              0daa 00f6  ld   $f6         4556  ld(-20/2)                       #19
