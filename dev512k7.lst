                                          3135  #
                                          3136  #  $0500 ROM page 5-6: Shift table and code
                                          3137  #
                                          3138  #-----------------------------------------------------------------------
                                          3139
                                          3140  align(0x100, size=0x200)
                                          3141
                                          3142  # Lookup table for i>>n, with n in 1..6
                                          3143  # Indexing ix = i & ~b | (b-1), where b = 1<<(n-1)
                                          3144  #       ...
                                          3145  #       ld   <.ret
                                          3146  #       st   [vTmp]
                                          3147  #       ld   >shiftTable,y
                                          3148  #       <calculate ix>
                                          3149  #       jmp  y,ac
                                          3150  #       bra  $ff
                                          3151  # .ret: ...
                                          3152  #
                                          3153  # i >> 7 can be always be done with RAM: [i&128]
                                          3154  #       ...
                                          3155  #       anda $80,x
                                          3156  #       ld   [x]
                                          3157  #       ...
                                          3158
                                          3159  label('shiftTable')
                                          3160  shiftTable = pc()
                                          3161
                                          3162  for ix in range(255):
                                          3163    for n in range(1,7): # Find first zero
                                          3164      if ~ix & (1 << (n-1)):
                                          3165        break
                                          3166    pattern = ['x' if i<n else '1' if ix&(1<<i) else '0' for i in range(8)]
                                          3167    ld(ix>>n); C('0b%s >> %d' % (''.join(reversed(pattern)), n))
