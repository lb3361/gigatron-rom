              048f c218  st   [$18]       2805  st([vAC])                       #21
                                          2806  #
                                          2807  # SYS implementation
                                          2808  label('.sys#16')
.sys#16:      0490 0116  ld   [$16]       2809  ld([vPC])                       #16
              0491 a002  suba $02         2810  suba(2)                         #17
              0492 c216  st   [$16]       2811  st([vPC])                       #18
              0493 1403  ld   $03,y       2812  ld(hi('REENTER'),Y)             #19
              0494 e0cb  jmp  y,$cb       2813  jmp(Y,'REENTER')                #20
              0495 00f4  ld   $f4         2814  ld(-24//2)                      #21
                                          2815  #
                                          2816  # CALL implementation
                                          2817  # - Displacing CALL adds 4 cycles.
                                          2818  #   This is less critical when we have CALLI.
                                          2819  label('call#14')
call#14:      0496 0116  ld   [$16]       2820  ld([vPC])                       #14
              0497 8002  adda $02         2821  adda(2)                         #15 Point to instruction after CALL
              0498 c21a  st   [$1a]       2822  st([vLR])                       #16
              0499 0117  ld   [$17]       2823  ld([vPC+1])                     #17
              049a c21b  st   [$1b]       2824  st([vLR+1])                     #18
              049b 0500  ld   [x]         2825  ld([X])                         #19
              049c c217  st   [$17]       2826  st([vPC+1])                     #20
              049d 112f  ld   [$2f],x     2827  ld([vTmp],X)                    #21
              049e 0500  ld   [x]         2828  ld([X])                         #22
              049f a002  suba $02         2829  suba(2)                         #23 Because NEXT will add 2
              04a0 c216  st   [$16]       2830  st([vPC])                       #24
              04a1 1403  ld   $03,y       2831  ld(hi('REENTER'),Y)             #25
              04a2 e0cb  jmp  y,$cb       2832  jmp(Y,'REENTER')                #26
              04a3 00f1  ld   $f1         2833  ld(-30/2)                       #27
