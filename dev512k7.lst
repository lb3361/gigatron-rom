                                          4575  assert v6502_Cflag == 1
v6502_rol:    0db8 1525  ld   [$25],y     4576  ld([v6502_ADH],Y)               #12
              0db9 0d00  ld   [y,x]       4577  ld([Y,X])                       #13
              0dba 2080  anda $80         4578  anda(0x80)                      #14
              0dbb c22f  st   [$2f]       4579  st([v6502_Tmp])                 #15
              0dbc 0127  ld   [$27]       4580  ld([v6502_P])                   #16
