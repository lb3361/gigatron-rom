sys_v6502:    0d8f d605  st   [$05],y     4509  st([vCpuSelect],Y)              #18 Activate v6502
              0d90 00f5  ld   $f5         4510  ld(-22/2)                       #19
              0d91 e0ff  jmp  y,$ff       4511  jmp(Y,'v6502_ENTER')            #20 Transfer control in the same time slice
