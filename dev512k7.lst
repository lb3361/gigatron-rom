              1570 0071  ld   $71
              1571 fc11  bra  fsm15:AND   7085  fsmAsm('AND', 0x3f)             # six valid bits only
              1572 003f  ld   $3f
              1573 fc0a  bra  fsm15:ST    7086  fsmAsm('ST', sysArgs+4)         # len
              1574 0028  ld   $28
              1575 fc14  bra  fsm15:BNZ   7087  fsmAsm('BNZ', 'sl:packet')
              1576 0083  ld   $83
              1577 fc22  bra  fsm15:SRIN  7088  fsmAsm('SRIN')
              1578 0079  ld   $79
              1579 fc0a  bra  fsm15:ST    7089  fsmAsm('ST', vLR)               # execl
              157a 001a  ld   $1a
              157b fc22  bra  fsm15:SRIN  7090  fsmAsm('SRIN')
              157c 007d  ld   $7d
              157d fc0a  bra  fsm15:ST    7091  fsmAsm('ST', vLR+1)             # exech
              157e 001b  ld   $1b
                                          7092  fsmAsm('VRETNZ')
