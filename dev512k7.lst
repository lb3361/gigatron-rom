                                          5122  label('v6502_SBC')
                                          5123  # No matter how hard we try, v6502_SBC always comes out a lot clumsier
                                          5124  # than v6502_ADC. And that one already barely fits in 38 cycles and is
                                          5125  # hard to follow. So we use a hack: transmorph our SBC into an ADC with
                                          5126  # inverted operand, and then dispatch again. Simple and effective.
v6502_SBC:    1029 1525  ld   [$25],y     5127  ld([v6502_ADH],Y)               #9,24
              102a 0d00  ld   [y,x]       5128  ld([Y,X])                       #10
              102b 60ff  xora $ff         5129  xora(255)                       #11 Invert right-hand side operand
              102c c219  st   [$19]       5130  st([v6502_BI])                  #12 Park modified operand for v6502_ADC
              102d 0019  ld   $19         5131  ld(v6502_BI&255)                #13 Address of BI
              102e d224  st   [$24],x     5132  st([v6502_ADL],X)               #14
              102f 0000  ld   $00         5133  ld(v6502_BI>>8)                 #15
              1030 c225  st   [$25]       5134  st([v6502_ADH])                 #16
              1031 0069  ld   $69         5135  ld(0x69)                        #17 ADC #$xx (Any ADC opcode will do)
              1032 c226  st   [$26]       5136  st([v6502_IR])                  #18
              1033 140e  ld   $0e,y       5137  ld(hi('v6502_check'),Y)         #20 Go back to time check before dispatch
              1034 e0f2  jmp  y,$f2       5138  jmp(Y,'v6502_check')            #20
              1035 00f5  ld   $f5         5139  ld(-22/2)                       #21
