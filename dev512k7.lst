              01da fcdf  bra  .select#76  1562    bra('.select#76')             #74
              01db 00fd  ld   $fd         1563    ld('nopixels')                #75
                                          1564    label('.select#73')
.select#73:   01dc 00fc  ld   $fc         1565    ld('pixels')                  #73
              01dd c20a  st   [$0a]       1566    st([videoModeB])              #74
              01de 0200  nop              1567    nop()                         #75
                                          1568    label('.select#76')
.select#76:   01df c20c  st   [$0c]       1569    st([videoModeD])              #76
              01e0 0200  nop              1570    nop()                         #77
                                          1571
              01e1 00ff  ld   $ff         1572  ld(255)                         #78
              01e2 c211  st   [$11]       1573  st([buttonState])               #79
                                          1574
                                          1575  if not WITH_128K_BOARD:
                                          1576
              01e3 1505  ld   [$05],y     1577    runVcpu(189-80,               #80
              01e4 c000  st   $00,[$00]
              01e5 00f3  ld   $f3
              01e6 c21e  st   [$1e]
              01e7 e0ff  jmp  y,$ff
              01e8 0020  ld   $20
                                          1578            '---D line 40 select',
                                          1579            returnTo='vBlankEnd#189')
                                          1580    label('.select#70')
.select#70:   01e9 1505  ld   [$05],y     1581    runVcpu(189-70,               #70
              01ea c000  st   $00,[$00]
              01eb 00f3  ld   $f3
              01ec c21e  st   [$1e]
              01ed e0ff  jmp  y,$ff
              01ee 0025  ld   $25
                                          1582            '---D line 40 no select',
                                          1583            returnTo='vBlankEnd#189')
