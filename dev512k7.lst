              00a4 1403  ld   $03,y       906   ld(hi('REENTER'),Y)             #15 slot 0xa4
              00a5 e0cb  jmp  y,$cb       907   jmp(Y,'REENTER')                #16
              00a6 00f6  ld   $f6         908   ld(-20/2)                       #17
                                          909
              00a7 1403  ld   $03,y       910   ld(hi('REENTER'),Y)             #15 slot 0xa7
              00a8 e0cb  jmp  y,$cb       911   jmp(Y,'REENTER')                #16
              00a9 00f6  ld   $f6         912   ld(-20/2)                       #17
                                          913
              00aa 1403  ld   $03,y       914   ld(hi('REENTER'),Y)             #15 slot 0xaa
