                                          3388  #-----------------------------------------------------------------------
                                          3389  # Extension SYS_Read3_40
                                          3390  #-----------------------------------------------------------------------
                                          3391
                                          3392  # Read 3 consecutive bytes from ROM
                                          3393  #
                                          3394  # Note: This function a bit obsolete, as it has very limited use. It's
                                          3395  #       effectively an application-specific SYS function for the Pictures
                                          3396  #       application from ROM v1. It requires the ROM data be organized
                                          3397  #       with trampoline3a and trampoline3b fragments, and their address
                                          3398  #       in ROM to be known. Better avoid using this.
                                          3399  # Variables:
                                          3400  #       sysArgs[0:2]    Bytes (out)
                                          3401  #       sysArgs[6:7]    ROM pointer (in)
                                          3402
                                          3403  fillers(until = 0xb9)
                                          3404  assert pc() == 0x6b9
                                          3405
                                          3406  label('SYS_Read3_40')
SYS_Read3_40: 06b9 152b  ld   [$2b],y     3407  ld([sysArgs+7],Y)               #15,43
              06ba e079  jmp  y,$79       3408  jmp(Y,128-7)                    #16 trampoline3a
              06bb 012a  ld   [$2a]       3409  ld([sysArgs+6])                 #17
                                          3410  label('txReturn')
txReturn:     06bc c226  st   [$26]       3411  st([sysArgs+2])                 #34
              06bd 1403  ld   $03,y       3412  ld(hi('REENTER'),Y)             #35
              06be e0cb  jmp  y,$cb       3413  jmp(Y,'REENTER')                #36
              06bf 00ec  ld   $ec         3414  ld(-40/2)                       #37
                                          3415
                                          3416  def trampoline3a():
                                          3417    """Read 3 bytes from ROM page"""
                                          3418    while pc()&255 < 128-7:
                                          3419      nop()
                                          3420    bra(AC)                       #18
                                          3421    C('Trampoline for page $%02x00 reading (entry)' % (pc()>>8))
                                          3422    bra(123)                      #19
                                          3423    st([sysArgs+0])               #21
                                          3424    ld([sysArgs+6])               #22
                                          3425    adda(1)                       #23
                                          3426    bra(AC)                       #24
                                          3427    bra(250)                      #25 trampoline3b
                                          3428    align(1, size=0x80)
                                          3429
                                          3430  def trampoline3b():
                                          3431    """Read 3 bytes from ROM page (continue)"""
                                          3432    while pc()&255 < 256-6:
                                          3433      nop()
                                          3434    st([sysArgs+1])               #27
                                          3435    C('Trampoline for page $%02x00 reading (continue)' % (pc()>>8))
                                          3436    ld([sysArgs+6])               #28
                                          3437    adda(2)                       #29
                                          3438    ld(hi('txReturn'),Y)          #30
                                          3439    bra(AC)                       #31
                                          3440    jmp(Y,'txReturn')             #32
                                          3441    align(1, size=0x100)
