                                          210   enableListing()
                                          211   #-----------------------------------------------------------------------
                                          212   #
                                          213   #  Start of core
                                          214   #
                                          215   #-----------------------------------------------------------------------
                                          216
                                          217   # Pre-loading the formal interface as a way to get warnings when
                                          218   # accidentally redefined with a different value
                                          219   loadBindings('interface.json')
                                          220   loadBindings('Core/interface-dev.json') # Provisional values for DEVROM
                                          221
                                          222   # Gigatron clock
                                          223   cpuClock = 6.250e+06
                                          224
                                          225   # Output pin assignment for VGA
                                          226   R, G, B, hSync, vSync = 1, 4, 16, 64, 128
                                          227   syncBits = hSync+vSync # Both pulses negative
                                          228
                                          229   # When the XOUT register is in the circuit, the rising edge triggers its update.
                                          230   # The loop can therefore not be agnostic to the horizontal pulse polarity.
                                          231   assert syncBits & hSync != 0
                                          232
                                          233   # VGA 640x480 defaults (to be adjusted below!)
                                          234   vFront = 10     # Vertical front porch
                                          235   vPulse = 2      # Vertical sync pulse
                                          236   vBack  = 33     # Vertical back porch
                                          237   vgaLines = vFront + vPulse + vBack + 480
                                          238   vgaClock = 25.175e+06
                                          239
                                          240   # Video adjustments for Gigatron
                                          241   # 1. Our clock is (slightly) slower than 1/4th VGA clock. Not all monitors will
                                          242   #    accept the decreased frame rate, so we restore the frame rate to above
                                          243   #    minimum 59.94 Hz by cutting some lines from the vertical front porch.
                                          244   vFrontAdjust = vgaLines - int(4 * cpuClock / vgaClock * vgaLines)
                                          245   vFront -= vFrontAdjust
                                          246   # 2. Extend vertical sync pulse so we can feed the game controller the same
                                          247   #    signal. This is needed for controllers based on the 4021 instead of 74165
                                          248   vPulseExtension = max(0, 8-vPulse)
                                          249   vPulse += vPulseExtension
                                          250   # 3. Borrow these lines from the back porch so the refresh rate remains
                                          251   #    unaffected
                                          252   vBack -= vPulseExtension
                                          253
                                          254   # Start value of vertical blank counter
                                          255   videoYline0 = 1-2*(vFront+vPulse+vBack-2)
                                          256
                                          257   # Mismatch between video lines and sound channels
                                          258   soundDiscontinuity = (vFront+vPulse+vBack) % 4
                                          259
                                          260   # QQVGA resolution
                                          261   qqVgaWidth      = 160
                                          262   qqVgaHeight     = 120
                                          263
                                          264   # Game controller bits (actual controllers in kit have negative output)
                                          265   # +----------------------------------------+
                                          266   # |       Up                        B*     |
                                          267   # |  Left    Right               B     A*  |
                                          268   # |      Down      Select Start     A      |
                                          269   # +----------------------------------------+ *=Auto fire
                                          270   buttonRight     = 1
                                          271   buttonLeft      = 2
                                          272   buttonDown      = 4
                                          273   buttonUp        = 8
                                          274   buttonStart     = 16
                                          275   buttonSelect    = 32
                                          276   buttonB         = 64
                                          277   buttonA         = 128
                                          278
                                          279   #-----------------------------------------------------------------------
                                          280   #
                                          281   #  RAM page 0: zero-page variables
                                          282   #
                                          283   #-----------------------------------------------------------------------
                                          284
                                          285   # Memory size in pages from auto-detect
                                          286   memSize         = zpByte()
                                          287
                                          288   # The current channel number for sound generation. Advanced every scan line
                                          289   # and independent of the vertical refresh to maintain constant oscillation.
                                          290   channel         = zpByte()
                                          291
                                          292   # Next sound sample being synthesized
                                          293   sample          = zpByte()
                                          294   # To save one instruction in the critical inner loop, `sample' is always
                                          295   # reset with its own address instead of, for example, the value 0. Compare:
                                          296   # 1 instruction reset
                                          297   #       st sample,[sample]
                                          298   # 2 instruction reset:
                                          299   #       ld 0
                                          300   #       st [sample]
                                          301   # The difference is not audible. This is fine when the reset/address
                                          302   # value is low and doesn't overflow with 4 channels added to it.
                                          303   # There is an alternative, but it requires pull-down diodes on the data bus:
                                          304   #       st [sample],[sample]
                                          305   assert 4*63 + sample < 256
                                          306   # We pin this reset/address value to 3, so `sample' swings from 3 to 255
                                          307   assert sample == 3
                                          308
                                          309   # Former bootCount and bootCheck (<= ROMv3)
                                          310   zpReserved      = zpByte() # Recycled and still unused. Candidate future uses:
                                          311                              # - Video driver high address (for alternative video modes)
                                          312                              # - v6502: ADH offset ("MMU")
                                          313                              # - v8080: ???
                                          314   vCpuSelect      = zpByte() # Active interpreter page
                                          315
                                          316   if WITH_128K_BOARD:
                                          317     entropy      = zpByte(2) # Entropy harvested from SRAM startup and controller input
                                          318     ctrlVideo    = zpByte()  # ctrl bits for video access
                                          319   else:
                                          320     entropy      = zpByte(3) # Entropy harvested from SRAM startup and controller input
                                          321
                                          322   # Visible video
                                          323   videoY          = zpByte() # Counts up from 0 to 238 in steps of 2
                                          324                              # Counts up (and is odd) during vertical blank
                                          325   videoModeB      = zpByte() # Handler for every 2nd line (pixel burst or vCPU)
                                          326   videoModeC      = zpByte() # Handler for every 3rd line (pixel burst or vCPU)
                                          327   videoModeD      = zpByte() # Handler for every 4th line (pixel burst or vCPU)
                                          328
                                          329   nextVideo       = zpByte() # Jump offset to scan line handler (videoA, B, C...)
                                          330   videoPulse      = nextVideo # Used for pulse width modulation
                                          331
                                          332   # Frame counter is good enough as system clock
                                          333   frameCount      = zpByte(1)
                                          334
                                          335   # Serial input (game controller)
                                          336   serialRaw       = zpByte() # New raw serial read
                                          337   serialLast      = zpByte() # Previous serial read
                                          338   buttonState     = zpByte() # Clearable button state
                                          339   resetTimer      = zpByte() # After 2 seconds of holding 'Start', do a soft reset
                                          340                              # XXX move to page 1 to free up space
                                          341
                                          342   # Extended output (blinkenlights in bit 0:3 and audio in bit 4:7). This
                                          343   # value must be present in AC during a rising hSync edge. It then gets
                                          344   # copied to the XOUT register by the hardware. The XOUT register is only
                                          345   # accessible in this indirect manner because it isn't part of the core
                                          346   # CPU architecture.
                                          347   xout            = zpByte()
                                          348   xoutMask        = zpByte() # The blinkenlights and sound on/off state
                                          349
                                          350   # vCPU interpreter
                                          351   vTicks          = zpByte()  # Interpreter ticks are units of 2 clocks
                                          352   vPC             = zpByte(2) # Interpreter program counter, points into RAM
                                          353   vAC             = zpByte(2) # Interpreter accumulator, 16-bits
                                          354   vLR             = zpByte(2) # Return address, for returning after CALL
                                          355   vSP             = zpByte(2) # Stack pointer (16 bits!)
                                          356   vReturn         = zpByte()  # Return into video loop (in page of vBlankStart)
                                          357
                                          358   # Scratch
                                          359   frameX          = zpByte() # Starting byte within page
                                          360   frameY          = zpByte() # Page of current pixel line (updated by videoA)
                                          361
                                          362   # Vertical blank (reuse some variables used in the visible part)
                                          363   videoSync0      = frameX   # Vertical sync type on current line (0xc0 or 0x40)
                                          364   videoSync1      = frameY   # Same during horizontal pulse (0x80 or 0x00)
                                          365
                                          366   # Versioning for GT1 compatibility
                                          367   # Please refer to Docs/GT1-files.txt for interpreting this variable
                                          368   romType         = zpByte(1)
                                          369
                                          370   # The low 3 bits are repurposed to select the actively updated sound channels.
                                          371   # Valid bit combinations are:
                                          372   #  xxxxx011     Default after reset: 4 channels (page 1,2,3,4)
                                          373   #  xxxxx001     2 channels at double update rate (page 1,2)
                                          374   #  xxxxx000     1 channel at quadruple update rate (page 1)
                                          375   # The main application for this is to free up the high bytes of page 2,3,4.
                                          376   channelMask = symbol('channelMask_v4')
                                          377   assert romType == channelMask
                                          378
                                          379   # SYS function arguments and results/scratch
                                          380   sysFn           = zpByte(2)
                                          381   sysArgs         = zpByte(8)
                                          382   fsmState        = sysArgs+7
                                          383
                                          384   # Play sound if non-zero, count down and stop sound when zero
                                          385   soundTimer      = zpByte()
                                          386
                                          387   # Former ledTimer
                                          388   if WITH_128K_BOARD:
                                          389     ctrlCopy      = zpByte() # ctrl bits for vcpu access
                                          390   else:
                                          391     zpReserved2   = zpByte()
                                          392
                                          393   # LED state machine
                                          394   ledState_v2     = zpByte() # Current LED state
                                          395
                                          396   # Former ledTempo
                                          397   vTmp            = zpByte() # Scratch byte
                                          398
                                          399   # Management of free space in page zero (userVars)
                                          400   # * Programs that only use the features of ROMvx can
                                          401   #   safely use all bytes above userVars_vx except 0x80.
                                          402   # * Programs that use some but not all features of ROMvx
                                          403   #   may exceptionally use bytes between userVars
                                          404   #   and userVars_vx if they avoid using ROM features
                                          405   #   that need them. This is considerably riskier.
                                          406   userVars        = zpByte(0)
                                          407
                                          408   # Start of safely usable bytes under ROMv4
                                          409   userVars_v4     = zpByte(0)
                                          410   vIrqSave        = zpByte(6) # saved vcpu context during virq
                                          411   # Start of safely usable bytes under ROMv5,6,7
                                          412   userVars_v5     = zpByte(0)
                                          413   userVars_v6     = zpByte(0)
                                          414   userVars_v7     = zpByte(0)
                                          415
                                          416   # [0x80] Constant 0x01
                                          417   oneConst        = 0x80
                                          418
                                          419   zpReset(0x81)                 # Second variable zone
                                          420   userVars2       = zpByte(0)
                                          421   userVars2_v4    = zpByte(0)+1 # ROMv4's ctrlBits at 0x81!!!
                                          422   userVars2_v5    = zpByte(0)
                                          423   userVars2_v6    = zpByte(0)
                                          424   vFAS            = zpByte(1)   # FAC sign
                                          425   vFAE            = zpByte(1)   # FAC exponent
                                          426   vLAX            = zpByte(1)   # Extended long accumulator (40 bits)
                                          427   vLAC            = zpByte(4)   # Long accumulator (32 bits)
                                          428   vT2             = zpByte(2)   # T2 register
                                          429   vT3             = zpByte(2)   # T3 register
                                          430   userVars2_v7    = zpByte(0)
                                          431
                                          432
                                          433   #-----------------------------------------------------------------------
                                          434   #
                                          435   #  RAM page 1: video line table
                                          436   #
                                          437   #-----------------------------------------------------------------------
                                          438
                                          439   # Byte 0-239 define the video lines
                                          440   videoTable      = 0x0100 # Indirection table: Y[0] dX[0]  ..., Y[119] dX[119]
                                          441
                                          442   vReset          = 0x01f0 # Reset stub
                                          443   if WITH_128K_BOARD:
                                          444     entropy2      = 0x01f2 # (displaced) Entropy hidden state
                                          445   ledTempo        = 0x01f3 # (displaced) Led timer reset value
                                          446   ledTimer        = 0x01f4 # (displaced) Ticks until next LED change
                                          447   vIrqCtx_v7      = 0x01f5 # context page for irq
                                          448   vIRQ_v5         = 0x01f6 # vIRQ vector
                                          449   ctrlBits        = 0x01f8 # Expansion control bits
                                          450   videoTop_v5     = 0x01f9 # Number of skipped lines
                                          451
                                          452   # Highest bytes are for sound channel variables
                                          453   wavA = 250      # Waveform modulation with `adda'
                                          454   wavX = 251      # Waveform modulation with `xora'
                                          455   keyL = 252      # Frequency low 7 bits (bit7 == 0)
                                          456   keyH = 253      # Frequency high 8 bits
                                          457   oscL = 254      # Phase low 7 bits
                                          458   oscH = 255      # Phase high 8 bits
                                          459
                                          460   #-----------------------------------------------------------------------
                                          461   #  Memory layout
                                          462   #-----------------------------------------------------------------------
                                          463
                                          464   userCode = 0x0200       # Application vCPU code
                                          465   soundTable = 0x0700     # Wave form tables (doubles as right-shift-2 table)
                                          466   screenMemory = 0x0800   # Default start of screen memory: 0x0800 to 0x7fff
                                          467
                                          468   #-----------------------------------------------------------------------
                                          469   #  Application definitions
                                          470   #-----------------------------------------------------------------------
                                          471
                                          472   maxTicks = 30//2                # Duration of vCPU's slowest virtual opcode (ticks)
                                          473   minTicks = 14//2                # vcPU's fastest instruction
                                          474   v6502_maxTicks = 38//2          # Max duration of v6502 processing phase (ticks)
                                          475
                                          476   runVcpu_overhead = 5            # Caller overhead (cycles)
                                          477   vCPU_overhead = 9               # Callee overhead of jumping in and out (cycles)
                                          478   v6502_overhead = 11             # Callee overhead for v6502 (cycles)
                                          479
                                          480   v6502_adjust = (v6502_maxTicks - maxTicks) + (v6502_overhead - vCPU_overhead)//2
                                          481   assert v6502_adjust >= 0        # v6502's overhead is a bit more than vCPU
                                          482
                                          483
                                          484   def runVcpu_ticks(n, overhead, ref=None):
                                          485     overhead += vCPU_overhead
                                          486     n -= overhead
                                          487     assert n > 0
                                          488     m = n % 2                     # Need alignment?
                                          489     n //= 2
                                          490     n -= maxTicks                 # First instruction always runs
                                          491     assert n < 128
                                          492     assert n >= v6502_adjust
                                          493     print('runVcpu at $%04x net cycles %3s info %s' % (pc(), (n + maxTicks) * 2, ref))
                                          494     return n, m
                                          495
                                          496   def runVcpu(n, ref=None, returnTo=None):
                                          497     """Macro to run interpreter for exactly n cycles. Returns 0 in AC.
                                          498
                                          499     - `n' is the number of available Gigatron cycles including overhead.
                                          500       This is converted into interpreter ticks and takes into account
                                          501       the vCPU calling overheads. A `nop' is inserted when necessary
                                          502       for alignment between cycles and ticks.
                                          503     - `returnTo' is where program flow continues after return. If not set
                                          504        explicitely, it will be the first instruction behind the expansion.
                                          505     - If another interpreter than vCPU is active (v6502...), that one
                                          506       must adjust for the timing differences, because runVcpu wouldn't know."""
                                          507
                                          508     overhead = runVcpu_overhead
                                          509     if returnTo == 0x100:         # Special case for videoZ
                                          510       overhead -= 2
                                          511
                                          512     if n is None:
                                          513       # (Clumsily) create a maximum time slice, corresponding to a vTicks
                                          514       # value of 127 (giving 282 cycles). A higher value doesn't work because
                                          515       # then SYS functions that just need 28 cycles (0 excess) won't start.
                                          516       n = (127 + maxTicks) * 2 + overhead + vCPU_overhead
                                          517
                                          518     n, m = runVcpu_ticks(n, overhead, ref)
                                          519
                                          520     ld([vCpuSelect],Y)            #0 Allows us to use ctrl() just before runVcpu
                                          521     if m == 1:
                                          522         st(0,[0])                 # Tick alignment
                                          523     if returnTo != 0x100:
                                          524       if returnTo is None:
                                          525         returnTo = pc() + 4       # Next instruction
                                          526       ld(lo(returnTo))            #1
                                          527       st([vReturn])               #2
                                          528     jmp(Y,'ENTER')                #3
                                          529     ld(n)                         #4
                                          530   assert runVcpu_overhead ==       5
                                          531
                                          532
                                          533   #-----------------------------------------------------------------------
                                          534   #       v6502 definitions
                                          535   #-----------------------------------------------------------------------
                                          536
                                          537   # Registers are zero page variables
                                          538   v6502_PC        = vLR           # Program Counter
                                          539   v6502_PCL       = vLR+0         # Program Counter Low
                                          540   v6502_PCH       = vLR+1         # Program Counter High
                                          541   v6502_S         = vSP           # Stack Pointer (kept as "S+1")
                                          542   v6502_A         = vAC+0         # Accumulator
                                          543   v6502_BI        = vAC+1         # B Input Register (used by SBC)
                                          544   v6502_ADL       = sysArgs+0     # Low Address Register
                                          545   v6502_ADH       = sysArgs+1     # High Address Register
                                          546   v6502_IR        = sysArgs+2     # Instruction Register
                                          547   v6502_P         = sysArgs+3     # Processor Status Register (V flag in bit 7)
                                          548   v6502_Qz        = sysArgs+4     # Quick Status Register for Z flag
                                          549   v6502_Qn        = sysArgs+5     # Quick Status Register for N flag
                                          550   v6502_X         = sysArgs+6     # Index Register X
                                          551   v6502_Y         = sysArgs+7     # Index Register Y
                                          552   v6502_Tmp       = vTmp          # Scratch (may be clobbered outside v6502)
                                          553
                                          554   # MOS 6502 definitions for P register
                                          555   v6502_Cflag = 1                 # Carry Flag (unsigned overflow)
                                          556   v6502_Zflag = 2                 # Zero Flag (all bits zero)
                                          557   v6502_Iflag = 4                 # Interrupt Enable Flag (1=Disable)
                                          558   v6502_Dflag = 8                 # Decimal Enable Flag (aka BCD mode, 1=Enable)
                                          559   v6502_Bflag = 16                # Break (or PHP) Instruction Flag
                                          560   v6502_Uflag = 32                # Unused (always 1)
                                          561   v6502_Vflag = 64                # Overflow Flag (signed overflow)
                                          562   v6502_Nflag = 128               # Negative Flag (bit 7 of result)
                                          563
                                          564   # In emulation it is much faster to keep the V flag in bit 7
                                          565   # This can be corrected when importing/exporting with PHP, PLP, etc
                                          566   v6502_Vemu = 128
                                          567
                                          568   # On overflow:
                                          569   #       """Overflow is set if two inputs with the same sign produce
                                          570   #          a result with a different sign. Otherwise it is clear."""
                                          571   # Formula (without carry/borrow in!):
                                          572   #       (A ^ (A+B)) & (B ^ (A+B)) & 0x80
                                          573   # References:
                                          574   #       http://www.righto.com/2012/12/the-6502-overflow-flag-explained.html
                                          575   #       http://6502.org/tutorials/vflag.html
                                          576
                                          577   # Memory layout
                                          578   v6502_Stack     = 0x0000        # 0x0100 is already used in the Gigatron
                                          579   #v6502_NMI      = 0xfffa
                                          580   #v6502_RESET    = 0xfffc
                                          581   #v6502_IRQ      = 0xfffe
                                          582
                                          583   #-----------------------------------------------------------------------
                                          584   #
                                          585   #  $0000 ROM page 0: Boot
                                          586   #
                                          587   #-----------------------------------------------------------------------
                                          588
                                          589   align(0x100, size=0x80)
                                          590
                                          591   # Give a first sign of life that can be checked with a voltmeter
              address
              |    encoding
              |    |     instruction
              |    |     |    operands
              |    |     |    |
              V    V     V    V
              0000 0000  ld   $00         592   ld(0b0000)                      # LEDs |OOOO|
              0001 1880  ld   $80,out     593   ld(syncBits^hSync,OUT)          # Prepare XOUT update, hSync goes down, RGB to black
              0002 18c0  ld   $c0,out     594   ld(syncBits,OUT)                # hSync goes up, updating XOUT
                                          595
                                          596   # Setup I/O and RAM expander
              0003 c17f  ctrl $7f         597   ctrl(0b01111111)                # Reset signal (default state | 0x3)
              0004 c17c  ctrl $7c         598   ctrl(0b01111100)                # Disable SPI slaves, enable RAM, bank 1
                                          599   #      ^^^^^^^^
                                          600   #      |||||||`-- SCLK
                                          601   #      ||||||`--- Not connected
                                          602   #      |||||`---- /SS0
                                          603   #      ||||`----- /SS1
                                          604   #      |||`------ /SS2
                                          605   #      ||`------- /SS3
                                          606   #      |`-------- B0
                                          607   #      `--------- B1
                                          608   # bit15 --------- MOSI = 0
                                          609
                                          610   # Simple RAM test and size check by writing to [1<<n] and see if [0] changes or not.
              0005 0001  ld   $01         611   ld(1)                           # Quick RAM test and count
                                          612   label('.countMem0')
.countMem0:   0006 d601  st   [$01],y     613   st([memSize],Y)                 # Store in RAM and load AC in Y
              0007 00ff  ld   $ff         614   ld(255)
              0008 6900  xora [y,$00]     615   xora([Y,0])                     # Invert value from memory
              0009 ca00  st   [y,$00]     616   st([Y,0])                       # Test RAM by writing the new value
              000a c200  st   [$00]       617   st([0])                         # Copy result in [0]
              000b 6900  xora [y,$00]     618   xora([Y,0])                     # Read back and compare if written ok
              000c ec0c  bne  $000c       619   bne(pc())                       # Loop forever on RAM failure here
              000d 00ff  ld   $ff         620   ld(255)
              000e 6900  xora [y,$00]     621   xora([Y,0])                     # Invert memory value again
              000f ca00  st   [y,$00]     622   st([Y,0])                       # To restore original value
              0010 6100  xora [$00]       623   xora([0])                       # Compare with inverted copy
              0011 f015  beq  .countMem1  624   beq('.countMem1')               # If equal, we wrapped around
              0012 0101  ld   [$01]       625   ld([memSize])
              0013 fc06  bra  .countMem0  626   bra('.countMem0')               # Loop to test next address line
              0014 8200  adda ac          627   adda(AC)                        # Executes in the branch delay slot!
                                          628   label('.countMem1')
                                          629
                                          630   # Momentarily wait to allow for debouncing of the reset switch by spinning
                                          631   # roughly 2^15 times at 2 clocks per loop: 6.5ms@10MHz to 10ms@6.3MHz
                                          632   # Real-world switches normally bounce shorter than that.
                                          633   # "[...] 16 switches exhibited an average 1557 usec of bouncing, with,
                                          634   #  as I said, a max of 6200 usec" (From: http://www.ganssle.com/debouncing.htm)
                                          635   # Relevant for the breadboard version, as the kit doesn't have a reset switch.
                                          636
.countMem1:   0015 00ff  ld   $ff         637   ld(255)                         # Debounce reset button
                                          638   label('.debounce')
.debounce:    0016 c200  st   [$00]       639   st([0])
              0017 ec17  bne  $0017       640   bne(pc())
              0018 a001  suba $01         641   suba(1)                         # Branch delay slot
              0019 0100  ld   [$00]       642   ld([0])
              001a ec16  bne  .debounce   643   bne('.debounce')
              001b a001  suba $01         644   suba(1)                         # Branch delay slot
                                          645
                                          646   # Update LEDs (memory is present and counted, reset is stable)
              001c 0001  ld   $01         647   ld(0b0001)                      # LEDs |*OOO|
              001d 1880  ld   $80,out     648   ld(syncBits^hSync,OUT)
              001e 18c0  ld   $c0,out     649   ld(syncBits,OUT)
                                          650
                                          651   # Scan the entire RAM space to collect entropy for a random number generator.
                                          652   # The 16-bit address space is scanned, even if less RAM was detected.
              001f 0000  ld   $00         653   ld(0)                           # Collect entropy from RAM
              0020 d218  st   [$18],x     654   st([vAC+0],X)
              0021 d619  st   [$19],y     655   st([vAC+1],Y)
                                          656   label('.initEnt0')
.initEnt0:    0022 0106  ld   [$06]       657   ld([entropy+0])
              0023 f426  bge  .initEnt1   658   bpl('.initEnt1')
              0024 8d00  adda [y,x]       659   adda([Y,X])
              0025 60bf  xora $bf         660   xora(191)
                                          661   label('.initEnt1')
.initEnt1:    0026 c206  st   [$06]       662   st([entropy+0])
              0027 0107  ld   [$07]       663   ld([entropy+1])
              0028 f42b  bge  .initEnt2   664   bpl('.initEnt2')
              0029 8106  adda [$06]       665   adda([entropy+0])
              002a 60c1  xora $c1         666   xora(193)
                                          667   label('.initEnt2')
.initEnt2:    002b c207  st   [$07]       668   st([entropy+1])
              002c 1401  ld   $01,y       669   ld(1,Y)
                                          670   if WITH_128K_BOARD:
                                          671     adda([Y,entropy2])            # displaced third entropy byte
                                          672     st([Y,entropy2])
                                          673   else:
              002d 8108  adda [$08]       674     adda([entropy+2])             # preserved third entropy byte
              002e c208  st   [$08]       675     st([entropy+2])
              002f 1519  ld   [$19],y     676   ld([vAC+1],Y)
              0030 0118  ld   [$18]       677   ld([vAC+0])
              0031 8001  adda $01         678   adda(1)
              0032 ec22  bne  .initEnt0   679   bne('.initEnt0')
              0033 d218  st   [$18],x     680   st([vAC+0],X)
              0034 0119  ld   [$19]       681   ld([vAC+1])
              0035 8001  adda $01         682   adda(1)
              0036 ec22  bne  .initEnt0   683   bne('.initEnt0')
              0037 d619  st   [$19],y     684   st([vAC+1],Y)
                                          685
                                          686   # Update LEDs
              0038 0003  ld   $03         687   ld(0b0011)                      # LEDs |**OO|
              0039 1880  ld   $80,out     688   ld(syncBits^hSync,OUT)
              003a 18c0  ld   $c0,out     689   ld(syncBits,OUT)
                                          690
                                          691   # vCPU reset handler
              003b 0002  ld   $02         692   ld(hi('ENTER'))                 # vCPU is the active interpreter
              003c c205  st   [$05]       693   st([vCpuSelect])
              003d 00ee  ld   $ee         694   ld((vReset&255)-2)              # Setup reset handler
              003e c216  st   [$16]       695   st([vPC])
              003f 9002  adda $02,x       696   adda(2,X)
              0040 0001  ld   $01         697   ld(vReset>>8)
              0041 d617  st   [$17],y     698   st([vPC+1],Y)
              0042 dc35  st   $35,[y,x++] 699   st(lo('PREFIX35'),    [Y,Xpp])  # vReset
              0043 dc7d  st   $7d,[y,x++] 700   st(lo('RESET_v7'),    [Y,Xpp])
                                          701
                                          702   # Init key variables (Y=1)
              0044 0000  ld   $00         703   ld(0)
              0045 c200  st   [$00]       704   st([0])                         # Carry lookup ([0x80] in 1st line of vBlank)
              0046 c202  st   [$02]       705   st([channel])
              0047 c22c  st   [$2c]       706   st([soundTimer])
              0048 caf5  st   [y,$f5]     707   st([Y, vIrqCtx_v7])
              0049 caf6  st   [y,$f6]     708   st([Y, vIRQ_v5])
              004a caf7  st   [y,$f7]     709   st([Y, vIRQ_v5+1])
              004b caf9  st   [y,$f9]     710   st([Y, videoTop_v5])
              004c 00ff  ld   $ff         711   ld(255)                         # Setup serial input
              004d c20e  st   [$0e]       712   st([frameCount])
              004e c20f  st   [$0f]       713   st([serialRaw])
              004f c210  st   [$10]       714   st([serialLast])
              0050 c211  st   [$11]       715   st([buttonState])
              0051 c212  st   [$12]       716   st([resetTimer])                # resetTimer<0 when entering Main.gcl
              0052 007c  ld   $7c         717   ld(0x7c)
              0053 caf8  st   [y,$f8]     718   st([Y, ctrlBits])
              0054 0200  nop              719   st([ctrlVideo]) if WITH_128K_BOARD else nop()
              0055 0200  nop              720   st([ctrlCopy])  if WITH_128K_BOARD else nop()
                                          721
              0056 000f  ld   $0f         722   ld(0b1111)                      # LEDs |****|
              0057 1880  ld   $80,out     723   ld(syncBits^hSync,OUT)
              0058 18c0  ld   $c0,out     724   ld(syncBits,OUT)
              0059 c213  st   [$13]       725   st([xout])                      # Setup for control by video loop
              005a c214  st   [$14]       726   st([xoutMask])
                                          727
                                          728   # Start
              005b 1401  ld   $01,y       729   ld(hi('startVideo'),Y)          # Enter video loop at vertical blank
              005c e003  jmp  y,$03       730   jmp(Y,'startVideo')
              005d c22e  st   [$2e]       731   st([ledState_v2])               # Setting to 1..126 means "stopped"
                                          732
                                          733   #-----------------------------------------------------------------------
                                          734   # Soft reset
                                          735   #-----------------------------------------------------------------------
                                          736
                                          737   # Resets the gigatron without breaking the video loop.
                                          738   # This mostly consists of executing Reset.gt1.
                                          739   #
                                          740   # This used to be achieved with a SYS_Reset_88 that was removed
                                          741   # from interface.json for ROMv5a in order to prefer achieving this
                                          742   # by jumping to vReset. Instead of a SYS call, this is now
                                          743   # achieved by a secret vCPU instruction RESET_v7 that frees
                                          744   # the [1f2-1f5] space for other purposes.
                                          745
                                          746   # ROM type (see also Docs/GT1-files.txt)
                                          747   romTypeValue = symbol('romTypeValue_DEVROM')
                                          748
                                          749   label('softReset#24')
softReset#24: 005e 0000  ld   $00         750   ld(0)                           #24
              005f c21c  st   [$1c]       751   st([vSP])                       #25 vSP
              0060 c21d  st   [$1d]       752   st([vSP+1])                     #26
              0061 1401  ld   $01,y       753   ld(hi('videoTop_v5'),Y)         #27
              0062 caf9  st   [y,$f9]     754   st([Y,lo('videoTop_v5')])       #28 Show all 120 pixel lines
              0063 caf5  st   [y,$f5]     755   st([Y,vIrqCtx_v7])              #29
              0064 caf6  st   [y,$f6]     756   st([Y,vIRQ_v5])                 #30 Disable vIRQ dispatch
              0065 caf7  st   [y,$f7]     757   st([Y,vIRQ_v5+1])               #31
              0066 c22c  st   [$2c]       758   st([soundTimer])                #32 soundTimer
              0067 c21a  st   [$1a]       759   st([vLR])                       #33 vLR
              0068 c21b  st   [$1b]       760   st([vLR+1])                     #34
              0069 c20b  st   [$0b]       761   st([videoModeC]) if WITH_512K_BOARD else None
              006a 007c  ld   $7c         762   ld(0x7c)                        #35/36
              006b caf8  st   [y,$f8]     763   st([Y,ctrlBits])                #36/37
              006c 0200  nop              764   st([ctrlVideo])  if WITH_128K_BOARD else nop()
              006d 0200  nop              765   st([ctrlCopy])   if WITH_128K_BOARD else nop()
              006e 00fd  ld   $fd         766   ld('nopixels')                  #39/40
                                          767   st([videoModeC]) if not WITH_512K_BOARD else None
              006f c20a  st   [$0a]       768   st([videoModeB])                #41
              0070 c20c  st   [$0c]       769   st([videoModeD])                #42
                                          770   # Set romTypeValue
                                          771   assert (romTypeValue & 7) == 0
              0071 00f8  ld   $f8         772   ld(romTypeValue)                #43 Set ROM type/version and clear channel mask
              0072 c221  st   [$21]       773   st([romType])                   #44
                                          774   # Reset expansion board
              0073 c17f  ctrl $7f         775   ctrl(0b01111111)                #45 Reset signal (default state | 0x3)
              0074 c17c  ctrl $7c         776   ctrl(0b01111100)                #46 Default state.
                                          777   # Adjust ticks
              0075 0115  ld   [$15]       778   ld([vTicks])                    #47 Always load after ctrl
              0076 80ed  adda $ed         779   adda(-38/2)                     #48-38=10
              0077 c215  st   [$15]       780   st([vTicks])                    #11
              0078 0065  ld   $65         781   ld('Reset')                     #12 Reset.gt1 from EPROM
              0079 c224  st   [$24]       782   st([sysArgs+0])                 #13
              007a 00e5  ld   $e5         783   ld(hi('Reset'))                 #14
              007b 1420  ld   $20,y       784   ld(hi('sys_Exec'),Y)            #15
              007c e009  jmp  y,$09       785   jmp(Y,'sys_Exec')               #16
              007d c225  st   [$25]       786   st([sysArgs+1])                 #17
                                          787
                                          788
                                          789
                                          790   #-----------------------------------------------------------------------
                                          791   # Placeholders for future SYS functions. This works as a kind of jump
                                          792   # table. The indirection allows SYS implementations to be moved around
                                          793   # between ROM versions, at the expense of 2 clock cycles (or 1). When
                                          794   # the function is not present it just acts as a NOP. Of course, when a
                                          795   # SYS function must be patched or extended it needs to have budget for
                                          796   # that in its declared maximum cycle count.
                                          797   #
                                          798   # Technically the same goal can be achieved by starting each function
                                          799   # with 2 nop's, or by overdeclaring their duration in the first place
                                          800   # (a bit is still wise to do). But this can result in fragmentation
                                          801   # of future ROM images. The indirection avoids that.
                                          802   #
                                          803   # An added advantage of having these in ROM page 0 is that it saves one
                                          804   # byte when setting sysFn: LDI+STW (4 bytes) instead of LDWI+STW (5 bytes)
                                          805   #-----------------------------------------------------------------------
                                          806
              007e 0200  nop              807   align(0x80, size=0x80)
              007f 0200  nop
                                          808   assert pc() == 0x80
                                          809
              0080 1403  ld   $03,y       810   ld(hi('REENTER'),Y)             #15 slot 0x80
              0081 e0cb  jmp  y,$cb       811   jmp(Y,'REENTER')                #16
              0082 00f6  ld   $f6         812   ld(-20/2)                       #17
                                          813
              0083 1403  ld   $03,y       814   ld(hi('REENTER'),Y)             #15 slot 0x83
              0084 e0cb  jmp  y,$cb       815   jmp(Y,'REENTER')                #16
              0085 00f6  ld   $f6         816   ld(-20/2)                       #17
                                          817
              0086 1403  ld   $03,y       818   ld(hi('REENTER'),Y)             #15 slot 0x86
              0087 e0cb  jmp  y,$cb       819   jmp(Y,'REENTER')                #16
              0088 00f6  ld   $f6         820   ld(-20/2)                       #17
                                          821
              0089 1403  ld   $03,y       822   ld(hi('REENTER'),Y)             #15 slot 0x89
              008a e0cb  jmp  y,$cb       823   jmp(Y,'REENTER')                #16
              008b 00f6  ld   $f6         824   ld(-20/2)                       #17
                                          825
              008c 1403  ld   $03,y       826   ld(hi('REENTER'),Y)             #15 slot 0x8c
              008d e0cb  jmp  y,$cb       827   jmp(Y,'REENTER')                #16
              008e 00f6  ld   $f6         828   ld(-20/2)                       #17
                                          829
              008f 1403  ld   $03,y       830   ld(hi('REENTER'),Y)             #15 slot 0x8f
              0090 e0cb  jmp  y,$cb       831   jmp(Y,'REENTER')                #16
              0091 00f6  ld   $f6         832   ld(-20/2)                       #17
                                          833
              0092 1403  ld   $03,y       834   ld(hi('REENTER'),Y)             #15 slot 0x92
              0093 e0cb  jmp  y,$cb       835   jmp(Y,'REENTER')                #16
              0094 00f6  ld   $f6         836   ld(-20/2)                       #17
                                          837
              0095 1403  ld   $03,y       838   ld(hi('REENTER'),Y)             #15 slot 0x95
              0096 e0cb  jmp  y,$cb       839   jmp(Y,'REENTER')                #16
              0097 00f6  ld   $f6         840   ld(-20/2)                       #17
                                          841
              0098 1403  ld   $03,y       842   ld(hi('REENTER'),Y)             #15 slot 0x98
              0099 e0cb  jmp  y,$cb       843   jmp(Y,'REENTER')                #16
              009a 00f6  ld   $f6         844   ld(-20/2)                       #17
                                          845
              009b 1403  ld   $03,y       846   ld(hi('REENTER'),Y)             #15 slot 0x9b
              009c e0cb  jmp  y,$cb       847   jmp(Y,'REENTER')                #16
