                                          5845
                                          5846  label('vBlankFirst#86')
vBlankFirst#86:
              1200 09f7  ld   [y,$f7]     5847  ld([Y,vIRQ_v5+1])               #86
              1201 49f6  ora  [y,$f6]     5848  ora([Y,vIRQ_v5])                #87
                                          5849  beq('vBlankFirst#90')           #88
              1202 f00d  beq  vBlankFirst#90
              1203 09f5  ld   [y,$f5]     5850  ld([Y, vIrqCtx_v7])             #89
                                          5851  beq('vBlankFirst#92')           #90
              1204 f013  beq  vBlankFirst#92
              1205 0200  nop              5852  nop()                           #91
              1206 1600  ld   ac,y        5853  ld(AC,Y)                        #92
              1207 09ff  ld   [y,$ff]     5854  ld([Y,0xff])                    #93 irqMask
                                          5855  bne('vBlankFirst#96')           #94
              1208 ec10  bne  vBlankFirst#96
              1209 cafe  st   [y,$fe]     5856  st([Y,0xfe])                    #95 irqFlag
              120a 1421  ld   $21,y       5857  ld(hi('vIRQ#99'),Y)             #96 ctx irq
              120b e026  jmp  y,$26       5858  jmp(Y,'vIRQ#99')                #97
              120c 1401  ld   $01,y       5859  ld(1,Y)                         #98
