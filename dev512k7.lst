              04f4 c205  st   [$05]       3114  st([vCpuSelect])                #27
              04f5 0115  ld   [$15]       3115  ld([vTicks])                    #28 enough time for immediate resume?
              04f6 80e9  adda $e9         3116  adda(maxTicks-vRtiNeeds)        #29
              04f7 f4eb  bge  vRTI#32     3117  bge('vRTI#32')                  #30
              04f8 1403  ld   $03,y       3118  ld(hi('RESYNC'),Y)              #31
              04f9 e00c  jmp  y,$0c       3119  jmp(Y,'RESYNC')                 #32
              04fa 8017  adda $17         3120  adda(vRtiNeeds-30//2)           #33-30=3
