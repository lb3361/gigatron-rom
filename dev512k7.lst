                                          5262  # Carry calculation table
                                          5263  #   L7 R7 C7   RX UC SC
                                          5264  #   -- -- -- | -- -- --
                                          5265  #    0  0  0 |  0  0  0
                                          5266  #    0  0  1 |  0  0  0
                                          5267  #    1  0  0 |  0  1 +1
                                          5268  #    1  0  1 |  0  0  0
                                          5269  #    0  1  0 | -1  1  0
                                          5270  #    0  1  1 | -1  0 -1
                                          5271  #    1  1  0 | -1  1  0
                                          5272  #    1  1  1 | -1  1  0
                                          5273  #   -- -- -- | -- -- --
                                          5274  #    ^  ^  ^    ^  ^  ^
                                          5275  #    |  |  |    |  |  `--- Carry of unsigned L + signed R: SC = RX + UC
                                          5276  #    |  |  |    |  `----- Carry of unsigned L + unsigned R: UC = C7 ? L7&R7 : L7|R7
                                          5277  #    |  |  |    `------- Sign extension of signed R
                                          5278  #    |  |  `--------- MSB of unextended L + R
                                          5279  #    |  `----------- MSB of right operand R
                                          5280  #    `------------- MSB of left operand L
