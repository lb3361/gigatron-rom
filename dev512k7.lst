                                          3103
                                          3104  # Immediate resume is possible when there is enough time for
                                          3105  # finishing vrti and executing the next instruction (possibly v6502)
                                          3106  vRtiNeeds=36//2+maxTicks+v6502_adjust
                                          3107
                                          3108  label('vRTI#22')
vRTI#22:      04ef 0132  ld   [$32]       3109  ld([vIrqSave+2])                #22
