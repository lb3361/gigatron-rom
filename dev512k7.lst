                                          2976  # vRTI immediate resume
                                          2977  label('vRTI#32')
vRTI#32:      04eb 1505  ld   [$05],y     2978  ld([vCpuSelect],Y)              #32
              04ec 00ee  ld   $ee         2979  ld(-36//2)                      #33
              04ed e0ff  jmp  y,$ff       2980  jmp(Y,'ENTER')                  #34
              04ee 8115  adda [$15]       2981  adda([vTicks])                  #35-36=-1
                                          2982
                                          2983  # Immediate resume is possible when there is enough time for
                                          2984  # finishing vrti and executing the next instruction (possibly v6502)
                                          2985  vRtiNeeds=36//2+maxTicks+v6502_adjust
                                          2986
                                          2987  label('vRTI#22')
vRTI#22:      04ef 0132  ld   [$32]       2988  ld([vIrqSave+2])                #22
              04f0 c218  st   [$18]       2989  st([vAC])                       #23
              04f1 0133  ld   [$33]       2990  ld([vIrqSave+3])                #24
              04f2 c219  st   [$19]       2991  st([vAC+1])                     #25
              04f3 0134  ld   [$34]       2992  ld([vIrqSave+4])                #26
              04f4 c205  st   [$05]       2993  st([vCpuSelect])                #27
              04f5 0115  ld   [$15]       2994  ld([vTicks])                    #28 enough time for immediate resume?
              04f6 80e9  adda $e9         2995  adda(maxTicks-vRtiNeeds)        #29
              04f7 f4eb  bge  vRTI#32     2996  bge('vRTI#32')                  #30
              04f8 1403  ld   $03,y       2997  ld(hi('RESYNC'),Y)              #31
              04f9 e00c  jmp  y,$0c       2998  jmp(Y,'RESYNC')                 #32
              04fa 8017  adda $17         2999  adda(vRtiNeeds-30//2)           #33-30=3
                                          3000
                                          3001  # Resync cycle adjustment must be positive
                                          3002  assert (maxTicks-vRtiNeeds)+(vRtiNeeds-30//2) >= 0
                                          3003
