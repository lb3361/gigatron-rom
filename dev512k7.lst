                                          3556  #-----------------------------------------------------------------------
                                          3557  # Extension SYS_ExpanderControl_v4_40
                                          3558  #-----------------------------------------------------------------------
                                          3559
                                          3560  # Sets the I/O and RAM expander's control register
                                          3561  #
                                          3562  # Variables:
                                          3563  #       vAC bit 2       Device enable /SS0
                                          3564  #           bit 3       Device enable /SS1
                                          3565  #           bit 4       Device enable /SS2
                                          3566  #           bit 5       Device enable /SS3
                                          3567  #           bit 6       Banking B0
                                          3568  #           bit 7       Banking B1
                                          3569  #           bit 15      Data out MOSI
                                          3570  #       sysArgs[7]      Cache for control state (written to)
                                          3571  #
                                          3572  # Intended for prototyping, and probably too low-level for most applications
                                          3573  # Still there's a safeguard: it's not possible to disable RAM using this
                                          3574
                                          3575  label('SYS_ExpanderControl_v4_40')
SYS_ExpanderControl_v4_40:
              0b09 140d  ld   $0d,y       3576  ld(hi('sys_ExpanderControl'),Y) #15
              0b0a e000  jmp  y,$00       3577  jmp(Y,'sys_ExpanderControl')    #16
              0b0b 000c  ld   $0c         3578  ld(0b00001100)                  #17
                                          3579  #    ^^^^^^^^
                                          3580  #    |||||||`-- SCLK
                                          3581  #    ||||||`--- Not connected
                                          3582  #    |||||`---- /SS0
                                          3583  #    ||||`----- /SS1
                                          3584  #    |||`------ /SS2 or /CPOL
                                          3585  #    ||`------- /SS3 or /ZPBANK
                                          3586  #    |`-------- B0
                                          3587  #    `--------- B1
                                          3588
                                          3589  #-----------------------------------------------------------------------
                                          3590  # Extension SYS_Run6502_v4_80
                                          3591  #-----------------------------------------------------------------------
                                          3592
                                          3593  # Transfer control to v6502
                                          3594  #
                                          3595  # Calling 6502 code from vCPU goes (only) through this SYS function.
                                          3596  # Directly modifying the vCpuSelect variable is unreliable. The
                                          3597  # control transfer is immediate, without waiting for the current
                                          3598  # time slice to end or first returning to vCPU.
                                          3599  #
                                          3600  # vCPU code and v6502 code can interoperate without much hassle:
                                          3601  # - The v6502 program counter is vLR, and v6502 doesn't touch vPC
                                          3602  # - Returning to vCPU is with the BRK instruction
                                          3603  # - BRK doesn't dump process state on the stack
                                          3604  # - vCPU can save/restore the vLR with PUSH/POP
                                          3605  # - Stacks are shared, vAC is shared
                                          3606  # - vAC can indicate what the v6502 code wants. vAC+1 will be cleared
                                          3607  # - Alternative is to leave a word in sysArgs[6:7] (v6502 X and Y registers)
                                          3608  # - Another way is to set vPC before BRK, and vCPU will continue there(+2)
                                          3609  #
                                          3610  # Calling v6502 code from vCPU looks like this:
                                          3611  #       LDWI  SYS_Run6502_v4_80
                                          3612  #       STW   sysFn
                                          3613  #       LDWI  $6502_start_address
                                          3614  #       STW   vLR
                                          3615  #       SYS   80
                                          3616  #
                                          3617  # Variables:
                                          3618  #       vAC             Accumulator
                                          3619  #       vLR             Program Counter
                                          3620  #       vSP             Stack Pointer (+1)
                                          3621  #       sysArgs[6]      Index Register X
                                          3622  #       sysArgs[7]      Index Register Y
                                          3623  # For info:
                                          3624  #       sysArgs[0:1]    Address Register, free to clobber
                                          3625  #       sysArgs[2]      Instruction Register, free to clobber
                                          3626  #       sysArgs[3:5]    Flags, don't touch
                                          3627  #
                                          3628  # Implementation details::
                                          3629  #
                                          3630  #  The time to reserve for this transition is the maximum time
                                          3631  #  between NEXT and v6502_check. This is
                                          3632  #       SYS call duration + 2*v6502_maxTicks + (v6502_overhead - vCPU_overhead)
                                          3633  #     = 22 + 28 + (11 - 9) = 62 cycles.
                                          3634  #  So reserving 80 cycles is future proof. This isn't overhead, as it includes
                                          3635  #  the fetching of the first 6502 opcode and its operands..
                                          3636  #
                                          3637  #                      0            10                 28=0         9
                                          3638  #    ---+----+---------+------------+------------------+-----------+---
                                          3639  # video | nop| runVcpu |   ENTER    | At least one ins |   EXIT    | video
                                          3640  #    ---+----+---------+------------+------------------+-----------+---
                                          3641  #        sync  prelude  ENTER-to-ins    ins-to-NEXT     NEXT-to-video
                                          3642  #       |<-->|
                                          3643  #        0/1 |<------->|
                                          3644  #                 5    |<----------------------------->|
                                          3645  #          runVCpu_overhead           28               |<--------->|
                                          3646  #                                 2*maxTicks                 9
                                          3647  #                                                      vCPU_overhead
                                          3648  #
                                          3649  #                      0                21                    38=0       11
                                          3650  #    ---+----+---------+----------------+--------------------+-----------+---
                                          3651  # video | nop| runVcpu |   v6502_ENTER  | At least one fetch |v6502_exitB| video
                                          3652  #    ---+----+---------+----------------+--------------------+-----------+---
                                          3653  #        sync  prelude   enter-to-fetch     fetch-to-check    check-to-video
                                          3654  #       |<-->|
                                          3655  #        0/1 |<------->|
                                          3656  #                 5    |<----------------------------------->|
                                          3657  #          runVcpu_overhead           38                     |<--------->|
                                          3658  #                              2*v6520_maxTicks                    11
                                          3659  #                                                            v6502_overhead
                                          3660
                                          3661  label('SYS_Run6502_v4_80')
SYS_Run6502_v4_80:
              0b0c 140d  ld   $0d,y       3662  ld(hi('sys_v6502'),Y)           #15
              0b0d e08f  jmp  y,$8f       3663  jmp(Y,'sys_v6502')              #16
              0b0e 000d  ld   $0d         3664  ld(hi('v6502_ENTER'))           #17 Activate v6502
                                          3665
