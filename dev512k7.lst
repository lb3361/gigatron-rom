                                          1111  #-----------------------------------------------------------------------
                                          1112  # Extension SYS_CopyMemoryExt_v6_100
                                          1113  #-----------------------------------------------------------------------
                                          1114
                                          1115  # SYS function for copying 1..256 bytes across banks
                                          1116  #
                                          1117  # sysArgs[0:1]  Destination address
                                          1118  # sysArgs[2:3]  Source address
                                          1119  # vAC[0]        Count (0 means 256)
                                          1120  # vAC[1]        Bits 7 and 6 contain the destination bank number,
                                          1121  #               and bits 5 and 4 the source bank number.
                                          1122  #
                                          1123  # Doesn't cross page boundaries.
                                          1124  # Overwrites sysArgs[4:7], vLR, and vTmp.
                                          1125  # Temporarily deselect all SPI devices.
                                          1126  # Should not call without expansion board
                                          1127
                                          1128  label('SYS_CopyMemoryExt_v6_100')
