                                          5141  # Carry calculation table
                                          5142  #   L7 R7 C7   RX UC SC
                                          5143  #   -- -- -- | -- -- --
                                          5144  #    0  0  0 |  0  0  0
                                          5145  #    0  0  1 |  0  0  0
                                          5146  #    1  0  0 |  0  1 +1
                                          5147  #    1  0  1 |  0  0  0
                                          5148  #    0  1  0 | -1  1  0
                                          5149  #    0  1  1 | -1  0 -1
                                          5150  #    1  1  0 | -1  1  0
                                          5151  #    1  1  1 | -1  1  0
                                          5152  #   -- -- -- | -- -- --
                                          5153  #    ^  ^  ^    ^  ^  ^
                                          5154  #    |  |  |    |  |  `--- Carry of unsigned L + signed R: SC = RX + UC
                                          5155  #    |  |  |    |  `----- Carry of unsigned L + unsigned R: UC = C7 ? L7&R7 : L7|R7
                                          5156  #    |  |  |    `------- Sign extension of signed R
                                          5157  #    |  |  `--------- MSB of unextended L + R
                                          5158  #    |  `----------- MSB of right operand R
                                          5159  #    `------------- MSB of left operand L
                                          5160
                                          5161  label('v6502_CLC')
v6502_CLC:    1036 0127  ld   [$27]       5162  ld([v6502_P])                   #9
              1037 fc3b  bra  .sec12      5163  bra('.sec12')                   #10
                                          5164  label('v6502_SEC')
