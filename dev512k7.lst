                                          2794  #
                                          2795  # XORW implementation
                                          2796  label('xorw')
xorw:         0487 9001  adda $01,x       2797  adda(1,X)                       #13
              0488 0500  ld   [x]         2798  ld([X])                         #14
              0489 6119  xora [$19]       2799  xora([vAC+1])                   #15
              048a c219  st   [$19]       2800  st([vAC+1])                     #16
              048b 112f  ld   [$2f],x     2801  ld([vTmp],X)                    #17
              048c 0500  ld   [x]         2802  ld([X])                         #18
              048d 6118  xora [$18]       2803  xora([vAC])                     #19
