                                          6775  label('FSM15_ENTER')
FSM15_ENTER:  14ff fc03  bra  $1503       6776  bra(pc()+4)                     #0
                                          6777  align(0x100, size=0x100)
              1500 fd2b  bra  [$2b]       6778  bra([fsmState])                 #1
                                          6779  assert (pc() & 255) == (symbol('NEXT') & 255)
                                          6780  label('FSM15_NEXT')
FSM15_NEXT:   1501 8115  adda [$15]       6781  adda([vTicks])                  #0
              1502 f52b  bge  [$2b]       6782  bge([fsmState],warn=False)      #1
              1503 c215  st   [$15]       6783  st([vTicks])                    #2
              1504 800f  adda $0f         6784  adda(maxTicks)                  #3
              1505 e405  bgt  $1505       6785  bgt(pc()&255)                   #4
              1506 a001  suba $01         6786  suba(1)                         #5
              1507 1401  ld   $01,y       6787  ld(hi('vBlankStart'),Y)         #6
              1508 e11e  jmp  y,[$1e]     6788  jmp(Y,[vReturn])                #7
              1509 0102  ld   [$02]       6789  ld([channel])                   #8
