                                          1068  #-----------------------------------------------------------------------
                                          1069  # Extension SYS_ScanMemory_v6_50
                                          1070  #-----------------------------------------------------------------------
                                          1071
                                          1072  # SYS function for searching bytes in memory.
                                          1073  # This function examines bytes starting from address sysArgs[01] and
                                          1074  # stops when encountering a byte equal to either sysArgs[2] or
                                          1075  # sysArgs[3], or when vACL bytes have been examined, whichever comes
                                          1076  # first.  It does not cross page boudaries but wraps around in the
                                          1077  # page, leaving sysArgs[1] unchanged.
                                          1078  #
                                          1079  # Inputs:
                                          1080  #   sysArgs[01]        Start address of the string
                                          1081  #   sysArgs[23]        Bytes to search
                                          1082  #   vACL               Length of the string (0 means 256)
                                          1083  #
                                          1084  # If a matching byte is found, its address is returned in vAC and sysArgs[01].
                                          1085  # Otherwise, zero is returned in vAC and sysArgs[0] point right after the string.
                                          1086
                                          1087  label('SYS_ScanMemory_v6_50')
SYS_ScanMemory_v6_50:
              00e6 1412  ld   $12,y       1088  ld(hi('sys_ScanMemory'),Y)      #15 slot 0xe6
              00e7 e09a  jmp  y,$9a       1089  jmp(Y,'sys_ScanMemory')         #16
              00e8 1525  ld   [$25],y     1090  ld([sysArgs+1],Y)               #17
                                          1091
                                          1092
