                                          10526  # LUP implementation
                                          10527
                                          10528  # LUP on dev7rom runs 4 cycles behind earlier ROMS.
                                          10529  # Clearing [vAC+1] is now achieved before branching
                                          10530  # into the rom page instead of in the return suffix.
                                          10531  # This permits sys_Exec to consult the ROM tables
                                          10532  # without losing the contents of [vAC+1] and with
                                          10533  # enough time to increment the lup pointer.
                                          10534  label('lup#13')
lup#13:       2000 1519  ld   [$19],y     10535  ld([vAC+1],Y)                   #13
              2001 1019  ld   $19,x       10536  ld(vAC+1,X)                     #14
              2002 e0fb  jmp  y,$fb       10537  jmp(Y,251)                      #15
              2003 c400  st   $00,[x]     10538  st(0,[X])                       #16 clear [vAC+1]
                                          10539
