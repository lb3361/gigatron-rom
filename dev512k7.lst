                                          10905  # Context structure
                                          10906  #
                                          10907  # page+0xe0: vAC
                                          10908  #     +0xe2: vPC, vLR, vSP
                                          10909  #     +0xe8: vLAC, vT2, vT3
                                          10910  #     +0xf0: sysArgs[0-7]
                                          10911  #     +0xf8: sysFn
                                          10912  #     +0xfa: vFAS, vFAE, vLAX0
                                          10913  #     +0xfd: vCpuSelect
                                          10914  #     +0xfe: irqFlag
                                          10915  #     +0xff: irqMask
                                          10916
                                          10917  def vSave(off,*vars):
                                          10918      for v in vars:
                                          10919          ld([v])
                                          10920          st([Y,off])
                                          10921          off += 1
                                          10922
                                          10923  def vRest(off,*vars):
                                          10924      for v in vars:
                                          10925          ld([Y,off])
                                          10926          st([v])
                                          10927          off += 1
                                          10928
