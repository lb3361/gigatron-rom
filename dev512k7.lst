                                          433   #-----------------------------------------------------------------------
                                          434   #
                                          435   #  RAM page 1: video line table
                                          436   #
                                          437   #-----------------------------------------------------------------------
                                          438
                                          439   # Byte 0-239 define the video lines
                                          440   videoTable      = 0x0100 # Indirection table: Y[0] dX[0]  ..., Y[119] dX[119]
                                          441
                                          442   vReset          = 0x01f0 # Reset stub
                                          443   if WITH_128K_BOARD:
                                          444     entropy2      = 0x01f2 # (displaced) Entropy hidden state
                                          445   ledTempo        = 0x01f3 # (displaced) Led timer reset value
                                          446   ledTimer        = 0x01f4 # (displaced) Ticks until next LED change
                                          447   vIrqCtx_v7      = 0x01f5 # context page for irq
                                          448   vIRQ_v5         = 0x01f6 # vIRQ vector
                                          449   ctrlBits        = 0x01f8 # Expansion control bits
                                          450   videoTop_v5     = 0x01f9 # Number of skipped lines
                                          451
                                          452   # Highest bytes are for sound channel variables
                                          453   wavA = 250      # Waveform modulation with `adda'
                                          454   wavX = 251      # Waveform modulation with `xora'
                                          455   keyL = 252      # Frequency low 7 bits (bit7 == 0)
                                          456   keyH = 253      # Frequency high 8 bits
                                          457   oscL = 254      # Phase low 7 bits
                                          458   oscH = 255      # Phase high 8 bits
                                          459
                                          460   #-----------------------------------------------------------------------
                                          461   #  Memory layout
                                          462   #-----------------------------------------------------------------------
                                          463
                                          464   userCode = 0x0200       # Application vCPU code
                                          465   soundTable = 0x0700     # Wave form tables (doubles as right-shift-2 table)
                                          466   screenMemory = 0x0800   # Default start of screen memory: 0x0800 to 0x7fff
                                          467
                                          468   #-----------------------------------------------------------------------
                                          469   #  Application definitions
                                          470   #-----------------------------------------------------------------------
                                          471
                                          472   maxTicks = 30//2                # Duration of vCPU's slowest virtual opcode (ticks)
                                          473   minTicks = 14//2                # vcPU's fastest instruction
                                          474   v6502_maxTicks = 38//2          # Max duration of v6502 processing phase (ticks)
                                          475
                                          476   vCPU_overhead = 9               # Callee overhead of jumping in and out (cycles)
                                          477   v6502_overhead = 11             # Callee overhead for v6502 (cycles)
                                          478
                                          479   v6502_adjust = (v6502_maxTicks - maxTicks) + (v6502_overhead - vCPU_overhead)//2
                                          480   assert v6502_adjust >= 0        # v6502's overhead is a bit more than vCPU
                                          481
                                          482
                                          483   def runVcpu_new(n, ref=None):
                                          484     '''Macro to run interpreter for exactly n cycles.
                                          485        Argument `n' is the number of available Gigatron cycles.
                                          486        This is converted into interpreter ticks and takes into account
                                          487        the vCPU calling overheads. A `nop' is inserted when necessary
                                          488        for alignment between cycles and ticks.
                                          489        After `n' cycles, code execution resumes at 0x100+[vReturn].'''
                                          490
                                          491     if n is None:
                                          492       n, m = 127, 0               # longest slice
                                          493     else:
                                          494       n -= vCPU_overhead + 3
                                          495       assert n > 0
                                          496       n, m = n // 2 - maxTicks, n % 2
                                          497     assert n < 128
                                          498     assert n >= v6502_adjust
                                          499     print('runVcpu at $%04x net cycles %3s info %s' % (pc(), (n + maxTicks) * 2, ref))
                                          500     ld([vCpuSelect],Y)            #0 Allows us to use ctrl() just before runVcpu
                                          501     st(0,[0]) if m == 1 else None #? Tick alignment
                                          502     jmp(Y,'ENTER')                #3
                                          503     ld(n)                         #4
                                          504
                                          505
                                          506   #-----------------------------------------------------------------------
                                          507   #       v6502 definitions
                                          508   #-----------------------------------------------------------------------
                                          509
                                          510   # Registers are zero page variables
                                          511   v6502_PC        = vLR           # Program Counter
                                          512   v6502_PCL       = vLR+0         # Program Counter Low
                                          513   v6502_PCH       = vLR+1         # Program Counter High
                                          514   v6502_S         = vSP           # Stack Pointer (kept as "S+1")
                                          515   v6502_A         = vAC+0         # Accumulator
                                          516   v6502_BI        = vAC+1         # B Input Register (used by SBC)
                                          517   v6502_ADL       = sysArgs+0     # Low Address Register
                                          518   v6502_ADH       = sysArgs+1     # High Address Register
                                          519   v6502_IR        = sysArgs+2     # Instruction Register
                                          520   v6502_P         = sysArgs+3     # Processor Status Register (V flag in bit 7)
                                          521   v6502_Qz        = sysArgs+4     # Quick Status Register for Z flag
                                          522   v6502_Qn        = sysArgs+5     # Quick Status Register for N flag
                                          523   v6502_X         = sysArgs+6     # Index Register X
                                          524   v6502_Y         = sysArgs+7     # Index Register Y
                                          525   v6502_Tmp       = vTmp          # Scratch (may be clobbered outside v6502)
                                          526
                                          527   # MOS 6502 definitions for P register
                                          528   v6502_Cflag = 1                 # Carry Flag (unsigned overflow)
                                          529   v6502_Zflag = 2                 # Zero Flag (all bits zero)
                                          530   v6502_Iflag = 4                 # Interrupt Enable Flag (1=Disable)
                                          531   v6502_Dflag = 8                 # Decimal Enable Flag (aka BCD mode, 1=Enable)
                                          532   v6502_Bflag = 16                # Break (or PHP) Instruction Flag
                                          533   v6502_Uflag = 32                # Unused (always 1)
                                          534   v6502_Vflag = 64                # Overflow Flag (signed overflow)
                                          535   v6502_Nflag = 128               # Negative Flag (bit 7 of result)
                                          536
                                          537   # In emulation it is much faster to keep the V flag in bit 7
                                          538   # This can be corrected when importing/exporting with PHP, PLP, etc
                                          539   v6502_Vemu = 128
                                          540
                                          541   # On overflow:
                                          542   #       """Overflow is set if two inputs with the same sign produce
                                          543   #          a result with a different sign. Otherwise it is clear."""
                                          544   # Formula (without carry/borrow in!):
                                          545   #       (A ^ (A+B)) & (B ^ (A+B)) & 0x80
                                          546   # References:
                                          547   #       http://www.righto.com/2012/12/the-6502-overflow-flag-explained.html
                                          548   #       http://6502.org/tutorials/vflag.html
                                          549
                                          550   # Memory layout
                                          551   v6502_Stack     = 0x0000        # 0x0100 is already used in the Gigatron
                                          552   #v6502_NMI      = 0xfffa
                                          553   #v6502_RESET    = 0xfffc
                                          554   #v6502_IRQ      = 0xfffe
                                          555
                                          556   #-----------------------------------------------------------------------
                                          557   #
                                          558   #  $0000 ROM page 0: Boot
                                          559   #
                                          560   #-----------------------------------------------------------------------
                                          561
                                          562   align(0x100, size=0x80)
                                          563
                                          564   # Give a first sign of life that can be checked with a voltmeter
              address
              |    encoding
              |    |     instruction
              |    |     |    operands
              |    |     |    |
              V    V     V    V
              0000 0000  ld   $00         565   ld(0b0000)                      # LEDs |OOOO|
              0001 1880  ld   $80,out     566   ld(syncBits^hSync,OUT)          # Prepare XOUT update, hSync goes down, RGB to black
              0002 18c0  ld   $c0,out     567   ld(syncBits,OUT)                # hSync goes up, updating XOUT
                                          568
                                          569   # Setup I/O and RAM expander
              0003 c17f  ctrl $7f         570   ctrl(0b01111111)                # Reset signal (default state | 0x3)
              0004 c17c  ctrl $7c         571   ctrl(0b01111100)                # Disable SPI slaves, enable RAM, bank 1
                                          572   #      ^^^^^^^^
                                          573   #      |||||||`-- SCLK
                                          574   #      ||||||`--- Not connected
                                          575   #      |||||`---- /SS0
                                          576   #      ||||`----- /SS1
                                          577   #      |||`------ /SS2
                                          578   #      ||`------- /SS3
                                          579   #      |`-------- B0
                                          580   #      `--------- B1
                                          581   # bit15 --------- MOSI = 0
                                          582
                                          583   # Simple RAM test and size check by writing to [1<<n] and see if [0] changes or not.
              0005 0001  ld   $01         584   ld(1)                           # Quick RAM test and count
                                          585   label('.countMem0')
.countMem0:   0006 d601  st   [$01],y     586   st([memSize],Y)                 # Store in RAM and load AC in Y
              0007 00ff  ld   $ff         587   ld(255)
              0008 6900  xora [y,$00]     588   xora([Y,0])                     # Invert value from memory
              0009 ca00  st   [y,$00]     589   st([Y,0])                       # Test RAM by writing the new value
              000a c200  st   [$00]       590   st([0])                         # Copy result in [0]
              000b 6900  xora [y,$00]     591   xora([Y,0])                     # Read back and compare if written ok
              000c ec0c  bne  $000c       592   bne(pc())                       # Loop forever on RAM failure here
              000d 00ff  ld   $ff         593   ld(255)
              000e 6900  xora [y,$00]     594   xora([Y,0])                     # Invert memory value again
              000f ca00  st   [y,$00]     595   st([Y,0])                       # To restore original value
              0010 6100  xora [$00]       596   xora([0])                       # Compare with inverted copy
              0011 f015  beq  .countMem1  597   beq('.countMem1')               # If equal, we wrapped around
              0012 0101  ld   [$01]       598   ld([memSize])
              0013 fc06  bra  .countMem0  599   bra('.countMem0')               # Loop to test next address line
              0014 8200  adda ac          600   adda(AC)                        # Executes in the branch delay slot!
                                          601   label('.countMem1')
                                          602
                                          603   # Momentarily wait to allow for debouncing of the reset switch by spinning
                                          604   # roughly 2^15 times at 2 clocks per loop: 6.5ms@10MHz to 10ms@6.3MHz
                                          605   # Real-world switches normally bounce shorter than that.
                                          606   # "[...] 16 switches exhibited an average 1557 usec of bouncing, with,
                                          607   #  as I said, a max of 6200 usec" (From: http://www.ganssle.com/debouncing.htm)
                                          608   # Relevant for the breadboard version, as the kit doesn't have a reset switch.
                                          609
.countMem1:   0015 00ff  ld   $ff         610   ld(255)                         # Debounce reset button
                                          611   label('.debounce')
.debounce:    0016 c200  st   [$00]       612   st([0])
              0017 ec17  bne  $0017       613   bne(pc())
              0018 a001  suba $01         614   suba(1)                         # Branch delay slot
              0019 0100  ld   [$00]       615   ld([0])
              001a ec16  bne  .debounce   616   bne('.debounce')
              001b a001  suba $01         617   suba(1)                         # Branch delay slot
                                          618
                                          619   # Update LEDs (memory is present and counted, reset is stable)
              001c 0001  ld   $01         620   ld(0b0001)                      # LEDs |*OOO|
              001d 1880  ld   $80,out     621   ld(syncBits^hSync,OUT)
              001e 18c0  ld   $c0,out     622   ld(syncBits,OUT)
                                          623
                                          624   # Scan the entire RAM space to collect entropy for a random number generator.
                                          625   # The 16-bit address space is scanned, even if less RAM was detected.
              001f 0000  ld   $00         626   ld(0)                           # Collect entropy from RAM
              0020 d218  st   [$18],x     627   st([vAC+0],X)
              0021 d619  st   [$19],y     628   st([vAC+1],Y)
                                          629   label('.initEnt0')
.initEnt0:    0022 0106  ld   [$06]       630   ld([entropy+0])
              0023 f426  bge  .initEnt1   631   bpl('.initEnt1')
              0024 8d00  adda [y,x]       632   adda([Y,X])
              0025 60bf  xora $bf         633   xora(191)
                                          634   label('.initEnt1')
.initEnt1:    0026 c206  st   [$06]       635   st([entropy+0])
              0027 0107  ld   [$07]       636   ld([entropy+1])
              0028 f42b  bge  .initEnt2   637   bpl('.initEnt2')
              0029 8106  adda [$06]       638   adda([entropy+0])
              002a 60c1  xora $c1         639   xora(193)
                                          640   label('.initEnt2')
.initEnt2:    002b c207  st   [$07]       641   st([entropy+1])
              002c 1401  ld   $01,y       642   ld(1,Y)
                                          643   if WITH_128K_BOARD:
                                          644     adda([Y,entropy2])            # displaced third entropy byte
                                          645     st([Y,entropy2])
                                          646   else:
              002d 8108  adda [$08]       647     adda([entropy+2])             # preserved third entropy byte
              002e c208  st   [$08]       648     st([entropy+2])
              002f 1519  ld   [$19],y     649   ld([vAC+1],Y)
              0030 0118  ld   [$18]       650   ld([vAC+0])
              0031 8001  adda $01         651   adda(1)
              0032 ec22  bne  .initEnt0   652   bne('.initEnt0')
              0033 d218  st   [$18],x     653   st([vAC+0],X)
              0034 0119  ld   [$19]       654   ld([vAC+1])
              0035 8001  adda $01         655   adda(1)
              0036 ec22  bne  .initEnt0   656   bne('.initEnt0')
              0037 d619  st   [$19],y     657   st([vAC+1],Y)
                                          658
                                          659   # Update LEDs
              0038 0003  ld   $03         660   ld(0b0011)                      # LEDs |**OO|
              0039 1880  ld   $80,out     661   ld(syncBits^hSync,OUT)
              003a 18c0  ld   $c0,out     662   ld(syncBits,OUT)
                                          663
                                          664   # vCPU reset handler
              003b 0002  ld   $02         665   ld(hi('ENTER'))                 # vCPU is the active interpreter
              003c c205  st   [$05]       666   st([vCpuSelect])
              003d 00ee  ld   $ee         667   ld((vReset&255)-2)              # Setup reset handler
              003e c216  st   [$16]       668   st([vPC])
              003f 9002  adda $02,x       669   adda(2,X)
              0040 0001  ld   $01         670   ld(vReset>>8)
              0041 d617  st   [$17],y     671   st([vPC+1],Y)
              0042 dc35  st   $35,[y,x++] 672   st(lo('PREFIX35'),    [Y,Xpp])  # vReset
              0043 dc7d  st   $7d,[y,x++] 673   st(lo('RESET_v7'),    [Y,Xpp])
                                          674
                                          675   # Init key variables (Y=1)
              0044 0000  ld   $00         676   ld(0)
              0045 c200  st   [$00]       677   st([0])                         # Carry lookup ([0x80] in 1st line of vBlank)
              0046 c202  st   [$02]       678   st([channel])
              0047 c22c  st   [$2c]       679   st([soundTimer])
              0048 caf5  st   [y,$f5]     680   st([Y, vIrqCtx_v7])
              0049 caf6  st   [y,$f6]     681   st([Y, vIRQ_v5])
              004a caf7  st   [y,$f7]     682   st([Y, vIRQ_v5+1])
              004b caf9  st   [y,$f9]     683   st([Y, videoTop_v5])
              004c 00ff  ld   $ff         684   ld(255)                         # Setup serial input
              004d c20e  st   [$0e]       685   st([frameCount])
              004e c20f  st   [$0f]       686   st([serialRaw])
              004f c210  st   [$10]       687   st([serialLast])
              0050 c211  st   [$11]       688   st([buttonState])
              0051 c212  st   [$12]       689   st([resetTimer])                # resetTimer<0 when entering Main.gcl
              0052 007c  ld   $7c         690   ld(0x7c)
              0053 caf8  st   [y,$f8]     691   st([Y, ctrlBits])
              0054 0200  nop              692   st([ctrlVideo]) if WITH_128K_BOARD else nop()
              0055 0200  nop              693   st([ctrlCopy])  if WITH_128K_BOARD else nop()
                                          694
              0056 000f  ld   $0f         695   ld(0b1111)                      # LEDs |****|
              0057 1880  ld   $80,out     696   ld(syncBits^hSync,OUT)
              0058 18c0  ld   $c0,out     697   ld(syncBits,OUT)
              0059 c213  st   [$13]       698   st([xout])                      # Setup for control by video loop
              005a c214  st   [$14]       699   st([xoutMask])
                                          700
                                          701   # Start
              005b 1401  ld   $01,y       702   ld(hi('startVideo'),Y)          # Enter video loop at vertical blank
              005c e003  jmp  y,$03       703   jmp(Y,'startVideo')
              005d c22e  st   [$2e]       704   st([ledState_v2])               # Setting to 1..126 means "stopped"
                                          705
                                          706   #-----------------------------------------------------------------------
                                          707   # Soft reset
                                          708   #-----------------------------------------------------------------------
                                          709
                                          710   # Resets the gigatron without breaking the video loop.
                                          711   # This mostly consists of executing Reset.gt1.
                                          712   #
                                          713   # This used to be achieved with a SYS_Reset_88 that was removed
                                          714   # from interface.json for ROMv5a in order to prefer achieving this
                                          715   # by jumping to vReset. Instead of a SYS call, this is now
                                          716   # achieved by a secret vCPU instruction RESET_v7 that frees
                                          717   # the [1f2-1f5] space for other purposes.
                                          718
                                          719   # ROM type (see also Docs/GT1-files.txt)
                                          720   romTypeValue = symbol('romTypeValue_DEVROM')
                                          721
                                          722   label('softReset#24')
softReset#24: 005e 0000  ld   $00         723   ld(0)                           #24
              005f c21c  st   [$1c]       724   st([vSP])                       #25 vSP
              0060 c21d  st   [$1d]       725   st([vSP+1])                     #26
              0061 1401  ld   $01,y       726   ld(hi('videoTop_v5'),Y)         #27
              0062 caf9  st   [y,$f9]     727   st([Y,lo('videoTop_v5')])       #28 Show all 120 pixel lines
              0063 caf5  st   [y,$f5]     728   st([Y,vIrqCtx_v7])              #29
              0064 caf6  st   [y,$f6]     729   st([Y,vIRQ_v5])                 #30 Disable vIRQ dispatch
              0065 caf7  st   [y,$f7]     730   st([Y,vIRQ_v5+1])               #31
              0066 c22c  st   [$2c]       731   st([soundTimer])                #32 soundTimer
              0067 c21a  st   [$1a]       732   st([vLR])                       #33 vLR
              0068 c21b  st   [$1b]       733   st([vLR+1])                     #34
              0069 c20b  st   [$0b]       734   st([videoModeC]) if WITH_512K_BOARD else None
              006a 007c  ld   $7c         735   ld(0x7c)                        #35/36
              006b caf8  st   [y,$f8]     736   st([Y,ctrlBits])                #36/37
              006c 0200  nop              737   st([ctrlVideo])  if WITH_128K_BOARD else nop()
              006d 0200  nop              738   st([ctrlCopy])   if WITH_128K_BOARD else nop()
              006e 00fd  ld   $fd         739   ld('nopixels')                  #39/40
                                          740   st([videoModeC]) if not WITH_512K_BOARD else None
              006f c20a  st   [$0a]       741   st([videoModeB])                #41
              0070 c20c  st   [$0c]       742   st([videoModeD])                #42
                                          743   # Set romTypeValue
                                          744   assert (romTypeValue & 7) == 0
              0071 00f8  ld   $f8         745   ld(romTypeValue)                #43 Set ROM type/version and clear channel mask
              0072 c221  st   [$21]       746   st([romType])                   #44
                                          747   # Reset expansion board
              0073 c17f  ctrl $7f         748   ctrl(0b01111111)                #45 Reset signal (default state | 0x3)
              0074 c17c  ctrl $7c         749   ctrl(0b01111100)                #46 Default state.
                                          750   # Adjust ticks
              0075 0115  ld   [$15]       751   ld([vTicks])                    #47 Always load after ctrl
              0076 80ed  adda $ed         752   adda(-38/2)                     #48-38=10
              0077 c215  st   [$15]       753   st([vTicks])                    #11
              0078 0099  ld   $99         754   ld('Reset')                     #12 Reset.gt1 from EPROM
              0079 c224  st   [$24]       755   st([sysArgs+0])                 #13
              007a 00e4  ld   $e4         756   ld(hi('Reset'))                 #14
              007b 1420  ld   $20,y       757   ld(hi('sys_Exec'),Y)            #15
              007c e009  jmp  y,$09       758   jmp(Y,'sys_Exec')               #16
              007d c225  st   [$25]       759   st([sysArgs+1])                 #17
