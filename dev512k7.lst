                                          6020
                                          6021  #-----------------------------------------------------------------------
                                          6022  #       Extended vertical blank logic: game controller decoding
                                          6023  #-----------------------------------------------------------------------
                                          6024
                                          6025  # Entered last line of vertical blank (line 40)
                                          6026  label('vBlankLast#34')
                                          6027
                                          6028  # Game controller types
                                          6029  # TypeA: Based on 74LS165 shift register (not supported)
                                          6030  # TypeB: Based on CD4021B shift register (standard)
                                          6031  # TypeC: Based on priority encoder
                                          6032  #
                                          6033  # Notes:
                                          6034  # - TypeA was only used during development and first beta test, before ROM v1
                                          6035  # - TypeB appears as type A with negative logic levels
                                          6036  # - TypeB is the game controller type that comes with the original kit and ROM v1
                                          6037  # - TypeB is mimicked by BabelFish / Pluggy McPlugface
                                          6038  # - TypeB requires a prolonged /SER_LATCH, therefore vPulse is 8 scanlines, not 2
                                          6039  # - TypeB and TypeC can be sampled in the same scanline
                                          6040  # - TypeA is 1 scanline shifted as it looks at a different edge (XXX up or down?)
                                          6041  # - TypeC gives incomplete information: lower buttons overshadow higher ones
                                          6042  #
                                          6043  #       TypeC    Alias    Button TypeB
                                          6044  #       00000000  ^@   -> Right  11111110
                                          6045  #       00000001  ^A   -> Left   11111101
                                          6046  #       00000011  ^C   -> Down   11111011
                                          6047  #       00000111  ^G   -> Up     11110111
                                          6048  #       00001111  ^O   -> Start  11101111
                                          6049  #       00011111  ^_   -> Select 11011111
                                          6050  #       00111111  ?    -> B      10111111
                                          6051  #       01111111  DEL  -> A      01111111
                                          6052  #       11111111       -> (None) 11111111
                                          6053  #
                                          6054  #       Conversion formula:
                                          6055  #               f(x) := 254 - x
                                          6056
                                          6057  # Detect controller TypeC codes
vBlankLast#34:
              1227 010f  ld   [$0f]       6058  ld([serialRaw])                 #34 if serialRaw in [0,1,3,7,15,31,63,127,255]
              1228 8001  adda $01         6059  adda(1)                         #35
              1229 210f  anda [$0f]       6060  anda([serialRaw])               #36
              122a ec3b  bne  .buttons#39 6061  bne('.buttons#39')              #37
                                          6062
                                          6063  # TypeC
              122b 010f  ld   [$0f]       6064  ld([serialRaw])                 #38 [TypeC] if serialRaw < serialLast
              122c 8001  adda $01         6065  adda(1)                         #39
              122d 2110  anda [$10]       6066  anda([serialLast])              #40
              122e ec32  bne  .buttons#43 6067  bne('.buttons#43')              #41
              122f 00fe  ld   $fe         6068  ld(254)                         #42 then clear the selected bit
              1230 0200  nop              6069  nop()                           #43
              1231 fc35  bra  .buttons#46 6070  bra('.buttons#46')              #44
                                          6071  label('.buttons#43')
.buttons#43:  1232 a10f  suba [$0f]       6072  suba([serialRaw])               #43,45
              1233 2111  anda [$11]       6073  anda([buttonState])             #44
              1234 c211  st   [$11]       6074  st([buttonState])               #45
                                          6075  label('.buttons#46')
.buttons#46:  1235 010f  ld   [$0f]       6076  ld([serialRaw])                 #46 Set the lower bits
              1236 4111  ora  [$11]       6077  ora([buttonState])              #47
                                          6078  label('.buttons#48')
.buttons#48:  1237 c211  st   [$11]       6079  st([buttonState])               #48
              1238 010f  ld   [$0f]       6080  ld([serialRaw])                 #49 Update serialLast for next pass
              1239 e0ba  jmp  y,$ba       6081  jmp(Y,'vBlankLast#52')          #50
              123a c210  st   [$10]       6082  st([serialLast])                #51
                                          6083
                                          6084  # TypeB
                                          6085  # pChange = pNew & ~pOld
                                          6086  # nChange = nNew | ~nOld {DeMorgan}
                                          6087  label('.buttons#39')
.buttons#39:  123b 00ff  ld   $ff         6088  ld(255)                         #39 [TypeB] Bitwise edge-filter to detect button presses
              123c 6110  xora [$10]       6089  xora([serialLast])              #40
              123d 410f  ora  [$0f]       6090  ora([serialRaw])                #41 Catch button-press events
              123e 2111  anda [$11]       6091  anda([buttonState])             #42 Keep active button presses
              123f 410f  ora  [$0f]       6092  ora([serialRaw])                #43
              1240 0200  nop              6093  nop()                           #44
              1241 0200  nop              6094  nop()                           #45
              1242 fc37  bra  .buttons#48 6095  bra('.buttons#48')              #46
              1243 0200  nop              6096  nop()                           #47
