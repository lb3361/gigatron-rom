              0df8 0000  ld   $00         4656  ld(0)                           #14
              0df9 c219  st   [$19]       4657  st([vAC+1])                     #15
              0dfa 1403  ld   $03,y       4658  ld(hi('REENTER'),Y)             #16 Switch in the current time slice
              0dfb 00fa  ld   $fa         4659  ld(-22//2+v6502_adjust)         #17
