                                          3710  #-----------------------------------------------------------------------
                                          3711  # Extension SYS_ReceiveSerial1_v6_32
                                          3712  #-----------------------------------------------------------------------
                                          3713
                                          3714  # SYS function for receiving one byte over the serial controller port.
                                          3715  # This is a public version of SYS_NextByteIn from the loader private
                                          3716  # extension.  A byte is read from IN when videoY reaches
                                          3717  # sysArgs[3]. The byte is added to the checksum sysArgs[2] then stored
                                          3718  # at address sysArgs[0:1] which gets incremented.
                                          3719  #
                                          3720  # The 65 bytes of a serial frame can be read for the following values
                                          3721  # of videoY: 207 (protocol byte) 219 (length, 6 bits only) 235, 251
                                          3722  # (address) then 2, 6, 10, .. 238 stepping by four, then 185.
                                          3723  #
                                          3724  # Variables:
                                          3725  #     sysArgs[0:1] Address
                                          3726  #     sysArgs[2]   Checksum
                                          3727  #     sysArgs[3]   Wait value (videoY)
                                          3728
                                          3729  label('SYS_ReceiveSerial1_v6_32')
SYS_ReceiveSerial1_v6_32:                 3730  bra('sys_ReceiveSerial1')       #15
              0b18 fcb9  bra  sys_ReceiveSerial1
              0b19 0127  ld   [$27]       3731  ld([sysArgs+3])                 #16
                                          3732
