                                          7293  label('se:fin')
se:fin:       165c fc0c  bra  fsm16:LD    7294  fsmAsm('LD', 'SYS_Exec_88')     # restore sysFn
              165d 00ad  ld   $ad
              165e fc0a  bra  fsm16:ST    7295  fsmAsm('ST', sysFn)
              165f 0022  ld   $22
              1660 fc0c  bra  fsm16:LD    7296  fsmAsm('LD', hi('SYS_Exec_88'))
              1661 0000  ld   $00
              1662 fc0a  bra  fsm16:ST    7297  fsmAsm('ST', sysFn+1)
              1663 0023  ld   $23
                                          7298  fsmAsm('VRETNZ')
              1664 fc20  bra  fsm16:VRETNZ
              1665 0066  ld   $66
              1666 fc28  bra  fsm16:LUP   7299  fsmAsm('LUP')
              1667 0068  ld   $68
              1668 fc0a  bra  fsm16:ST    7300  fsmAsm('ST', vLR+1)
              1669 001b  ld   $1b
              166a fc28  bra  fsm16:LUP   7301  fsmAsm('LUP')
              166b 006c  ld   $6c
              166c fc0a  bra  fsm16:ST    7302  fsmAsm('ST', vLR)
              166d 001a  ld   $1a
                                          7303  label('se:ret')
                                          7304  fsmAsm('VRETNZ')
se:ret:       166e fc20  bra  fsm16:VRETNZ
              166f 0070  ld   $70
              1670 fc1d  bra  fsm16:BL    7305  fsmAsm('B', 'se:ret')           # don't crash, loop.
              1671 006e  ld   $6e
