              0b0f 1412  ld   $12,y       3676  ld(hi('sys_ResetWaveforms'),Y)  #15 Initial setup of waveforms. [vAC+0]=i
              0b10 e05f  jmp  y,$5f       3677  jmp(Y,'sys_ResetWaveforms')     #16
              0b11 1407  ld   $07,y       3678  ld(soundTable>>8,Y)             #17
