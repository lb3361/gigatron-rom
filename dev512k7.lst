              1213 c234  st   [$34]       5994  st([vIrqSave+4])                #92
              1214 09f6  ld   [y,$f6]     5995  ld([Y,vIRQ_v5])                 #93 Set vPC to vIRQ
              1215 a002  suba $02         5996  suba(2)                         #94
              1216 c216  st   [$16]       5997  st([vPC])                       #95
